<%- include('partials/head', { title: 'Admin' }) %>
<%- include('partials/nav') %>

<main class="page-main admin-page">
  <section class="page-hero">
    <div class="container">
      <div class="section-label">Admin Panel</div>
      <h1 class="page-title">Control <span class="glow-text">Centre</span></h1>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- Tab nav -->
      <div class="admin-tabs">
        <button class="admin-tab active" data-tab="event">Event</button>
        <button class="admin-tab" data-tab="questions">Eligibility</button>
        <button class="admin-tab" data-tab="applications" id="applications">
          Applications<% const pendingCount = applications.filter(a=>a.status==='pending').length; if(pendingCount>0){ %><span class="tab-badge"><%= pendingCount %></span><% } %>
        </button>
        <button class="admin-tab" data-tab="bot" id="bot">Bot</button>
        <button class="admin-tab" data-tab="staff" id="staff">Staff</button>
      </div>

      <!-- EVENT TAB -->
      <div class="admin-panel active" id="tab-event">
        <% if (!event) { %>
          <div class="admin-card">
            <h2>Create Event</h2>
            <form action="/admin/event/create" method="POST" class="admin-form">
              <div class="form-field">
                <label class="form-label">Event Title</label>
                <input type="text" name="title" class="form-input" value="500 Player Civilisation Event: 4 Island Experiment" required />
              </div>
              <div class="form-field">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-textarea" rows="4"></textarea>
              </div>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label">Applications Open At</label>
                  <input type="datetime-local" name="opens_at" class="form-input" />
                </div>
                <div class="form-field">
                  <label class="form-label">Applications Close At</label>
                  <input type="datetime-local" name="closes_at" class="form-input" />
                </div>
              </div>
              <button type="submit" class="btn btn-primary">Create Event</button>
            </form>
          </div>
        <% } else { %>
          <div class="admin-card">
            <h2>Edit Event</h2>
            <form action="/admin/event/update" method="POST" class="admin-form">
              <input type="hidden" name="id" value="<%= event.id %>" />
              <div class="form-field">
                <label class="form-label">Event Title</label>
                <input type="text" name="title" class="form-input" value="<%= event.title %>" required />
              </div>
              <div class="form-field">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-textarea" rows="4"><%= event.description || '' %></textarea>
              </div>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label">Opens At</label>
                  <input type="datetime-local" name="opens_at" class="form-input"
                    value="<%= event.opens_at ? new Date(event.opens_at).toISOString().slice(0,16) : '' %>" />
                </div>
                <div class="form-field">
                  <label class="form-label">Closes At</label>
                  <input type="datetime-local" name="closes_at" class="form-input"
                    value="<%= event.closes_at ? new Date(event.closes_at).toISOString().slice(0,16) : '' %>" />
                </div>
              </div>
              <div class="form-field">
                <label class="form-label">Applications Status</label>
                <select name="is_open" class="form-input">
                  <option value="true" <%= event.is_open ? 'selected' : '' %>>Open</option>
                  <option value="false" <%= !event.is_open ? 'selected' : '' %>>Closed</option>
                </select>
              </div>
              <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>
          </div>
        <% } %>
      </div>

      <!-- ELIGIBILITY TAB -->
      <div class="admin-panel" id="tab-questions">
        <div class="admin-card">
          <h2>Eligibility Questions</h2>
          <p class="muted" style="font-size:0.85rem;margin-bottom:1.5rem">These yes/no questions appear at Stage 1 of the application. <strong>Blocking</strong> means a wrong answer immediately disqualifies the applicant. Non-blocking questions are requirements but failing them alone does not disqualify.</p>
          <% if (eligibilityQuestions.length > 0) { %>
            <div class="questions-list">
              <% for (const q of eligibilityQuestions) { %>
                <div class="question-item">
                  <span class="question-order">#<%= q.display_order %></span>
                  <span class="question-text"><%= q.question_text %></span>
                  <span class="question-type-badge" style="background:rgba(78,201,148,0.12);color:#4ec994"><%= q.required_yes ? 'Must say YES' : 'Must say NO' %></span>
                  <span class="question-type-badge" style="<%= q.blocking ? 'background:rgba(220,50,50,0.12);color:#f87171' : 'background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.4)' %>"><%= q.blocking ? 'Blocking' : 'Optional' %></span>
                  <form action="/admin/eligibility/delete" method="POST" style="display:inline">
                    <input type="hidden" name="id" value="<%= q.id %>" />
                    <button type="submit" class="btn-icon btn-delete" onclick="return confirm('Delete this question?')">✕</button>
                  </form>
                </div>
              <% } %>
            </div>
            <hr class="divider" />
          <% } %>
          <h3 style="margin-bottom:1rem">Add Question</h3>
          <form action="/admin/eligibility/add" method="POST" class="admin-form">
            <div class="form-field">
              <label class="form-label">Question Text</label>
              <input type="text" name="question_text" class="form-input" placeholder="e.g. Are you 13 or older?" required />
            </div>
            <div class="form-row">
              <div class="form-field">
                <label class="form-label">Required Answer</label>
                <select name="required_yes" class="form-input">
                  <option value="true">Must answer YES to pass</option>
                  <option value="false">Must answer NO to pass</option>
                </select>
              </div>
              <div class="form-field">
                <label class="form-label">Blocking?</label>
                <select name="blocking" class="form-input">
                  <option value="true">Yes — wrong answer disqualifies</option>
                  <option value="false">No — optional requirement</option>
                </select>
              </div>
              <div class="form-field" style="flex:0.4">
                <label class="form-label">Order</label>
                <input type="number" name="display_order" class="form-input" value="<%= eligibilityQuestions.length %>" min="0" />
              </div>
            </div>
            <button type="submit" class="btn btn-primary">Add Question</button>
          </form>
        </div>
      </div>

      <!-- APPLICATIONS TAB -->
      <div class="admin-panel" id="tab-applications">

        <!-- Stats -->
        <div class="app-stats-bar">
          <% const statTotal = applications.length; %>
          <% const statPending = applications.filter(a=>a.status==='pending').length; %>
          <% const statAccepted = applications.filter(a=>a.status==='accepted').length; %>
          <% const statDeclined = applications.filter(a=>a.status==='declined').length; %>
          <div class="app-stat"><span class="app-stat-n"><%= statTotal %></span><span class="app-stat-l">Total</span></div>
          <div class="app-stat app-stat--pending"><span class="app-stat-n"><%= statPending %></span><span class="app-stat-l">Pending</span></div>
          <div class="app-stat app-stat--accepted"><span class="app-stat-n"><%= statAccepted %></span><span class="app-stat-l">Accepted</span></div>
          <div class="app-stat app-stat--declined"><span class="app-stat-n"><%= statDeclined %></span><span class="app-stat-l">Declined</span></div>
        </div>

        <!-- Controls -->
        <div class="app-controls">
          <div class="app-filter-tabs" id="appFilterTabs">
            <button class="app-filter-tab active" data-filter="all" onclick="filterApps('all',this)">All (<%= statTotal %>)</button>
            <button class="app-filter-tab" data-filter="pending" onclick="filterApps('pending',this)">Pending (<%= statPending %>)</button>
            <button class="app-filter-tab" data-filter="accepted" onclick="filterApps('accepted',this)">Accepted (<%= statAccepted %>)</button>
            <button class="app-filter-tab" data-filter="declined" onclick="filterApps('declined',this)">Declined (<%= statDeclined %>)</button>
          </div>
          <input type="text" class="app-search-input" id="appSearch" placeholder="Search by IGN or Discord..." oninput="filterApps(currentFilter, null)" />
        </div>

        <% if (applications.length === 0) { %>
          <div class="admin-card"><p class="muted">No applications yet.</p></div>
        <% } else { %>
          <div class="admin-card" style="padding:0;overflow:hidden">
            <div class="app-list-head">
              <span>Applicant</span>
              <span>IGN</span>
              <span>Playstyle</span>
              <span>Submitted</span>
              <span>Status</span>
              <span></span>
            </div>
            <div id="appList">
              <% for (const a of applications) { %>
                <div class="app-list-row" data-status="<%= a.status %>" data-search="<%= ((a.ign||'')+(a.discord_tag||'')).toLowerCase() %>">
                  <span class="app-applicant-cell">
                    <img src="<%= a.discord_avatar || '' %>" class="app-avatar" onerror="this.style.display='none'" />
                    <span class="muted" style="font-size:0.8rem">@<%= a.discord_tag || '—' %></span>
                  </span>
                  <span class="app-ign-cell"><%= a.ign || '—' %></span>
                  <span><% if(a.playstyle){ %><span class="playstyle-badge playstyle-<%= a.playstyle %>"><%= a.playstyle %></span><% } else { %>—<% } %></span>
                  <span class="muted" style="font-size:0.8rem"><%= new Date(a.submitted_at).toLocaleDateString('en-GB') %></span>
                  <span><span class="status-badge status-<%= a.status %>"><%= a.status %></span></span>
                  <span><a href="/admin/application/<%= a.id %>" class="btn btn-sm btn-outline">Review</a></span>
                </div>
              <% } %>
            </div>
            <div id="appEmptyMsg" style="display:none;padding:2rem;text-align:center;color:var(--text-muted)">No applications match your search.</div>
          </div>
        <% } %>

        <!-- Accepted roster -->
        <% const accepted = applications.filter(a => a.status === 'accepted'); %>
        <% if (accepted.length > 0) { %>
          <div class="admin-card" style="margin-top:1.5rem">
            <h3>Accepted Players (<%= accepted.length %>)</h3>
            <p class="muted" style="font-size:0.82rem;margin-bottom:1rem">Players confirmed for the event.</p>
            <div class="accepted-roster">
              <% for (const a of accepted) { %>
                <a href="/admin/application/<%= a.id %>" class="accepted-card">
                  <img src="<%= a.discord_avatar || '' %>" class="accepted-avatar" onerror="this.style.display='none'" />
                  <div class="accepted-ign"><%= a.ign || a.discord_tag %></div>
                  <% if (a.playstyle) { %><span class="playstyle-badge playstyle-<%= a.playstyle %>" style="font-size:0.6rem"><%= a.playstyle %></span><% } %>
                </a>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>

      <!-- BOT TAB -->
      <div class="admin-panel" id="tab-bot">
        <% if (guilds.length === 0) { %>
          <div class="admin-card">
            <h2>Bot Settings</h2>
            <p class="muted">The bot hasn't been active in any server yet. Once it receives its first message, the server will appear here.</p>
          </div>
        <% } else { %>
          <% for (const guild of guilds) { %>
            <div class="admin-card">
              <h2>Server: <code><%= guild.guild_id %></code></h2>
              <form action="/admin/bot/xp" method="POST" class="admin-form">
                <input type="hidden" name="guild_id" value="<%= guild.guild_id %>" />
                <div class="form-row">
                  <div class="form-field">
                    <label class="form-label">XP per Message</label>
                    <input type="number" name="xp_per_message" class="form-input" value="<%= guild.xp_per_message %>" min="1" />
                  </div>
                  <div class="form-field">
                    <label class="form-label">Cooldown (seconds)</label>
                    <input type="number" name="xp_cooldown_seconds" class="form-input" value="<%= guild.xp_cooldown_seconds %>" min="0" />
                  </div>
                  <div class="form-field">
                    <label class="form-label">Level-Up Channel ID</label>
                    <input type="text" name="level_up_channel_id" class="form-input" value="<%= guild.level_up_channel_id || '' %>" />
                  </div>
                </div>
                <button type="submit" class="btn btn-primary">Save XP Settings</button>
              </form>

              <hr class="divider" />

              <h3>Veteran Role</h3>
              <p class="muted" style="font-size:0.85rem;margin-bottom:1rem">Automatically assigns a role to members who joined the server 6+ months ago. Uses Discord's actual join date — works for members who joined before the bot.</p>
              <form action="/admin/bot/veteran" method="POST" class="admin-form">
                <input type="hidden" name="guild_id" value="<%= guild.guild_id %>" />
                <div class="form-row">
                  <div class="form-field">
                    <label class="form-label">Veteran Role ID</label>
                    <input type="text" name="veteran_role_id" class="form-input" value="<%= guild.veteran_role_id || '' %>" placeholder="Right-click role in Discord, Copy ID" />
                  </div>
                  <div class="form-field" style="flex:0.4">
                    <label class="form-label">Months threshold</label>
                    <input type="number" name="veteran_months" class="form-input" value="<%= guild.veteran_months || 6 %>" min="1" max="60" />
                  </div>
                </div>
                <button type="submit" class="btn btn-primary">Save Veteran Role</button>
              </form>

              <hr class="divider" />

              <h3>Staff Page Role</h3>
              <p class="muted" style="font-size:0.85rem;margin-bottom:1rem">Members with this Discord role can see unblurred content on the Staff page. Right-click the role in Discord and Copy ID.</p>
              <form action="/admin/bot/staff-role" method="POST" class="admin-form">
                <input type="hidden" name="guild_id" value="<%= guild.guild_id %>" />
                <div class="form-field" style="max-width:340px">
                  <label class="form-label">Staff Role ID</label>
                  <input type="text" name="staff_role_id" class="form-input" value="<%= guild.staff_role_id || '' %>" placeholder="Right-click role in Discord, Copy ID" />
                </div>
                <button type="submit" class="btn btn-primary">Save Staff Role</button>
              </form>

              <hr class="divider" />

              <h3>Levels and Roles</h3>
              <p class="muted" style="font-size:0.85rem;margin-bottom:1rem">Role ID is optional. If set, the bot will assign that Discord role when a user reaches that level (and remove the previous level role).</p>
              <form action="/admin/bot/levels" method="POST" class="admin-form">
                <input type="hidden" name="guild_id" value="<%= guild.guild_id %>" />
                <div id="levels-list-<%= guild.guild_id %>">
                  <div class="level-row-head"><span>Level #</span><span>Name</span><span>XP Required</span><span>Role ID (optional)</span><span></span></div>
                  <% const gLevels = levels.filter(l => l.guild_id === guild.guild_id); %>
                  <% const gLevelRoles = levelRoles.filter(l => l.guild_id === guild.guild_id); %>
                  <% for (const lv of gLevels) { %>
                    <% const lr = gLevelRoles.find(r => r.level_number === lv.level_number); %>
                    <div class="level-row level-row--wide">
                      <input type="number" name="level_numbers" class="form-input" value="<%= lv.level_number %>" min="1" />
                      <input type="text" name="level_names" class="form-input" value="<%= lv.level_name %>" />
                      <input type="number" name="level_xp" class="form-input" value="<%= lv.xp_required %>" min="0" />
                      <input type="text" name="level_role_ids" class="form-input" value="<%= lr ? lr.role_id : '' %>" placeholder="Role ID" />
                      <button type="button" class="btn-icon btn-delete" onclick="this.closest('.level-row').remove()">✕</button>
                    </div>
                  <% } %>
                </div>
                <button type="button" class="btn btn-ghost" onclick="addLevelRow('<%= guild.guild_id %>')">+ Add Level</button>
                <button type="submit" class="btn btn-primary" style="margin-left:0.5rem">Save Levels</button>
              </form>
            </div>
          <% } %>
        <% } %>
      </div>

      <!-- STAFF TAB -->
      <div class="admin-panel" id="tab-staff">
        <div class="admin-card">
          <h2>Staff Roles</h2>
          <p class="muted" style="font-size:0.85rem;margin-bottom:1.5rem">Add staff positions shown on the public Staff page. Tick "Blur" to hide that field from non-staff visitors.</p>

          <% for (const sr of staffRoles) { %>
            <form action="/admin/staff/update" method="POST" class="admin-form staff-role-form">
              <input type="hidden" name="id" value="<%= sr.id %>" />
              <div class="form-row" style="align-items:flex-start;gap:0.75rem">
                <div class="form-field" style="flex:0.5">
                  <label class="form-label">Order</label>
                  <input type="number" name="display_order" class="form-input" value="<%= sr.display_order %>" min="0" style="width:70px" />
                </div>
                <div class="form-field" style="flex:2">
                  <label class="form-label">Title</label>
                  <input type="text" name="title" class="form-input" value="<%= sr.title %>" required />
                </div>
                <div class="form-field" style="flex:1.5">
                  <label class="form-label">Pay</label>
                  <input type="text" name="pay" class="form-input" value="<%= sr.pay %>" placeholder="e.g. $10/hr" />
                </div>
                <div class="form-field" style="flex:0;white-space:nowrap;padding-top:1.6rem">
                  <label class="form-label" style="display:flex;align-items:center;gap:0.4rem;cursor:pointer">
                    <input type="checkbox" name="blur_pay" <%= sr.blur_pay ? 'checked' : '' %> /> Blur pay
                  </label>
                </div>
              </div>
              <div class="form-field">
                <label class="form-label">Description</label>
                <div class="fmt-toolbar">
                  <button type="button" class="fmt-btn" onclick="fmtWrap(this,'**','**')" title="Bold"><b>B</b></button>
                  <button type="button" class="fmt-btn" onclick="fmtWrap(this,'__','__')" title="Underline"><u>U</u></button>
                  <span class="fmt-hint">**bold** &nbsp; __underline__ &nbsp; Enter = new line</span>
                </div>
                <textarea name="description" class="form-textarea" rows="4"><%= sr.description %></textarea>
              </div>
              <div class="form-field">
                <label class="form-label" style="display:flex;align-items:center;gap:0.4rem;cursor:pointer">
                  <input type="checkbox" name="blur_description" <%= sr.blur_description ? 'checked' : '' %> /> Blur description
                </label>
              </div>
              <div style="display:flex;gap:0.5rem;margin-top:0.25rem">
                <button type="submit" class="btn btn-primary btn-sm">Save</button>
                <button type="button" class="btn btn-sm" style="background:rgba(220,50,50,0.15);color:#f87171;border:1px solid rgba(220,50,50,0.3)"
                  onclick="if(confirm('Delete this staff role?')){document.getElementById('del-sr-<%= sr.id %>').submit()}">Delete</button>
              </div>
            </form>
            <form id="del-sr-<%= sr.id %>" action="/admin/staff/delete" method="POST" style="display:none">
              <input type="hidden" name="id" value="<%= sr.id %>" />
            </form>
            <hr class="divider" />
          <% } %>

          <h3 style="margin-bottom:1rem"><%= staffRoles.length ? 'Add Another' : 'Add First Staff Role' %></h3>
          <form action="/admin/staff/add" method="POST" class="admin-form">
            <div class="form-row" style="align-items:flex-start;gap:0.75rem">
              <div class="form-field" style="flex:0.5">
                <label class="form-label">Order</label>
                <input type="number" name="display_order" class="form-input" value="<%= staffRoles.length %>" min="0" style="width:70px" />
              </div>
              <div class="form-field" style="flex:2">
                <label class="form-label">Title</label>
                <input type="text" name="title" class="form-input" placeholder="e.g. Event Director" required />
              </div>
              <div class="form-field" style="flex:1.5">
                <label class="form-label">Pay</label>
                <input type="text" name="pay" class="form-input" placeholder="e.g. $10/hr or Volunteer" />
              </div>
              <div class="form-field" style="flex:0;white-space:nowrap;padding-top:1.6rem">
                <label class="form-label" style="display:flex;align-items:center;gap:0.4rem;cursor:pointer">
                  <input type="checkbox" name="blur_pay" /> Blur pay
                </label>
              </div>
            </div>
            <div class="form-field">
              <label class="form-label">Description</label>
              <div class="fmt-toolbar">
                <button type="button" class="fmt-btn" onclick="fmtWrap(this,'**','**')" title="Bold"><b>B</b></button>
                <button type="button" class="fmt-btn" onclick="fmtWrap(this,'__','__')" title="Underline"><u>U</u></button>
                <span class="fmt-hint">**bold** &nbsp; __underline__ &nbsp; Enter = new line</span>
              </div>
              <textarea name="description" class="form-textarea" rows="4" placeholder="What does this role do?"></textarea>
            </div>
            <div class="form-field">
              <label class="form-label" style="display:flex;align-items:center;gap:0.4rem;cursor:pointer">
                <input type="checkbox" name="blur_description" /> Blur description
              </label>
            </div>
            <button type="submit" class="btn btn-primary">Add Staff Role</button>
          </form>
        </div>

        <div class="admin-card">
          <h2>Staff Page Access</h2>
          <p class="muted" style="font-size:0.85rem;margin-bottom:1.5rem">Grant specific people access to see blurred content on the Staff page by their Discord User ID. They must sign in with Discord on the site. Right-click their name in Discord and click Copy User ID (with Developer Mode on).</p>

          <% if (staffAccess.length > 0) { %>
            <div class="staff-access-list">
              <% for (const sa of staffAccess) { %>
                <div class="staff-access-row">
                  <span class="staff-access-id"><%= sa.discord_id %></span>
                  <span class="muted" style="font-size:0.75rem">Added <%= new Date(sa.granted_at).toLocaleDateString() %></span>
                  <form action="/admin/staff/access/remove" method="POST" style="margin:0">
                    <input type="hidden" name="discord_id" value="<%= sa.discord_id %>" />
                    <button type="submit" class="btn btn-sm" style="background:rgba(220,50,50,0.15);color:#f87171;border:1px solid rgba(220,50,50,0.3)" onclick="return confirm('Remove access for <%= sa.discord_id %>?')">Remove</button>
                  </form>
                </div>
              <% } %>
            </div>
            <hr class="divider" />
          <% } %>

          <form action="/admin/staff/access/add" method="POST" class="admin-form" style="display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap">
            <div class="form-field" style="flex:1;min-width:200px;margin:0">
              <label class="form-label">Discord User ID</label>
              <input type="text" name="discord_id" class="form-input" placeholder="e.g. 933421117211815987" required pattern="[0-9]+" title="Numbers only" />
            </div>
            <button type="submit" class="btn btn-primary">Grant Access</button>
          </form>
        </div>
      </div>

    </div>
  </section>
</main>

<script>
  function switchTab(name) {
    document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.admin-panel').forEach(p => p.classList.remove('active'));
    const tab = document.querySelector(`[data-tab="${name}"]`);
    const panel = document.getElementById('tab-' + name);
    if (tab) tab.classList.add('active');
    if (panel) panel.classList.add('active');
    sessionStorage.setItem('adminTab', name);
  }

  // Tab switching
  document.querySelectorAll('.admin-tab').forEach(tab => {
    tab.addEventListener('click', () => switchTab(tab.dataset.tab));
  });

  // Restore tab from hash or sessionStorage
  const hashTab = window.location.hash.replace('#', '');
  const savedTab = sessionStorage.getItem('adminTab');
  const activeTab = hashTab || savedTab || 'event';
  switchTab(activeTab);
  if (hashTab) history.replaceState(null, '', '/admin');

  // Show save toast
  const params = new URLSearchParams(window.location.search);
  if (params.get('saved')) {
    const toast = document.createElement('div');
    const savedVal = params.get('saved');
    const toastMessages = { levels: 'Levels saved!', veteran: 'Veteran role saved!', staffrole: 'Staff role saved!', staff: 'Staff page saved!', xp: 'XP settings saved!', access: 'Staff access updated!', eligibility: 'Eligibility question saved!' };
    toast.textContent = toastMessages[savedVal] || 'Saved!';
    toast.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);background:#4ec994;color:#000;padding:0.75rem 1.5rem;border-radius:8px;font-weight:600;font-size:0.9rem;z-index:999;box-shadow:0 4px 20px rgba(78,201,148,0.4)';
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
    history.replaceState(null, '', '/admin');
  }

  // Application list filter + search
  let currentFilter = 'all';
  function filterApps(filter, btn) {
    if (filter) currentFilter = filter;
    if (btn) {
      document.querySelectorAll('.app-filter-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
    }
    const search = (document.getElementById('appSearch')?.value || '').toLowerCase().trim();
    const rows = document.querySelectorAll('#appList .app-list-row');
    let visible = 0;
    rows.forEach(row => {
      const statusMatch = currentFilter === 'all' || row.dataset.status === currentFilter;
      const searchMatch = !search || (row.dataset.search || '').includes(search);
      const show = statusMatch && searchMatch;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const empty = document.getElementById('appEmptyMsg');
    if (empty) empty.style.display = visible === 0 && rows.length > 0 ? 'block' : 'none';
  }

  function fmtWrap(btn, before, after) {
    const ta = btn.closest('.form-field').querySelector('textarea');
    const start = ta.selectionStart;
    const end = ta.selectionEnd;
    const selected = ta.value.slice(start, end);
    const replacement = before + (selected || 'text') + after;
    ta.setRangeText(replacement, start, end, 'select');
    ta.focus();
    if (!selected) {
      ta.selectionStart = start + before.length;
      ta.selectionEnd = start + before.length + 4;
    }
  }

  function addLevelRow(guildId) {
    const container = document.getElementById('levels-list-' + guildId);
    const row = document.createElement('div');
    row.className = 'level-row level-row--wide';
    row.innerHTML = `
      <input type="number" name="level_numbers" class="form-input" placeholder="#" min="1" />
      <input type="text" name="level_names" class="form-input" placeholder="Level name" />
      <input type="number" name="level_xp" class="form-input" placeholder="XP" min="0" />
      <input type="text" name="level_role_ids" class="form-input" placeholder="Role ID" />
      <button type="button" class="btn-icon btn-delete" onclick="this.closest('.level-row').remove()">✕</button>
    `;
    container.appendChild(row);
  }
</script>

