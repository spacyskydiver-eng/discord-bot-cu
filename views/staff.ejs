<%- include('partials/head', { title: 'Staff' }) %>
<%- include('partials/nav') %>

<main class="page-main">
  <section class="page-hero">
    <div class="container">
      <div class="section-label reveal">The Team</div>
      <h1 class="page-title reveal">Meet the <span class="glow-text">Staff</span></h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="staff-grid">
        <div class="staff-card reveal">
          <div class="staff-avatar-wrap">
            <div class="staff-avatar">👑</div>
          </div>
          <h3>Owner</h3>
          <p class="staff-role">Event Director</p>
          <p class="staff-desc">Oversees all event operations, final decisions, and the grand design of the Collective Union experience.</p>
        </div>
        <div class="staff-card reveal">
          <div class="staff-avatar-wrap">
            <div class="staff-avatar">⚔️</div>
          </div>
          <h3>Moderators</h3>
          <p class="staff-role">Event Staff</p>
          <p class="staff-desc">Enforcing the rules, keeping order across 4 islands, and making sure every session runs smoothly.</p>
        </div>
        <div class="staff-card reveal">
          <div class="staff-avatar-wrap">
            <div class="staff-avatar">🏗️</div>
          </div>
          <h3>Builders</h3>
          <p class="staff-role">World Designers</p>
          <p class="staff-desc">The architects behind the 4 handcrafted islands — every biome, altar and terrain feature crafted by hand.</p>
        </div>
      </div>
      <p class="staff-note reveal">Want to join the team? Reach out in our Discord server.</p>
    </div>
  </section>
</main>

<%- include('partials/foot') %>
