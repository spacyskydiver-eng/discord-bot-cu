<%- include('partials/head', { title: 'Staff' }) %>
<%- include('partials/nav') %>

<main class="page-main">
  <section class="page-hero">
    <div class="container">
      <div class="section-label reveal">The Team</div>
      <h1 class="page-title reveal">Meet the <span class="glow-text">Staff</span></h1>
      <% if (!isStaff && staffRoles.some(r => r.blur_pay || r.blur_description)) { %>
        <p class="staff-gate-notice reveal">Some information is restricted to staff members. <% if (!user) { %><a href="/auth/discord" class="inline-link">Sign in with Discord</a> to check your access.<% } else { %>Sign in with a staff account to unlock.<% } %></p>
      <% } %>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <% if (staffRoles.length === 0) { %>
        <p class="muted" style="text-align:center">No staff roles have been added yet.</p>
      <% } else { %>
        <div class="staff-roles-list">
          <% for (const sr of staffRoles) { %>
            <div class="staff-role-card reveal">
              <div class="staff-role-header">
                <h3 class="staff-role-title"><%= sr.title %></h3>
                <div class="staff-role-pay <%= (!isStaff && sr.blur_pay) ? 'blurred' : '' %>">
                  <span class="pay-label">Pay</span>
                  <% if (!isStaff && sr.blur_pay) { %>
                    <span class="blurred-value" title="Staff only">████████</span>
                  <% } else { %>
                    <span><%= sr.pay || 'Not specified' %></span>
                  <% } %>
                </div>
              </div>
              <% if (sr.description) { %>
                <p class="staff-role-desc <%= (!isStaff && sr.blur_description) ? 'blurred' : '' %>">
                  <% if (!isStaff && sr.blur_description) { %>
                    <span class="blurred-value" title="Staff only"><%= sr.description.replace(/./g, '█') %></span>
                  <% } else { %>
                    <%= sr.description %>
                  <% } %>
                </p>
              <% } %>
            </div>
          <% } %>
        </div>
      <% } %>

      <p class="staff-note reveal">Want to join the team? Reach out in our Discord server.</p>
    </div>
  </section>
</main>

<%- include('partials/foot') %>
