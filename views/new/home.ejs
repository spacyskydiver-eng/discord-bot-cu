<%- include('partials/head', { pageTitle: '' }) %>
<%- include('partials/header') %>

<main class="wrap">
  <div class="home">

    <!-- ── Sidebar: logo + description + Discord ── -->
    <aside class="sidebar">
      <div class="logo">CUE<span class="sub">COLLECTIVE UNION EVENTS</span></div>

      <p class="lede">The Collective is a Minecraft event server built for players who want something worth actually showing up for.</p>

      <div class="more" id="moreText">
        <p>We run large scale civilisation events, smaller mini events, and tournaments throughout the year, all built with real investment, custom development, and a standard that most servers in this space simply do not meet. No rushed launches, no half finished ideas, no events that disappear after two weeks.</p>
        <p>The goal is simple. Build the kind of server that people remember being part of.</p>
      </div>

      <button class="showmore" id="showMore" aria-expanded="false">
        <span class="t">Show more</span>
        <span class="chev">▾</span>
      </button>

      <a class="discord" href="https://discord.gg/cuevents" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4.4A19 19 0 0 0 15.3 3l-.3.5a14 14 0 0 1 4 2 16 16 0 0 0-13.4 0 14 14 0 0 1 4-2L9.3 3A19 19 0 0 0 4.6 4.4 20 20 0 0 0 1 18.6 19 19 0 0 0 6.8 21l.6-1a13 13 0 0 1-2-1l.5-.3a13 13 0 0 0 11.2 0l.5.3a13 13 0 0 1-2 1l.6 1A19 19 0 0 0 23 18.6 20 20 0 0 0 20 4.4ZM8.6 15.3c-.9 0-1.7-.9-1.7-2s.8-2 1.7-2 1.7.9 1.7 2-.7 2-1.7 2Zm6.8 0c-.9 0-1.7-.9-1.7-2s.8-2 1.7-2 1.7.9 1.7 2-.7 2-1.7 2Z"/></svg>
        Join our Discord
      </a>
    </aside>

    <!-- ── Tiles: 3 action buttons ── -->
