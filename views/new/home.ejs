      <a href="/events" class="tile events">
        <div class="bgart">
          <svg width="100%" height="100%" preserveAspectRatio="none" viewBox="0 0 600 160" xmlns="http://www.w3.org/2000/svg">
            <defs><linearGradient id="ev" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#5fb0f7"/><stop offset="1" stop-color="#1c4f82"/></linearGradient></defs>
            <g opacity="0.5" stroke="#bfe1ff" stroke-width="2" fill="none">
              <path d="M0 40 L60 20 L120 50 L180 18 L240 46 L300 22 L360 48 L420 20 L480 44 L540 22 L600 42"/>
              <path d="M0 120 L80 138 L160 110 L240 140 L320 112 L400 142 L480 112 L560 138 L600 120"/>
            </g>
            <g fill="url(#ev)" opacity="0.85">
              <polygon points="430,30 470,60 450,110 410,80"/><polygon points="500,55 535,80 520,120 488,95"/>
            </g>
          </svg>
        </div>
        <div class="ico">
          <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <polygon points="50,8 78,30 64,86 36,86 22,30" fill="#cfe9ff"/>
            <polygon points="50,8 78,30 50,44 22,30" fill="#9fd0ff"/>
            <polygon points="22,30 50,44 36,86" fill="#6fb6f5"/>
            <polygon points="78,30 50,44 64,86" fill="#4d97e0"/>
          </svg>
        </div>
        <div class="label">
          <h3>Upcoming Events</h3>
          <p>See what's coming next</p>
        </div>
      </a>

      <a href="/applications" class="tile apps">
        <div class="bgart">
          <svg width="100%" height="100%" preserveAspectRatio="none" viewBox="0 0 600 160" xmlns="http://www.w3.org/2000/svg">
            <g fill="#7df3a6" opacity="0.85">
              <polygon points="420,28 460,58 442,108 404,78"/><polygon points="495,52 528,78 512,116 482,92"/>
              <polygon points="360,70 386,90 374,120 350,100"/>
            </g>
            <g opacity="0.4" stroke="#a8ffce" stroke-width="2" fill="none">
              <path d="M30 0 C 60 40, 10 70, 50 110 S 30 150, 70 160"/>
              <path d="M120 0 C 150 35, 100 65, 140 110"/>
            </g>
          </svg>
        </div>
        <div class="ico">
          <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <polygon points="50,8 78,30 64,86 36,86 22,30" fill="#bcffd6"/>
            <polygon points="50,8 78,30 50,44 22,30" fill="#7df3a6"/>
            <polygon points="22,30 50,44 36,86" fill="#34d178"/>
            <polygon points="78,30 50,44 64,86" fill="#1f9c54"/>
          </svg>
        </div>
        <div class="label">
          <h3>Applications</h3>
          <p>Apply to join an event</p>
        </div>
      </a>

      <a href="/store" class="tile store">
        <div class="bgart">
          <svg width="100%" height="100%" preserveAspectRatio="none" viewBox="0 0 600 160" xmlns="http://www.w3.org/2000/svg">
            <g fill="#ffe08a" opacity="0.85">
              <polygon points="430,30 466,58 450,106 412,80"/><polygon points="500,55 532,80 518,116 486,92"/>
            </g>
            <g opacity="0.25" fill="#fff">
              <circle cx="120" cy="40" r="2.5"/><circle cx="200" cy="90" r="2"/><circle cx="80" cy="110" r="2"/>
              <circle cx="300" cy="50" r="2"/><circle cx="260" cy="120" r="2.5"/>
            </g>
          </svg>
        </div>
        <div class="ico">
          <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <polygon points="50,8 78,30 64,86 36,86 22,30" fill="#fff0c0"/>
            <polygon points="50,8 78,30 50,44 22,30" fill="#ffe08a"/>
