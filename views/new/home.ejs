<script>
document.getElementById('showMore').addEventListener('click', function() {
  var m = document.getElementById('moreText');
  var open = m.classList.toggle('open');
  this.classList.toggle('open', open);
  this.querySelector('.t').textContent = open ? 'Show less' : 'Show more';
  this.setAttribute('aria-expanded', open);
});

document.getElementById('planToggle').addEventListener('click', function() {
  var body = document.getElementById('planBody');
  var expanded = this.getAttribute('aria-expanded') === 'true';
  this.setAttribute('aria-expanded', !expanded);
  body.classList.toggle('open', !expanded);
});

// Countdown to Saturday 11 July 2026 17:00 BST (16:00 UTC)
(function() {
  var target = new Date('2026-07-11T16:00:00Z').getTime();
  function tick() {
    var diff = target - Date.now();
    if (diff <= 0) {
      ['cdDays','cdHours','cdMins','cdSecs'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.textContent = '00';
      });
      return;
    }
    var d = Math.floor(diff / 86400000);
    var h = Math.floor(diff / 3600000) % 24;
    var m = Math.floor(diff / 60000) % 60;
    var s = Math.floor(diff / 1000) % 60;
    function pad(n) { return String(n).padStart(2, '0'); }
    document.getElementById('cdDays').textContent  = d;
    document.getElementById('cdHours').textContent = pad(h);
    document.getElementById('cdMins').textContent  = pad(m);
    document.getElementById('cdSecs').textContent  = pad(s);
  }
  tick();
  setInterval(tick, 1000);
})();
</script>
