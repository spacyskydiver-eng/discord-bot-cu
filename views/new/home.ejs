<%- include('partials/head', { pageTitle: '' }) %>
<%- include('partials/header') %>

<main class="nd-home">
  <div class="nd-home-grid">

    <!-- ── Left: brand + description ── -->
    <aside class="nd-home-left">

      <div class="nd-logo-wrap">
        <span class="nd-logo-badge">CUE</span>
        <span class="nd-logo-divider"></span>
        <div class="nd-logo-text-wrap">
          <div class="nd-logo-title">Collective<br>Union Events</div>
          <div class="nd-logo-sub">Est. 2025</div>
        </div>
      </div>
      <div class="nd-official-tag">Official Community Server</div>

      <p class="nd-desc-short">
        Collective Union Events is a competitive Minecraft civilisation server where players build empires, forge alliances, and compete across hand-crafted island worlds.
      </p>

      <div class="nd-desc-more" id="desc-more">
        <p>
          Each event drops players onto unique themed islands — jungle, snow, badlands, forest — where they must gather resources, establish settlements, and navigate diplomacy with neighbouring civilisations.
        </p>
        <p>
          We focus on creating an immersive, server-wide narrative. Every decision matters: from who you trade with to when you declare war. The strongest civilisation at the end of the event earns bragging rights and a share of the prize pool.
        </p>
        <p>
          Applications are reviewed by our team across multiple stages to ensure every player adds to the experience. Content creators are especially welcome.
        </p>
      </div>

      <button class="nd-btn-more" id="btn-more" onclick="toggleMore()">
        <span id="btn-more-arrow">▼</span> &nbsp;SHOW MORE
      </button>

      <a href="https://discord.gg/cuevents" target="_blank" rel="noopener" class="nd-btn-discord">
        <svg width="18" height="14" viewBox="0 0 71 55" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M60.1 4.6A58.7 58.7 0 0 0 45.5.3a.2.2 0 0 0-.2.1 40.9 40.9 0 0 0-1.8 3.7 54.2 54.2 0 0 0-16.3 0A37.5 37.5 0 0 0 25.4.4a.2.2 0 0 0-.2-.1 58.6 58.6 0 0 0-14.6 4.3.2.2 0 0 0-.1.1C1.6 19 -.9 33 .3 46.8c0 .1.1.2.2.2a59 59 0 0 0 17.7 9 .2.2 0 0 0 .2-.1c1.4-1.9 2.6-3.9 3.7-6a.2.2 0 0 0-.1-.3 38.8 38.8 0 0 1-5.5-2.6.2.2 0 0 1 0-.4l1.1-.9a.2.2 0 0 1 .2 0c11.5 5.3 24 5.3 35.4 0a.2.2 0 0 1 .2 0l1.1.9a.2.2 0 0 1 0 .4 36.2 36.2 0 0 1-5.5 2.6.2.2 0 0 0-.1.3c1.1 2.1 2.3 4.1 3.7 6a.2.2 0 0 0 .2.1 58.8 58.8 0 0 0 17.8-9 .2.2 0 0 0 .1-.2C73 30.9 69.2 17.1 60.2 4.7a.2.2 0 0 0-.1-.1zM23.7 38.6c-3.5 0-6.4-3.2-6.4-7.2s2.8-7.2 6.4-7.2c3.6 0 6.5 3.3 6.4 7.2 0 4-2.8 7.2-6.4 7.2zm23.7 0c-3.5 0-6.4-3.2-6.4-7.2s2.8-7.2 6.4-7.2c3.6 0 6.5 3.3 6.4 7.2 0 4-2.8 7.2-6.4 7.2z" fill="currentColor"/></svg>
        JOIN DISCORD
      </a>

    </aside>

    <!-- ── Right: action cards ── -->
    <section class="nd-home-right">

      <a href="/events" class="nd-action-card nd-action-events">
        <div class="nd-card-bg"></div>
        <div class="nd-card-icon-zone">
          <div class="nd-card-icon-placeholder">⚔️</div>
        </div>
        <div class="nd-card-text">
          <div class="nd-card-title">Upcoming Events</div>
          <div class="nd-card-sub">View all seasons &amp; matches</div>
          <% if (locals.openEventCount > 0) { %>
            <span class="nd-card-badge" style="border-color:rgba(59,130,246,0.4);color:#60a5fa;"><%= openEventCount %> live</span>
          <% } %>
        </div>
        <span class="nd-card-arrow">›</span>
      </a>

      <a href="/applications" class="nd-action-card nd-action-apply">
        <div class="nd-card-bg"></div>
        <div class="nd-card-icon-zone">
          <div class="nd-card-icon-placeholder">📜</div>
        </div>
        <div class="nd-card-text">
          <div class="nd-card-title">Applications</div>
          <div class="nd-card-sub">Apply to compete</div>
          <% if (locals.openAppCount > 0) { %>
            <span class="nd-card-badge" style="border-color:rgba(22,163,74,0.4);color:#4ade80;"><%= openAppCount %> open</span>
          <% } %>
        </div>
        <span class="nd-card-arrow">›</span>
      </a>

      <a href="/store" class="nd-action-card nd-action-store">
        <div class="nd-card-bg"></div>
        <div class="nd-card-icon-zone">
          <div class="nd-card-icon-placeholder">👑</div>
        </div>
        <div class="nd-card-text">
          <div class="nd-card-title">Store</div>
          <div class="nd-card-sub">VIP &amp; VIP+ cosmetic ranks</div>
        </div>
        <span class="nd-card-arrow">›</span>
      </a>

    </section>
  </div>
</main>

<%- include('partials/foot') %>

<script>
function toggleMore() {
  const el = document.getElementById('desc-more');
  const btn = document.getElementById('btn-more');
  const arrow = document.getElementById('btn-more-arrow');
  const open = el.style.maxHeight && el.style.maxHeight !== '0px';
  if (open) {
    el.style.maxHeight = '0px';
    el.style.opacity = '0';
    btn.innerHTML = '<span id="btn-more-arrow">▼</span> &nbsp;SHOW MORE';
  } else {
    el.style.maxHeight = el.scrollHeight + 'px';
    el.style.opacity = '1';
    btn.innerHTML = '<span id="btn-more-arrow">▲</span> &nbsp;SHOW LESS';
  }
}
</script>
