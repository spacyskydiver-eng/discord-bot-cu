/* ── Discord markdown parser ── */
function parseDiscord(raw) {
  if (!raw) return '';
  // Escape HTML
  let s = raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  // Fenced code blocks (preserve content)
  const codeBlocks = [];
  s = s.replace(/```(?:[a-zA-Z]*\n)?([\s\S]*?)```/g, (_, code) => {
    const i = codeBlocks.length;
    codeBlocks.push(`<div class="wh-code-block">${code.trim()}</div>`);
    return `\x00cb${i}\x00`;
  });
  // Inline code
  const inlineCodes = [];
  s = s.replace(/`([^`\n]+)`/g, (_, code) => {
    const i = inlineCodes.length;
    inlineCodes.push(`<span class="wh-inline-code">${code}</span>`);
    return `\x00ic${i}\x00`;
  });

  // Spoiler
  s = s.replace(/\|\|(.+?)\|\|/g, '<span class="wh-spoiler">$1</span>');
  // Bold+italic
  s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
  // Bold
  s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  // Underline+bold
  s = s.replace(/__\*\*(.+?)\*\*__/g, '<u><strong>$1</strong></u>');
  // Underline
  s = s.replace(/__(.+?)__/g, '<u>$1</u>');
  // Italic * and _
  s = s.replace(/\*([^*\n]+)\*/g, '<em>$1</em>');
  s = s.replace(/(?<![a-zA-Z0-9])_([^_\n]+)_(?![a-zA-Z0-9])/g, '<em>$1</em>');
  // Strikethrough
  s = s.replace(/~~(.+?)~~/g, '<del>$1</del>');

  // Headings (line-start)
  s = s.replace(/^### (.+)$/gm, '<span class="wh-h3">$1</span>');
  s = s.replace(/^## (.+)$/gm, '<span class="wh-h2">$1</span>');
  s = s.replace(/^# (.+)$/gm, '<span class="wh-h1">$1</span>');
  // Blockquotes (multi-line)
  s = s.replace(/^&gt; (.+)$/gm, '<span class="wh-blockquote">$1</span>');

  // Custom Discord emojis  <:name:id>  or  <a:name:id>
  s = s.replace(/&lt;(a?):(\w+):(\d+)&gt;/g, '<span class="wh-custom-emoji" title="$2">:$2:</span>');

  // Newlines → <br>
  s = s.replace(/\n/g, '<br>');

  // Restore code blocks
  codeBlocks.forEach((b, i) => { s = s.replace(`\x00cb${i}\x00`, b); });
  inlineCodes.forEach((c, i) => { s = s.replace(`\x00ic${i}\x00`, c); });

  return s;
}

/* ── Formatting toolbar ── */
function whFmt(taId, before, after) {
  const ta = document.getElementById(taId);
  const s = ta.selectionStart, e = ta.selectionEnd;
  const sel = ta.value.slice(s, e);
  const rep = before + (sel || 'text') + after;
  ta.setRangeText(rep, s, e, 'select');
  ta.focus();
  if (!sel) { ta.selectionStart = s + before.length; ta.selectionEnd = s + before.length + 4; }
  updatePreview();
}

