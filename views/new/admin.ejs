<script>
/* ── Tab switching ── */
function switchTab(name) {
  document.querySelectorAll('.nd-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.nd-panel').forEach(p=>p.classList.remove('active'));
  const tab = document.querySelector(`[data-tab="${name}"]`);
  const panel = document.getElementById('tab-'+name);
  if(tab) tab.classList.add('active');
  if(panel) panel.classList.add('active');
  sessionStorage.setItem('adminTab',name);
}
document.querySelectorAll('.nd-tab').forEach(t=>t.addEventListener('click',()=>switchTab(t.dataset.tab)));
const hashTab = window.location.hash.replace('#','');
switchTab(hashTab || sessionStorage.getItem('adminTab') || 'event');
if(hashTab) history.replaceState(null,'','/admin');

/* ── Toast ── */
const params = new URLSearchParams(window.location.search);
if(params.get('saved')){
  const msgs={levels:'Levels saved!',veteran:'Veteran role saved!',staffrole:'Staff role saved!',staff:'Staff page saved!',xp:'XP settings saved!',access:'Staff access updated!',eligibility:'Question saved!',stages:'Stage saved!'};
  const toast=document.createElement('div');
  toast.textContent=msgs[params.get('saved')]||'Saved!';
  toast.style.cssText='position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);background:#4ec994;color:#000;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;z-index:999;box-shadow:0 4px 20px rgba(78,201,148,.4);font-family:"Baloo 2"';
  document.body.appendChild(toast);
  setTimeout(()=>toast.remove(),3000);
  history.replaceState(null,'','/admin');
}

/* ── Application filter ── */
let currentFilter='all';
function filterApps(filter,btn){
  if(filter) currentFilter=filter;
  if(btn){document.querySelectorAll('.nd-filter-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');}
  const search=(document.getElementById('appSearch')?.value||'').toLowerCase().trim();
  const rows=document.querySelectorAll('#appList .nd-app-row');
  let visible=0;
  rows.forEach(row=>{
    let sm;
    if(currentFilter==='all') sm=true;
    else if(currentFilter.startsWith('stage')) sm=row.dataset.status==='pending'&&row.dataset.stage===currentFilter;
    else sm=row.dataset.status===currentFilter;
    const qm=!search||(row.dataset.search||'').includes(search);
    const show=sm&&qm;
    row.style.display=show?'':'none';
    if(show) visible++;
  });
  const empty=document.getElementById('appEmptyMsg');
  if(empty) empty.style.display=visible===0&&rows.length>0?'block':'none';
}

/* ── Stage accordion ── */
function toggleAcc(sn){
  const body=document.getElementById('nd-body-'+sn);
  const arrow=document.getElementById('nd-arr-'+sn);
  const open=body.style.display!=='none';
  body.style.display=open?'none':'block';
  arrow.textContent=open?'▶':'▼';
  if(!open) sessionStorage.setItem('openStage',sn);
}
(function(){
  const sp=new URLSearchParams(window.location.search).get('stage')||sessionStorage.getItem('openStage')||'1';
  const sn=parseInt(sp);
  if(sn>=1&&sn<=6){const b=document.getElementById('nd-body-'+sn);const a=document.getElementById('nd-arr-'+sn);if(b){b.style.display='block';a.textContent='▼';}}
})();

/* ── Block form labels ── */
function updateBlockForm(sel){
  const form=sel.closest('.sb-add-form');
  const type=sel.value;
  const sf=form.querySelector('.sb-style-field');
  const cl=form.querySelector('.sb-content-label');
  const ll=form.querySelector('.sb-label-label');
  const ta=form.querySelector('[name="content"]');
  if(type==='text'){sf.style.display='';cl.textContent='Text Content';ta.placeholder='Enter text...';ll.textContent='Caption (unused for text)'}
  else if(type==='image'){sf.style.display='none';cl.textContent='Image URL';ta.placeholder='https://example.com/image.png';ll.textContent='Caption (shown below image)'}
  else if(type==='video'){sf.style.display='none';cl.textContent='Video URL (YouTube or direct)';ta.placeholder='https://youtu.be/...';ll.textContent='Caption (shown below video)'}
  else if(type==='timestamp'){sf.style.display='none';cl.textContent='Date & Time (UTC)';ta.placeholder='2026-07-15T18:00:00Z';ll.textContent='Label (e.g. "Event Starts")'}
}
document.querySelectorAll('.sb-add-form [name="block_type"]').forEach(sel=>updateBlockForm(sel));

/* ── Format helpers ── */
function fmtWrap(btn,before,after){
  const ta=btn.closest('.nd-form-field').querySelector('textarea');
  const s=ta.selectionStart,e=ta.selectionEnd;
  const sel=ta.value.slice(s,e);
  const rep=before+(sel||'text')+after;
  ta.setRangeText(rep,s,e,'select');
  ta.focus();
  if(!sel){ta.selectionStart=s+before.length;ta.selectionEnd=s+before.length+4;}
}

/* ── Level rows ── */
function addLevelRow(guildId){
  const container=document.getElementById('nd-levels-'+guildId);
  const row=document.createElement('div');
  row.className='nd-level-row';
  row.innerHTML=`<input type="number" name="level_numbers" class="nd-input nd-btn-sm" placeholder="#" min="1"><input type="text" name="level_names" class="nd-input nd-btn-sm" placeholder="Level name"><input type="number" name="level_xp" class="nd-input nd-btn-sm" placeholder="XP" min="0"><input type="text" name="level_role_ids" class="nd-input nd-btn-sm" placeholder="Role ID"><button type="button" class="nd-btn-icon" onclick="this.closest('.nd-level-row').remove()">✕</button>`;
  container.appendChild(row);
}

/* ════════════════════════════════════════
   WEBHOOK BUILDER
════════════════════════════════════════ */

let currentMsgId = null;

/* ── Saved webhook URLs (localStorage) ── */
function loadSavedWebhooks(){
  const saved=JSON.parse(localStorage.getItem('wh_saved')||'[]');
  const list=document.getElementById('wh-saved-list');
  list.innerHTML='';
  saved.forEach((url,i)=>{
    const row=document.createElement('div');
    row.className='wh-saved-row';
    row.innerHTML=`<div class="wh-saved-item" onclick="document.getElementById('wh-url').value='${url.replace(/'/g,"\\'")}';updatePreview()"><code>${url}</code></div><button class="nd-btn-icon" onclick="deleteWebhook(${i})" title="Remove">✕</button>`;
    list.appendChild(row);
  });
}
function saveWebhook(){
  const url=document.getElementById('wh-url').value.trim();
  if(!url.startsWith('https://discord.com/api/webhooks/')&&!url.startsWith('https://discord.gg/')) return alert('Please enter a valid Discord webhook URL (https://discord.com/api/webhooks/...)');
  const saved=JSON.parse(localStorage.getItem('wh_saved')||'[]');
  if(!saved.includes(url)) saved.push(url);
  localStorage.setItem('wh_saved',JSON.stringify(saved));
  loadSavedWebhooks();
}
function deleteWebhook(i){
  const saved=JSON.parse(localStorage.getItem('wh_saved')||'[]');
  saved.splice(i,1);
  localStorage.setItem('wh_saved',JSON.stringify(saved));
  loadSavedWebhooks();
}
loadSavedWebhooks();

/* ── Saved Messages (database) ── */
const _msgCache={};
async function loadMessages(){
  const list=document.getElementById('wh-msg-list');
  list.innerHTML='<div class="wh-msg-empty">Loading...</div>';
  try{
    const r=await fetch('/admin/webhook/messages');
    const msgs=await r.json();
    list.innerHTML='';
    if(!msgs.length){list.innerHTML='<div class="wh-msg-empty">No saved messages yet. Fill in the form and click Save Message.</div>';return;}
    msgs.forEach(msg=>{
      _msgCache[msg.id]=msg;
      const d=document.createElement('div');
      d.className='wh-msg-item';
      const date=new Date(msg.updated_at).toLocaleString('en-GB',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
      d.innerHTML=`<span class="wh-msg-name">${escH(msg.name)}</span><span class="wh-msg-date">${date}</span><div style="display:flex;gap:6px"><button class="nd-btn nd-btn-ghost nd-btn-sm" onclick="loadMessage(${msg.id})">Load</button><button class="nd-btn-icon" onclick="deleteMessage(${msg.id})" title="Delete">✕</button></div>`;
      list.appendChild(d);
    });
  }catch(e){list.innerHTML='<div class="wh-msg-empty" style="color:#f87171">Failed to load messages.</div>';}
}

function escH(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

function loadMessage(id){
  const msg=_msgCache[id];
  if(!msg){alert('Message not found — try refreshing.');return;}
  currentMsgId=msg.id;
  const p=msg.payload||{};
  document.getElementById('wh-msg-name').value=msg.name||'';
  if(msg.webhook_url) document.getElementById('wh-url').value=msg.webhook_url;
  document.getElementById('wh-username').value=p.username||'';
  document.getElementById('wh-avatar').value=p.avatar_url||'';
  document.getElementById('wh-content').value=p.content||'';
  const emb=(p.embeds&&p.embeds[0])||{};
  const color=emb.color?'#'+emb.color.toString(16).padStart(6,'0'):'#5865f2';
  document.getElementById('wh-color').value=color;
  document.getElementById('wh-color-hex').value=color;
  document.getElementById('wh-author-name').value=(emb.author&&emb.author.name)||'';
  document.getElementById('wh-author-icon').value=(emb.author&&emb.author.icon_url)||'';
  document.getElementById('wh-author-url').value=(emb.author&&emb.author.url)||'';
  document.getElementById('wh-title').value=emb.title||'';
  document.getElementById('wh-title-url').value=emb.url||'';
  document.getElementById('wh-desc').value=emb.description||'';
  document.getElementById('wh-thumb').value=(emb.thumbnail&&emb.thumbnail.url)||'';
  document.getElementById('wh-image').value=(emb.image&&emb.image.url)||'';
  document.getElementById('wh-footer-text').value=(emb.footer&&emb.footer.text)||'';
  document.getElementById('wh-footer-icon').value=(emb.footer&&emb.footer.icon_url)||'';
  document.getElementById('wh-timestamp').checked=!!emb.timestamp;
  // Fields
  document.getElementById('wh-fields-list').innerHTML='';
  fieldCount=0;
  (emb.fields||[]).forEach(f=>{fieldCount++;const id=fieldCount;const div=document.createElement('div');div.className='wh-field-item';div.id='wh-field-'+id;div.innerHTML=`<div><label class="nd-label" style="font-size:10px">Field Name</label><input type="text" class="nd-input nd-btn-sm wh-fn" oninput="updatePreview()" value="${escH(f.name)}"></div><div><label class="nd-label" style="font-size:10px">Field Value</label><input type="text" class="nd-input nd-btn-sm wh-fv" oninput="updatePreview()" value="${escH(f.value)}"></div><label style="display:flex;flex-direction:column;align-items:center;gap:4px;font-size:11px;color:var(--muted);cursor:pointer;padding-top:18px"><input type="checkbox" class="wh-fi" onchange="updatePreview()"${f.inline?' checked':''}>Inline</label><button class="nd-btn-icon" style="padding-top:18px" onclick="document.getElementById('wh-field-${id}').remove();updatePreview()">✕</button>`;document.getElementById('wh-fields-list').appendChild(div);});
  // Buttons — restore from _meta (has styles + hidden messages), fall back to components
  document.getElementById('wh-btns-list').innerHTML='';
  btnCount=0;
  const metaBtns=(p._meta&&p._meta.buttons)||[];
  if(metaBtns.length){
    metaBtns.forEach(b=>addButton(b));
  } else {
    const comps=p.components||[];
    const btns=comps.length&&comps[0].components?comps[0].components:[];
    btns.forEach(b=>addButton({label:b.label||'',style:b.style||5,url:b.url||'',custom_id:b.custom_id}));
  }
  document.getElementById('wh-editing-badge').style.display='inline';
  updatePreview();
  showStatus('ok','Message loaded — edit and save or send.');
  setTimeout(()=>showStatus('',''),3000);
}

async function saveMessage(){
  const name=document.getElementById('wh-msg-name').value.trim();
  if(!name){alert('Enter a name for this message first.');document.getElementById('wh-msg-name').focus();return;}
  const webhook_url=document.getElementById('wh-url').value.trim()||null;
  const payload=collectPayload();
  try{
    const r=await fetch('/admin/webhook/save',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:currentMsgId,name,webhook_url,payload})});
    const data=await r.json();
    if(data.ok){
      currentMsgId=data.id;
      document.getElementById('wh-editing-badge').style.display='inline';
      showStatus('ok','Message saved!');
      setTimeout(()=>showStatus('',''),3000);
      loadMessages();
    }else{showStatus('err','Save failed: '+(data.error||'unknown error'));}
  }catch(e){showStatus('err','Network error: '+e.message);}
}

async function deleteMessage(id){
  if(!confirm('Delete this saved message?')) return;
  await fetch('/admin/webhook/message/'+id,{method:'DELETE'});
  if(currentMsgId===id){currentMsgId=null;document.getElementById('wh-editing-badge').style.display='none';}
  loadMessages();
}

loadMessages();

/* Buttons */
let btnCount=0;
const BTN_STYLES={1:'primary',2:'secondary',3:'success',4:'danger',5:'link'};

function addButton(opts){
  opts=opts||{};
  if(document.querySelectorAll('.wh-btn-row').length>=5){alert('Maximum 5 buttons per message.');return;}
  btnCount++;
  const id=btnCount;
  const customId=opts.custom_id||('btn_'+Date.now()+'_'+Math.random().toString(36).slice(2,6));
  const style=opts.style||5;
  const isLink=style===5;
  const div=document.createElement('div');
  div.className='wh-btn-row';
  div.id='wh-btn-'+id;
  div.dataset.customId=customId;
  div.innerHTML=`
    <div class="wh-btn-row-top">
      <div><label class="nd-label" style="font-size:10px">Button Label</label><input type="text" class="nd-input nd-btn-sm wh-btn-lbl" placeholder="Click here" oninput="updatePreview()" value="${escH(opts.label||'')}"></div>
