</main>

<%- include('partials/foot') %>

<script>
/* ── Tab switching ── */
function switchTab(name) {
  document.querySelectorAll('.nd-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.nd-panel').forEach(p=>p.classList.remove('active'));
  const tab = document.querySelector(`[data-tab="${name}"]`);
  const panel = document.getElementById('tab-'+name);
  if(tab) tab.classList.add('active');
  if(panel) panel.classList.add('active');
  sessionStorage.setItem('adminTab',name);
}
document.querySelectorAll('.nd-tab').forEach(t=>t.addEventListener('click',()=>switchTab(t.dataset.tab)));
const hashTab = window.location.hash.replace('#','');
switchTab(hashTab || sessionStorage.getItem('adminTab') || 'event');
if(hashTab) history.replaceState(null,'','/admin');

/* ── Toast ── */
const params = new URLSearchParams(window.location.search);
if(params.get('saved')){
  const msgs={levels:'Levels saved!',veteran:'Veteran role saved!',staffrole:'Staff role saved!',staff:'Staff page saved!',xp:'XP settings saved!',access:'Staff access updated!',eligibility:'Question saved!',stages:'Stage saved!'};
  const toast=document.createElement('div');
  toast.textContent=msgs[params.get('saved')]||'Saved!';
  toast.style.cssText='position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);background:#4ec994;color:#000;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;z-index:999;box-shadow:0 4px 20px rgba(78,201,148,.4);font-family:"Baloo 2"';
  document.body.appendChild(toast);
  setTimeout(()=>toast.remove(),3000);
  history.replaceState(null,'','/admin');
}

/* ── Application filter ── */
let currentFilter='all';
function filterApps(filter,btn){
  if(filter) currentFilter=filter;
  if(btn){document.querySelectorAll('.nd-filter-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');}
  const search=(document.getElementById('appSearch')?.value||'').toLowerCase().trim();
  const rows=document.querySelectorAll('#appList .nd-app-row');
  let visible=0;
  rows.forEach(row=>{
    let sm;
    if(currentFilter==='all') sm=true;
    else if(currentFilter.startsWith('stage')) sm=row.dataset.status==='pending'&&row.dataset.stage===currentFilter;
    else sm=row.dataset.status===currentFilter;
    const qm=!search||(row.dataset.search||'').includes(search);
    const show=sm&&qm;
    row.style.display=show?'':'none';
    if(show) visible++;
  });
  const empty=document.getElementById('appEmptyMsg');
  if(empty) empty.style.display=visible===0&&rows.length>0?'block':'none';
}

/* ── Stage accordion ── */
function toggleAcc(sn){
  const body=document.getElementById('nd-body-'+sn);
  const arrow=document.getElementById('nd-arr-'+sn);
  const open=body.style.display!=='none';
  body.style.display=open?'none':'block';
  arrow.textContent=open?'▶':'▼';
  if(!open) sessionStorage.setItem('openStage',sn);
}
(function(){
  const sp=new URLSearchParams(window.location.search).get('stage')||sessionStorage.getItem('openStage')||'1';
  const sn=parseInt(sp);
  if(sn>=1&&sn<=6){const b=document.getElementById('nd-body-'+sn);const a=document.getElementById('nd-arr-'+sn);if(b){b.style.display='block';a.textContent='▼';}}
})();

/* ── Block form labels ── */
function updateBlockForm(sel){
  const form=sel.closest('.sb-add-form');
  const type=sel.value;
  const sf=form.querySelector('.sb-style-field');
  const cl=form.querySelector('.sb-content-label');
  const ll=form.querySelector('.sb-label-label');
  const ta=form.querySelector('[name="content"]');
  if(type==='text'){sf.style.display='';cl.textContent='Text Content';ta.placeholder='Enter text...';ll.textContent='Caption (unused for text)'}
  else if(type==='image'){sf.style.display='none';cl.textContent='Image URL';ta.placeholder='https://example.com/image.png';ll.textContent='Caption (shown below image)'}
  else if(type==='video'){sf.style.display='none';cl.textContent='Video URL (YouTube or direct)';ta.placeholder='https://youtu.be/...';ll.textContent='Caption (shown below video)'}
  else if(type==='timestamp'){sf.style.display='none';cl.textContent='Date & Time (UTC)';ta.placeholder='2026-07-15T18:00:00Z';ll.textContent='Label (e.g. "Event Starts")'}
}
document.querySelectorAll('.sb-add-form [name="block_type"]').forEach(sel=>updateBlockForm(sel));

/* ── Format helpers ── */
function fmtWrap(btn,before,after){
  const ta=btn.closest('.nd-form-field').querySelector('textarea');
  const s=ta.selectionStart,e=ta.selectionEnd;
  const sel=ta.value.slice(s,e);
  const rep=before+(sel||'text')+after;
  ta.setRangeText(rep,s,e,'select');
  ta.focus();
  if(!sel){ta.selectionStart=s+before.length;ta.selectionEnd=s+before.length+4;}
}

/* ── Level rows ── */
function addLevelRow(guildId){
  const container=document.getElementById('nd-levels-'+guildId);
  const row=document.createElement('div');
  row.className='nd-level-row';
  row.innerHTML=`<input type="number" name="level_numbers" class="nd-input nd-btn-sm" placeholder="#" min="1"><input type="text" name="level_names" class="nd-input nd-btn-sm" placeholder="Level name"><input type="number" name="level_xp" class="nd-input nd-btn-sm" placeholder="XP" min="0"><input type="text" name="level_role_ids" class="nd-input nd-btn-sm" placeholder="Role ID"><button type="button" class="nd-btn-icon" onclick="this.closest('.nd-level-row').remove()">✕</button>`;
  container.appendChild(row);
}

/* ════════════════════════════════════════
   WEBHOOK BUILDER
════════════════════════════════════════ */

/* Saved webhooks (localStorage) */
function loadSavedWebhooks(){
  const saved=JSON.parse(localStorage.getItem('wh_saved')||'[]');
  const list=document.getElementById('wh-saved-list');
  list.innerHTML='';
  saved.forEach((url,i)=>{
    const row=document.createElement('div');
    row.className='wh-saved-row';
    row.innerHTML=`<div class="wh-saved-item" onclick="document.getElementById('wh-url').value='${url.replace(/'/g,"\\'")}';updatePreview()"><code>${url}</code></div><button class="nd-btn-icon" onclick="deleteWebhook(${i})" title="Remove">✕</button>`;
    list.appendChild(row);
  });
}
function saveWebhook(){
  const url=document.getElementById('wh-url').value.trim();
  if(!url.startsWith('https://discord.com/api/webhooks/')&&!url.startsWith('https://discord.gg/')) return alert('Please enter a valid Discord webhook URL (https://discord.com/api/webhooks/...)');
  const saved=JSON.parse(localStorage.getItem('wh_saved')||'[]');
  if(!saved.includes(url)) saved.push(url);
  localStorage.setItem('wh_saved',JSON.stringify(saved));
  loadSavedWebhooks();
}
function deleteWebhook(i){
  const saved=JSON.parse(localStorage.getItem('wh_saved')||'[]');
  saved.splice(i,1);
  localStorage.setItem('wh_saved',JSON.stringify(saved));
  loadSavedWebhooks();
}
loadSavedWebhooks();

/* Fields */
let fieldCount=0;
function addField(){
  fieldCount++;
  const id=fieldCount;
  const div=document.createElement('div');
  div.className='wh-field-item';
  div.id='wh-field-'+id;
  div.innerHTML=`<div><label class="nd-label" style="font-size:10px">Field Name</label><input type="text" class="nd-input nd-btn-sm wh-fn" oninput="updatePreview()"></div><div><label class="nd-label" style="font-size:10px">Field Value</label><input type="text" class="nd-input nd-btn-sm wh-fv" oninput="updatePreview()"></div><label style="display:flex;flex-direction:column;align-items:center;gap:4px;font-size:11px;color:var(--muted);cursor:pointer;padding-top:18px"><input type="checkbox" class="wh-fi" onchange="updatePreview()">Inline</label><button class="nd-btn-icon" style="padding-top:18px" onclick="document.getElementById('wh-field-${id}').remove();updatePreview()">✕</button>`;
  document.getElementById('wh-fields-list').appendChild(div);
}

/* Color sync */
function syncColorPicker(){
  const hex=document.getElementById('wh-color-hex').value.trim();
  if(/^#[0-9a-fA-F]{6}$/.test(hex)) document.getElementById('wh-color').value=hex;
  updatePreview();
}

/* Image upload */
async function whUpload(fileInput, targetId) {
  const file = fileInput.files[0];
  if (!file) return;
  const label = fileInput.closest('.wh-upload-btn');
  label.classList.add('loading');
  const fd = new FormData();
  fd.append('image', file);
  try {
    const r = await fetch('/admin/upload-image', { method: 'POST', body: fd });
    const data = await r.json();
    if (data.ok) {
      document.getElementById(targetId).value = window.location.origin + data.url;
      updatePreview();
    } else {
      alert('Upload failed: ' + data.error);
    }
  } catch(e) {
    alert('Upload error: ' + e.message);
  } finally {
    label.classList.remove('loading');
    fileInput.value = '';
  }
}

/* Update live preview */
function updatePreview(){
  const name=document.getElementById('wh-username').value.trim()||'CUE Bot';
  const avatarUrl=document.getElementById('wh-avatar').value.trim();
  document.getElementById('wh-prev-name').textContent=name;
  const avi=document.getElementById('wh-prev-avi');
  avi.src=avatarUrl||'/img/collective-union.png';
  const now=new Date();
  document.getElementById('wh-prev-time').textContent=now.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});

  // Update color hex from picker
  const colorHex=document.getElementById('wh-color').value;
  document.getElementById('wh-color-hex').value=colorHex;

  // Content
  const content=document.getElementById('wh-content').value;
  const contentEl=document.getElementById('wh-prev-content');
  contentEl.textContent=content;
  contentEl.style.display=content?'block':'none';

  // Check if embed has any content
  const authorName=document.getElementById('wh-author-name').value.trim();
  const authorIcon=document.getElementById('wh-author-icon').value.trim();
  const title=document.getElementById('wh-title').value.trim();
  const titleUrl=document.getElementById('wh-title-url').value.trim();
  const desc=document.getElementById('wh-desc').value.trim();
  const thumb=document.getElementById('wh-thumb').value.trim();
  const img=document.getElementById('wh-image').value.trim();
  const footerText=document.getElementById('wh-footer-text').value.trim();
  const footerIcon=document.getElementById('wh-footer-icon').value.trim();
  const hasTimestamp=document.getElementById('wh-timestamp').checked;
  const fields=Array.from(document.querySelectorAll('.wh-field-item')).map(el=>({name:el.querySelector('.wh-fn').value.trim(),value:el.querySelector('.wh-fv').value.trim(),inline:el.querySelector('.wh-fi').checked})).filter(f=>f.name||f.value);

  const hasEmbed=authorName||title||desc||thumb||img||footerText||fields.length>0||hasTimestamp;
  const embedWrap=document.getElementById('wh-prev-embed');
  embedWrap.style.display=hasEmbed?'block':'none';
  if(!hasEmbed) return;

  document.getElementById('wh-prev-embed-inner').style.borderLeftColor=colorHex;

  // Author
  const authorEl=document.getElementById('wh-prev-author');
  const authorNameEl=document.getElementById('wh-prev-author-name');
  const authorIconEl=document.getElementById('wh-prev-author-icon');
  if(authorName){
    authorEl.style.display='flex';
    authorNameEl.textContent=authorName;
    if(authorIcon){authorIconEl.src=authorIcon;authorIconEl.style.display='inline';}
    else authorIconEl.style.display='none';
  } else {authorEl.style.display='none';}

  // Title
  const titleEl=document.getElementById('wh-prev-title');
  if(title){
    titleEl.style.display='block';
    if(titleUrl) titleEl.innerHTML=`<a href="${titleUrl}" style="color:#fff;text-decoration:none" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">${title}</a>`;
    else titleEl.textContent=title;
  } else titleEl.style.display='none';

  // Description
  const descEl=document.getElementById('wh-prev-desc');
  if(desc){descEl.style.display='block';descEl.textContent=desc;}
  else descEl.style.display='none';

  // Fields
  const fieldsEl=document.getElementById('wh-prev-fields');
  fieldsEl.innerHTML='';
  fields.forEach(f=>{
    const d=document.createElement('div');
    d.className='wh-emb-field'+(f.inline?' inline':'');
    d.innerHTML=`<div class="wh-emb-field-name">${f.name}</div><div class="wh-emb-field-val">${f.value}</div>`;
    fieldsEl.appendChild(d);
  });

  // Thumbnail
  const thumbWrap=document.getElementById('wh-prev-thumb-wrap');
  if(thumb){thumbWrap.style.display='block';document.getElementById('wh-prev-thumb').src=thumb;}
  else thumbWrap.style.display='none';

  // Image
  const imgEl=document.getElementById('wh-prev-image');
  if(img){imgEl.src=img;imgEl.style.display='block';}
  else imgEl.style.display='none';

  // Footer
  const footerEl=document.getElementById('wh-prev-footer');
  const footerIconEl=document.getElementById('wh-prev-footer-icon');
  let footerParts=[];
  if(footerText) footerParts.push(footerText);
  if(hasTimestamp) footerParts.push(new Date().toLocaleString('en-GB',{day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}));
  if(footerParts.length||footerIcon){
    footerEl.style.display='flex';
    document.getElementById('wh-prev-footer-text').textContent=footerParts.join(' • ');
    if(footerIcon){footerIconEl.src=footerIcon;footerIconEl.style.display='inline';}
    else footerIconEl.style.display='none';
  } else footerEl.style.display='none';
}

/* Send webhook */
async function sendWebhook(){
  const url=document.getElementById('wh-url').value.trim();
  if(!url.startsWith('https://discord.com/api/webhooks/')){
    showStatus('err','Webhook URL must start with https://discord.com/api/webhooks/');return;
  }
  const colorHex=document.getElementById('wh-color').value;
  const colorInt=parseInt(colorHex.replace('#',''),16);

  const authorName=document.getElementById('wh-author-name').value.trim();
  const authorIcon=document.getElementById('wh-author-icon').value.trim();
  const authorUrl=document.getElementById('wh-author-url').value.trim();
  const title=document.getElementById('wh-title').value.trim();
  const titleUrl=document.getElementById('wh-title-url').value.trim();
  const desc=document.getElementById('wh-desc').value.trim();
  const thumb=document.getElementById('wh-thumb').value.trim();
  const img=document.getElementById('wh-image').value.trim();
  const footerText=document.getElementById('wh-footer-text').value.trim();
  const footerIcon=document.getElementById('wh-footer-icon').value.trim();
  const hasTimestamp=document.getElementById('wh-timestamp').checked;
  const fields=Array.from(document.querySelectorAll('.wh-field-item')).map(el=>({name:el.querySelector('.wh-fn').value.trim(),value:el.querySelector('.wh-fv').value.trim(),inline:el.querySelector('.wh-fi').checked})).filter(f=>f.name&&f.value);

  const embed={color:colorInt};
  if(authorName) embed.author={name:authorName,...(authorIcon?{icon_url:authorIcon}:{}),...(authorUrl?{url:authorUrl}:{})};
  if(title) {embed.title=title;if(titleUrl) embed.url=titleUrl;}
  if(desc) embed.description=desc;
  if(thumb) embed.thumbnail={url:thumb};
  if(img) embed.image={url:img};
  if(fields.length) embed.fields=fields;
  if(footerText||footerIcon) embed.footer={...(footerText?{text:footerText}:{}),...(footerIcon?{icon_url:footerIcon}:{})};
  if(hasTimestamp) embed.timestamp=new Date().toISOString();

  const hasEmbedContent=authorName||title||desc||thumb||img||footerText||fields.length>0||hasTimestamp;

  const payload={};
  const username=document.getElementById('wh-username').value.trim();
  const avatarUrl=document.getElementById('wh-avatar').value.trim();
  const content=document.getElementById('wh-content').value.trim();
  if(username) payload.username=username;
  if(avatarUrl) payload.avatar_url=avatarUrl;
  if(content) payload.content=content;
  if(hasEmbedContent) payload.embeds=[embed];

  if(!payload.content&&!payload.embeds){
    showStatus('err','Add some content or an embed before sending.');return;
  }

  showStatus('','Sending...');
  try{
    const r=await fetch('/admin/webhook/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({webhook_url:url,payload})});
    const data=await r.json();
    if(data.ok) showStatus('ok','Message sent successfully!');
    else showStatus('err','Error: '+data.error);
  }catch(e){showStatus('err','Network error: '+e.message);}
}

function showStatus(type,msg){
  const el=document.getElementById('wh-status');
  el.className='wh-status'+(type?' '+type:'');
  el.textContent=msg;
  el.style.display=msg?'block':'none';
}

function clearAll(){
  ['wh-username','wh-avatar','wh-content','wh-author-name','wh-author-icon','wh-author-url','wh-title','wh-title-url','wh-desc','wh-thumb','wh-image','wh-footer-text','wh-footer-icon'].forEach(id=>{const el=document.getElementById(id);if(el) el.value='';});
  document.getElementById('wh-timestamp').checked=false;
  document.getElementById('wh-color').value='#5865f2';
  document.getElementById('wh-color-hex').value='#5865f2';
  document.getElementById('wh-fields-list').innerHTML='';
  fieldCount=0;
  updatePreview();
}

// Init preview time
updatePreview();
setInterval(()=>{document.getElementById('wh-prev-time').textContent=new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});},30000);
</script>
