    div.dataset.hmPayload=JSON.stringify(opts.response_payload);
    const s=div.querySelector('.wh-btn-hm-summary');
    if(s){s.textContent='✓ Message configured';s.className='wh-btn-hm-summary set';}
  }
  updatePreview();
}

function updateBtnStyle(select){
  const row=select.closest('.wh-btn-row');
  const isLink=select.value==='5';
  row.querySelector('.wh-btn-url-wrap').style.display=isLink?'':'none';
  row.querySelector('.wh-btn-msg-wrap').style.display=isLink?'none':'';
  updatePreview();
}

/* ── Hidden Message Modal ── */
let hmTargetRow=null;
let hmFieldCount=0;

function openHmModal(rowId){
  hmTargetRow=document.getElementById(rowId);
  const payload=hmTargetRow.dataset.hmPayload?JSON.parse(hmTargetRow.dataset.hmPayload):{};
  fillHmFields(payload);
  document.getElementById('wh-hm-overlay').style.display='flex';
  document.body.style.overflow='hidden';
}

function closeHmModal(){
  document.getElementById('wh-hm-overlay').style.display='none';
  document.body.style.overflow='';
  hmTargetRow=null;
}

function toggleHmEmbed(){
  const on=document.getElementById('hm-embed-toggle').checked;
  document.getElementById('hm-embed-section').style.display=on?'':'none';
}

function fillHmFields(p){
  p=p||{};
  document.getElementById('hm-content').value=p.content||'';
  const emb=(p.embeds&&p.embeds[0])||{};
  const hasEmb=!!(p.embeds&&p.embeds.length);
  document.getElementById('hm-embed-toggle').checked=hasEmb;
  document.getElementById('hm-embed-section').style.display=hasEmb?'':'none';
  const color=emb.color?'#'+emb.color.toString(16).padStart(6,'0'):'#5865f2';
  document.getElementById('hm-color').value=color;
  document.getElementById('hm-color-hex').value=color;
  document.getElementById('hm-author-name').value=(emb.author&&emb.author.name)||'';
  document.getElementById('hm-author-icon').value=(emb.author&&emb.author.icon_url)||'';
  document.getElementById('hm-author-url').value=(emb.author&&emb.author.url)||'';
  document.getElementById('hm-title').value=emb.title||'';
  document.getElementById('hm-title-url').value=emb.url||'';
  document.getElementById('hm-desc').value=emb.description||'';
  document.getElementById('hm-thumb').value=(emb.thumbnail&&emb.thumbnail.url)||'';
  document.getElementById('hm-image').value=(emb.image&&emb.image.url)||'';
  document.getElementById('hm-footer-text').value=(emb.footer&&emb.footer.text)||'';
  document.getElementById('hm-footer-icon').value=(emb.footer&&emb.footer.icon_url)||'';
  document.getElementById('hm-timestamp').checked=!!emb.timestamp;
  document.getElementById('hm-fields-list').innerHTML='';
  hmFieldCount=0;
  (emb.fields||[]).forEach(f=>{
    hmFieldCount++;
    const fid=hmFieldCount;
    const div=document.createElement('div');
    div.className='wh-field-item';
    div.id='hm-field-'+fid;
    div.innerHTML=`<div><label class="nd-label" style="font-size:10px">Name</label><input type="text" class="nd-input nd-btn-sm hm-fn" value="${escH(f.name||'')}"></div><div><label class="nd-label" style="font-size:10px">Value</label><input type="text" class="nd-input nd-btn-sm hm-fv" value="${escH(f.value||'')}"></div><label style="display:flex;flex-direction:column;align-items:center;gap:4px;font-size:11px;color:var(--muted);cursor:pointer;padding-top:18px"><input type="checkbox" class="hm-fi"${f.inline?' checked':''}>Inline</label><button class="nd-btn-icon" style="padding-top:18px" onclick="document.getElementById('hm-field-${fid}').remove()">✕</button>`;
    document.getElementById('hm-fields-list').appendChild(div);
  });
}

function addHmField(){
  hmFieldCount++;
  const fid=hmFieldCount;
  const div=document.createElement('div');
  div.className='wh-field-item';
  div.id='hm-field-'+fid;
  div.innerHTML=`<div><label class="nd-label" style="font-size:10px">Name</label><input type="text" class="nd-input nd-btn-sm hm-fn"></div><div><label class="nd-label" style="font-size:10px">Value</label><input type="text" class="nd-input nd-btn-sm hm-fv"></div><label style="display:flex;flex-direction:column;align-items:center;gap:4px;font-size:11px;color:var(--muted);cursor:pointer;padding-top:18px"><input type="checkbox" class="hm-fi">Inline</label><button class="nd-btn-icon" style="padding-top:18px" onclick="document.getElementById('hm-field-${fid}').remove()">✕</button>`;
  document.getElementById('hm-fields-list').appendChild(div);
}

function collectHmPayload(){
  const payload={};
  const content=document.getElementById('hm-content').value.trim();
  if(content) payload.content=content;
  if(document.getElementById('hm-embed-toggle').checked){
    const colorHex=document.getElementById('hm-color').value;
    const colorInt=parseInt(colorHex.replace('#',''),16);
    const emb={color:colorInt};
    const authorName=document.getElementById('hm-author-name').value.trim();
    const authorIcon=document.getElementById('hm-author-icon').value.trim();
    const authorUrl=document.getElementById('hm-author-url').value.trim();
    if(authorName) emb.author={name:authorName,...(authorIcon?{icon_url:authorIcon}:{}),...(authorUrl?{url:authorUrl}:{})};
    const title=document.getElementById('hm-title').value.trim();
    const titleUrl=document.getElementById('hm-title-url').value.trim();
    if(title){emb.title=title;if(titleUrl) emb.url=titleUrl;}
    const desc=document.getElementById('hm-desc').value.trim();
    if(desc) emb.description=desc;
    const thumb=document.getElementById('hm-thumb').value.trim();
    if(thumb) emb.thumbnail={url:thumb};
    const img=document.getElementById('hm-image').value.trim();
    if(img) emb.image={url:img};
    const fields=Array.from(document.querySelectorAll('#hm-fields-list .wh-field-item')).map(el=>({name:el.querySelector('.hm-fn').value.trim(),value:el.querySelector('.hm-fv').value.trim(),inline:el.querySelector('.hm-fi').checked})).filter(f=>f.name&&f.value);
    if(fields.length) emb.fields=fields;
    const footerText=document.getElementById('hm-footer-text').value.trim();
    const footerIcon=document.getElementById('hm-footer-icon').value.trim();
    if(footerText||footerIcon) emb.footer={...(footerText?{text:footerText}:{}),...(footerIcon?{icon_url:footerIcon}:{})};
    if(document.getElementById('hm-timestamp').checked) emb.timestamp=new Date().toISOString();
    const hasEmbed=authorName||title||desc||thumb||img||footerText||fields.length>0||document.getElementById('hm-timestamp').checked;
    if(hasEmbed) payload.embeds=[emb];
  }
  return payload;
}

function applyHmModal(){
  if(!hmTargetRow) return;
  const payload=collectHmPayload();
  hmTargetRow.dataset.hmPayload=JSON.stringify(payload);
  const summary=hmTargetRow.querySelector('.wh-btn-hm-summary');
  const hasContent=payload.content||(payload.embeds&&payload.embeds.length);
  if(summary){
    summary.textContent=hasContent?'✓ Message configured':'Not configured';
    summary.className='wh-btn-hm-summary '+(hasContent?'set':'unset');
  }
  closeHmModal();
}

function clearHmModal(){
  fillHmFields({});
}

