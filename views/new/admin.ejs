let emojiTarget = null;
let allEmojiButtons = null;

function buildEmojiGrid(filter) {
  const grid = document.getElementById('wh-emoji-grid');
  grid.innerHTML = '';
  const q = (filter || '').toLowerCase();
  Object.entries(EMOJI_DATA).forEach(([cat, emojis]) => {
    const matching = q ? emojis.filter(e => e.toLowerCase().includes(q)) : emojis;
    if (!matching.length) return;
    const catEl = document.createElement('div');
    catEl.className = 'wh-e-cat';
    catEl.textContent = cat;
    grid.appendChild(catEl);
    matching.forEach(emoji => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'wh-e-btn';
      btn.textContent = emoji;
      btn.title = emoji;
      btn.onclick = () => insertEmoji(emoji);
      grid.appendChild(btn);
    });
  });
}

function filterEmojis(val) { buildEmojiGrid(val); }

function openEmoji(targetId, triggerBtn) {
  emojiTarget = targetId;
  const panel = document.getElementById('wh-emoji-panel');
  const rect = triggerBtn.getBoundingClientRect();
  panel.style.display = 'flex';
  // Position above or below button
  const spaceBelow = window.innerHeight - rect.bottom;
  if (spaceBelow < 400) {
    panel.style.top = (window.scrollY + rect.top - 400) + 'px';
  } else {
    panel.style.top = (window.scrollY + rect.bottom + 4) + 'px';
  }
  panel.style.left = Math.min(rect.left, window.innerWidth - 340) + 'px';
  document.getElementById('wh-emoji-search').value = '';
  buildEmojiGrid('');
  setTimeout(() => document.getElementById('wh-emoji-search').focus(), 50);
}

function insertEmoji(emoji) {
  if (!emojiTarget) return;
  const ta = document.getElementById(emojiTarget);
  const s = ta.selectionStart, e = ta.selectionEnd;
  ta.setRangeText(emoji, s, e, 'end');
  ta.focus();
  updatePreview();
}

// Close emoji panel when clicking outside
document.addEventListener('click', e => {
  const panel = document.getElementById('wh-emoji-panel');
  if (!panel || panel.style.display === 'none') return;
  if (!panel.contains(e.target) && !e.target.classList.contains('wh-emoji-trigger')) {
    panel.style.display = 'none';
  }
});

/* Image upload */
async function whUpload(fileInput, targetId) {
  const file = fileInput.files[0];
  if (!file) return;
  const label = fileInput.closest('.wh-upload-btn');
  label.classList.add('loading');
  const fd = new FormData();
  fd.append('image', file);
  try {
    const r = await fetch('/admin/upload-image', { method: 'POST', body: fd });
    const data = await r.json();
    if (data.ok) {
      document.getElementById(targetId).value = window.location.origin + data.url;
      updatePreview();
    } else {
      alert('Upload failed: ' + data.error);
    }
  } catch(e) {
    alert('Upload error: ' + e.message);
  } finally {
    label.classList.remove('loading');
    fileInput.value = '';
  }
}

/* Update live preview */
function updatePreview(){
  const name=document.getElementById('wh-username').value.trim()||'CUE Bot';
  const avatarUrl=document.getElementById('wh-avatar').value.trim();
  document.getElementById('wh-prev-name').textContent=name;
  const avi=document.getElementById('wh-prev-avi');
  avi.src=avatarUrl||'/img/collective-union.png';
  const now=new Date();
  document.getElementById('wh-prev-time').textContent=now.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});

  // Update color hex from picker
  const colorHex=document.getElementById('wh-color').value;
  document.getElementById('wh-color-hex').value=colorHex;

  // Content
  const content=document.getElementById('wh-content').value;
  const contentEl=document.getElementById('wh-prev-content');
  contentEl.innerHTML=parseDiscord(content);
  contentEl.style.display=content?'block':'none';

  // Check if embed has any content
  const authorName=document.getElementById('wh-author-name').value.trim();
  const authorIcon=document.getElementById('wh-author-icon').value.trim();
  const title=document.getElementById('wh-title').value.trim();
  const titleUrl=document.getElementById('wh-title-url').value.trim();
  const desc=document.getElementById('wh-desc').value.trim();
  const thumb=document.getElementById('wh-thumb').value.trim();
  const img=document.getElementById('wh-image').value.trim();
  const footerText=document.getElementById('wh-footer-text').value.trim();
  const footerIcon=document.getElementById('wh-footer-icon').value.trim();
  const hasTimestamp=document.getElementById('wh-timestamp').checked;
  const fields=Array.from(document.querySelectorAll('.wh-field-item')).map(el=>({name:el.querySelector('.wh-fn').value.trim(),value:el.querySelector('.wh-fv').value.trim(),inline:el.querySelector('.wh-fi').checked})).filter(f=>f.name||f.value);

  const hasEmbed=authorName||title||desc||thumb||img||footerText||fields.length>0||hasTimestamp;
  const embedWrap=document.getElementById('wh-prev-embed');
  embedWrap.style.display=hasEmbed?'block':'none';
  if(!hasEmbed) return;

  document.getElementById('wh-prev-embed-inner').style.borderLeftColor=colorHex;

  // Author
  const authorEl=document.getElementById('wh-prev-author');
  const authorNameEl=document.getElementById('wh-prev-author-name');
  const authorIconEl=document.getElementById('wh-prev-author-icon');
  if(authorName){
    authorEl.style.display='flex';
    authorNameEl.textContent=authorName;
    if(authorIcon){authorIconEl.src=authorIcon;authorIconEl.style.display='inline';}
    else authorIconEl.style.display='none';
  } else {authorEl.style.display='none';}

  // Title
  const titleEl=document.getElementById('wh-prev-title');
  if(title){
    titleEl.style.display='block';
    if(titleUrl) titleEl.innerHTML=`<a href="${titleUrl}" style="color:#fff;text-decoration:none" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">${title}</a>`;
    else titleEl.textContent=title;
  } else titleEl.style.display='none';

  // Description
  const descEl=document.getElementById('wh-prev-desc');
  if(desc){descEl.style.display='block';descEl.innerHTML=parseDiscord(desc);}
  else descEl.style.display='none';

  // Fields
  const fieldsEl=document.getElementById('wh-prev-fields');
  fieldsEl.innerHTML='';
  fields.forEach(f=>{
    const d=document.createElement('div');
    d.className='wh-emb-field'+(f.inline?' inline':'');
    d.innerHTML=`<div class="wh-emb-field-name">${parseDiscord(f.name)}</div><div class="wh-emb-field-val">${parseDiscord(f.value)}</div>`;
    fieldsEl.appendChild(d);
  });

  // Thumbnail
  const thumbWrap=document.getElementById('wh-prev-thumb-wrap');
  if(thumb){thumbWrap.style.display='block';document.getElementById('wh-prev-thumb').src=thumb;}
  else thumbWrap.style.display='none';

  // Image
  const imgEl=document.getElementById('wh-prev-image');
  if(img){imgEl.src=img;imgEl.style.display='block';}
  else imgEl.style.display='none';

  // Footer
  const footerEl=document.getElementById('wh-prev-footer');
  const footerIconEl=document.getElementById('wh-prev-footer-icon');
  let footerParts=[];
  if(footerText) footerParts.push(footerText);
  if(hasTimestamp) footerParts.push(new Date().toLocaleString('en-GB',{day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}));
  if(footerParts.length||footerIcon){
    footerEl.style.display='flex';
    document.getElementById('wh-prev-footer-text').textContent=footerParts.join(' • ');
    if(footerIcon){footerIconEl.src=footerIcon;footerIconEl.style.display='inline';}
    else footerIconEl.style.display='none';
  } else footerEl.style.display='none';

  // Buttons (preview outside embed)
  const btnRows=Array.from(document.querySelectorAll('.wh-btn-row'));
  const btnsEl=document.getElementById('wh-prev-buttons');
  btnsEl.innerHTML='';
  const validBtns=btnRows.map(r=>{
    const label=r.querySelector('.wh-btn-lbl').value.trim();
    const style=parseInt(r.querySelector('.wh-btn-style')?.value||5);
    const url=r.querySelector('.wh-btn-url')?.value.trim()||'';
    const msg=r.querySelector('.wh-btn-msg')?.value.trim()||'';
    return{label,style,url,msg};
  }).filter(b=>b.label);
  if(validBtns.length){
    btnsEl.style.display='flex';
    validBtns.forEach(b=>{
      const a=document.createElement('a');
      const cls=BTN_STYLES[b.style]||'secondary';
      a.className='wh-disc-btn wh-disc-btn-'+cls;
      a.href='#';
      a.title=b.style===5?(b.url||''):'Hidden message: '+b.msg;
      a.onclick=e=>e.preventDefault();
      const linkIcon=b.style===5?'<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="opacity:.6"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>':'';
      a.innerHTML=linkIcon+escH(b.label);
      btnsEl.appendChild(a);
    });
  } else {
    btnsEl.style.display='none';
  }
}

/* Collect current form state into a Discord payload object */
function collectPayload(){
  const colorHex=document.getElementById('wh-color').value;
  const colorInt=parseInt(colorHex.replace('#',''),16);
  const authorName=document.getElementById('wh-author-name').value.trim();
  const authorIcon=document.getElementById('wh-author-icon').value.trim();
  const authorUrl=document.getElementById('wh-author-url').value.trim();
  const title=document.getElementById('wh-title').value.trim();
  const titleUrl=document.getElementById('wh-title-url').value.trim();
  const desc=document.getElementById('wh-desc').value.trim();
  const thumb=document.getElementById('wh-thumb').value.trim();
  const img=document.getElementById('wh-image').value.trim();
  const footerText=document.getElementById('wh-footer-text').value.trim();
  const footerIcon=document.getElementById('wh-footer-icon').value.trim();
  const hasTimestamp=document.getElementById('wh-timestamp').checked;
  const fields=Array.from(document.querySelectorAll('.wh-field-item')).map(el=>({name:el.querySelector('.wh-fn').value.trim(),value:el.querySelector('.wh-fv').value.trim(),inline:el.querySelector('.wh-fi').checked})).filter(f=>f.name&&f.value);
  const buttonMeta=[];
  const discordBtns=[];
  Array.from(document.querySelectorAll('.wh-btn-row')).forEach(r=>{
    const label=r.querySelector('.wh-btn-lbl').value.trim();
    if(!label) return;
    const style=parseInt(r.querySelector('.wh-btn-style')?.value||5);
    const customId=r.dataset.customId||('btn_'+Date.now()+'_'+Math.random().toString(36).slice(2,6));
    if(style===5){
      const url=r.querySelector('.wh-btn-url')?.value.trim()||'';
      if(!url) return;
      discordBtns.push({type:2,style:5,label,url});
      buttonMeta.push({custom_id:customId,label,style:5,url});
    } else {
      const hmPayload=r.dataset.hmPayload?JSON.parse(r.dataset.hmPayload):null;
      discordBtns.push({type:2,style,label,custom_id:customId});
      buttonMeta.push({custom_id:customId,label,style,response_payload:hmPayload});
    }
  });

  const embed={color:colorInt};
  if(authorName) embed.author={name:authorName,...(authorIcon?{icon_url:authorIcon}:{}),...(authorUrl?{url:authorUrl}:{})};
  if(title){embed.title=title;if(titleUrl) embed.url=titleUrl;}
  if(desc) embed.description=desc;
  if(thumb) embed.thumbnail={url:thumb};
  if(img) embed.image={url:img};
  if(fields.length) embed.fields=fields;
  if(footerText||footerIcon) embed.footer={...(footerText?{text:footerText}:{}),...(footerIcon?{icon_url:footerIcon}:{})};
  if(hasTimestamp) embed.timestamp=new Date().toISOString();

  const hasEmbedContent=authorName||title||desc||thumb||img||footerText||fields.length>0||hasTimestamp;
  const payload={};
  const username=document.getElementById('wh-username').value.trim();
  const avatarUrl=document.getElementById('wh-avatar').value.trim();
  const content=document.getElementById('wh-content').value.trim();
  if(username) payload.username=username;
  if(avatarUrl) payload.avatar_url=avatarUrl;
  if(content) payload.content=content;
  if(hasEmbedContent) payload.embeds=[embed];
  if(discordBtns.length) payload.components=[{type:1,components:discordBtns}];
  payload._meta={buttons:buttonMeta};
  return payload;
}

/* Send webhook */
async function sendWebhook(){
  const url=document.getElementById('wh-url').value.trim();
  if(!url.startsWith('https://discord.com/api/webhooks/')){
    showStatus('err','Webhook URL must start with https://discord.com/api/webhooks/');return;
  }
  const payload=collectPayload();
  const meta=payload._meta||{};
  delete payload._meta;
  if(!payload.content&&!payload.embeds&&!payload.components){
    showStatus('err','Add some content or an embed before sending.');return;
  }
  showStatus('','Sending...');
  try{
    // Save non-link button responses so the bot can reply ephemerally
    const hiddenBtns=(meta.buttons||[]).filter(b=>b.style!==5);
    if(hiddenBtns.length){
      await fetch('/admin/webhook/button-responses',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({buttons:hiddenBtns.map(b=>({custom_id:b.custom_id,response_payload:b.response_payload}))})});
    }
    const r=await fetch('/admin/webhook/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({webhook_url:url,payload})});
    const data=await r.json();
    if(data.ok) showStatus('ok','Message sent successfully!');
    else showStatus('err','Error: '+data.error);
  }catch(e){showStatus('err','Network error: '+e.message);}
}

function showStatus(type,msg){
  const el=document.getElementById('wh-status');
  el.className='wh-status'+(type?' '+type:'');
  el.textContent=msg;
  el.style.display=msg?'block':'none';
}

function clearAll(){
  ['wh-username','wh-avatar','wh-content','wh-author-name','wh-author-icon','wh-author-url','wh-title','wh-title-url','wh-desc','wh-thumb','wh-image','wh-footer-text','wh-footer-icon','wh-msg-name'].forEach(id=>{const el=document.getElementById(id);if(el) el.value='';});
  document.getElementById('wh-timestamp').checked=false;
  document.getElementById('wh-color').value='#5865f2';
  document.getElementById('wh-color-hex').value='#5865f2';
  document.getElementById('wh-fields-list').innerHTML='';
  document.getElementById('wh-btns-list').innerHTML='';
  fieldCount=0;
  btnCount=0;
  currentMsgId=null;
  document.getElementById('wh-editing-badge').style.display='none';
  updatePreview();
}

// Init preview time
updatePreview();
setInterval(()=>{document.getElementById('wh-prev-time').textContent=new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});},30000);
</script>
