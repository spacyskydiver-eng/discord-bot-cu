<header class="nd-header">
  <div class="nd-header-inner">
    <a href="/" class="nd-header-brand">
      <span class="nd-header-name">CUE</span>
    </a>
    <div class="nd-header-right">
      <% if (locals.user) { %>
        <div class="nd-header-user">
          <% if (locals.user.avatar) { %>
            <img class="nd-header-avatar" src="https://cdn.discordapp.com/avatars/<%= locals.user.id %>/<%= locals.user.avatar %>.png" alt="">
          <% } %>
          <span><%= locals.user.globalName || locals.user.username %></span>
        </div>
        <% if (locals.isAdmin) { %>
          <a href="/admin" class="nd-header-login" style="background:rgba(168,30,30,0.25);border-color:rgba(168,30,30,0.4);">Admin</a>
        <% } %>
        <a href="/auth/logout" class="nd-header-login">Logout</a>
      <% } else { %>
        <a href="/auth/login" class="nd-header-login">Login with Discord</a>
      <% } %>
    </div>
  </div>
  <span class="nd-header-edge"></span>
</header>
