<%- include('partials/head', { pageTitle: 'Applications' }) %>
<%- include('partials/header') %>

<%
const ISLAND = {
  jungle: { color:'#2f9e44', name:'Jungle', shade:'#1e5e2e',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path d="M10 4 C 18 14, 4 22, 14 32 S 8 42, 18 46" stroke="#37b24d" stroke-width="3" fill="none" stroke-linecap="round"/><ellipse cx="9" cy="14" rx="5" ry="3" fill="#2f9e44" transform="rotate(-30 9 14)"/><ellipse cx="15" cy="26" rx="5" ry="3" fill="#40c057" transform="rotate(20 15 26)"/><ellipse cx="11" cy="38" rx="5" ry="3" fill="#2f9e44" transform="rotate(-15 11 38)"/><path d="M30 46 L30 26" stroke="#7a5230" stroke-width="3"/><circle cx="30" cy="20" r="10" fill="#2b8a3e"/><circle cx="38" cy="24" r="7" fill="#37b24d"/></svg>`
  },
  snow: { color:'#74c0fc', name:'Snow', shade:'#2b5d7a',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><polygon points="24,6 40,40 8,40" fill="#e7f5ff"/><polygon points="24,6 33,24 15,24" fill="#a5d8ff"/><polygon points="14,40 24,24 34,40" fill="#fff"/><g stroke="#d0ebff" stroke-width="2" stroke-linecap="round"><path d="M24 8 v8 M20 12 h8 M40 14 v6 M37 17 h6"/></g></svg>`
  },
  badlands: { color:'#e8590c', name:'Badlands', shade:'#7a3b12',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="30" width="36" height="12" fill="#d9480f"/><rect x="6" y="24" width="36" height="6" fill="#e8590c"/><rect x="6" y="18" width="36" height="6" fill="#f08c00"/><rect x="14" y="10" width="9" height="20" fill="#e8590c"/><rect x="14" y="6" width="9" height="4" fill="#ffa94d"/><rect x="28" y="14" width="8" height="16" fill="#d9480f"/></svg>`
  },
  forest: { color:'#82c91e', name:'Forest', shade:'#3d6312',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><rect x="22" y="34" width="4" height="10" fill="#7a5230"/><polygon points="24,6 36,24 12,24" fill="#5c940d"/><polygon points="24,14 38,34 10,34" fill="#82c91e"/><polygon points="24,22 40,40 8,40" fill="#a9e34b"/></svg>`
  }
};

function miniArt(theme) {
  if (theme === '4island' || theme === 'multi') {
    return `<div style="position:absolute;inset:0;display:flex">
      <div style="flex:1;background:#1e5e2e"></div><div style="flex:1;background:#2b5d7a"></div>
      <div style="flex:1;background:#7a3b12"></div><div style="flex:1;background:#3d6312"></div></div>
      <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:space-around;padding:0 12px">
      <div style="width:44px;height:44px;flex-shrink:0">${ISLAND.jungle.ico}</div>
      <div style="width:44px;height:44px;flex-shrink:0">${ISLAND.snow.ico}</div>
      <div style="width:44px;height:44px;flex-shrink:0">${ISLAND.badlands.ico}</div>
      <div style="width:44px;height:44px;flex-shrink:0">${ISLAND.forest.ico}</div></div>`;
  }
  const isl = ISLAND[theme];
  const shade = isl ? isl.shade : '#222';
  const ico = isl ? isl.ico : '';
  return `<div style="position:absolute;inset:0;background:linear-gradient(135deg,${shade},#0c0d10)"></div>
    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">
    <div style="width:76px;height:76px">${ico}</div></div>`;
}
%>

<main class="wrap">

  <div class="page-head">
    <a href="/" class="back">← Home</a>
    <div>
      <h1 class="page-title">Applications</h1>
      <p class="page-sub">Open applications can be filled in now. Locked ones show a countdown.</p>
    </div>
  </div>

  <% if (!locals.user) { %>
    <div style="text-align:center;padding:60px 20px;">
      <p style="font-family:'Baloo 2';font-size:18px;color:var(--muted);margin:0 0 20px">Log in with Discord to apply for events.</p>
      <a href="/auth/login" style="display:inline-flex;align-items:center;gap:10px;background:#5865F2;color:#fff;font-family:'Baloo 2';font-weight:800;font-size:16px;padding:13px 24px;border-radius:12px;text-decoration:none;">Login with Discord</a>
    </div>
  <% } else if (events.length === 0) { %>
    <p style="color:var(--muted);font-size:15px;text-align:center;padding:60px 0;">No applications open right now — check back soon!</p>
  <% } else { %>
  <div class="cards">
    <% events.forEach(function(ev) { %>
      <% const theme = ev.theme || 'default'; %>
      <% const isl = ISLAND[theme]; %>
      <% const color = isl ? isl.color : (theme==='4island'?'#2fd96b':'#888'); %>
      <% const open = ev.is_open; %>
      <% const hasApplied = userApp && open; %>

      <% if (open && !hasApplied) { %>
        <a href="/apply" class="card">
      <% } else { %>
        <div class="card<%= !open ? ' locked' : '' %>">
      <% } %>
        <div class="cardart"><%- miniArt(theme) %></div>
        <div class="cardbody">
          <h3><%= ev.title %></h3>
          <% if (ev.event_date) { %>
            <div class="meta">Starts <%= new Date(ev.event_date).toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'long',year:'numeric'}) %></div>
          <% } %>
          <% if (open) { %>
            <% if (hasApplied) { %>
              <div class="desc">You've applied — Status: <strong style="color:<%= userApp.status==='accepted'?'#5be38f':userApp.status==='declined'||userApp.status==='disqualified'?'#f87171':'#ffd56b' %>"><%= userApp.status %></strong></div>
              <span class="pill open">Application submitted</span>
            <% } else { %>
              <div class="desc">Applications are open — click to apply.</div>
              <span class="pill open">● Open now</span>
            <% } %>
          <% } else { %>
            <div class="desc">Applications not open yet.</div>
            <% if (locals.designPreview) { %>
              <a href="/apply" class="pill admin-bypass">↗ Preview apply page</a>
            <% } else if (ev.opens_at) { %>
              <span class="pill soon">Opens</span>
              <div class="countdown" data-countdown="<%= new Date(ev.opens_at).getTime() %>">--:--:--</div>
            <% } else { %>
              <span class="pill soon">Coming soon</span>
            <% } %>
          <% } %>
        </div>
      <% if (open && !hasApplied) { %>
        </a>
      <% } else { %>
        </div>
      <% } %>
    <% }); %>
  </div>
  <% } %>

</main>

<%- include('partials/foot') %>

<script>
(function() {
  function tick() {
    document.querySelectorAll('[data-countdown]').forEach(function(el) {
      var t = +el.dataset.countdown, diff = t - Date.now();
      if (diff <= 0) { el.textContent = 'Opening...'; return; }
      var d = Math.floor(diff/86400000),
          h = Math.floor(diff/3600000)%24,
          m = Math.floor(diff/60000)%60,
          s = Math.floor(diff/1000)%60;
      el.textContent = (d>0?d+'d ':'')+String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
    });
  }
  tick();
  setInterval(tick, 1000);
})();
</script>
