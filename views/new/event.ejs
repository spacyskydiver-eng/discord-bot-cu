<%- include('partials/head', { pageTitle: event.title }) %>
<%- include('partials/header') %>

<%
const theme = event.theme || 'default';

const ISLAND = {
  jungle: { color:'#2f9e44', name:'Jungle',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path d="M10 4 C 18 14, 4 22, 14 32 S 8 42, 18 46" stroke="#37b24d" stroke-width="3" fill="none" stroke-linecap="round"/><ellipse cx="9" cy="14" rx="5" ry="3" fill="#2f9e44" transform="rotate(-30 9 14)"/><ellipse cx="15" cy="26" rx="5" ry="3" fill="#40c057" transform="rotate(20 15 26)"/><ellipse cx="11" cy="38" rx="5" ry="3" fill="#2f9e44" transform="rotate(-15 11 38)"/><path d="M30 46 L30 26" stroke="#7a5230" stroke-width="3"/><circle cx="30" cy="20" r="10" fill="#2b8a3e"/><circle cx="38" cy="24" r="7" fill="#37b24d"/></svg>`
  },
  snow: { color:'#74c0fc', name:'Snow',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><polygon points="24,6 40,40 8,40" fill="#e7f5ff"/><polygon points="24,6 33,24 15,24" fill="#a5d8ff"/><polygon points="14,40 24,24 34,40" fill="#fff"/><g stroke="#d0ebff" stroke-width="2" stroke-linecap="round"><path d="M24 8 v8 M20 12 h8 M40 14 v6 M37 17 h6"/></g></svg>`
  },
  badlands: { color:'#e8590c', name:'Badlands',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="30" width="36" height="12" fill="#d9480f"/><rect x="6" y="24" width="36" height="6" fill="#e8590c"/><rect x="6" y="18" width="36" height="6" fill="#f08c00"/><rect x="14" y="10" width="9" height="20" fill="#e8590c"/><rect x="14" y="6" width="9" height="4" fill="#ffa94d"/><rect x="28" y="14" width="8" height="16" fill="#d9480f"/></svg>`
  },
  forest: { color:'#82c91e', name:'Forest',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><rect x="22" y="34" width="4" height="10" fill="#7a5230"/><polygon points="24,6 36,24 12,24" fill="#5c940d"/><polygon points="24,14 38,34 10,34" fill="#82c91e"/><polygon points="24,22 40,40 8,40" fill="#a9e34b"/></svg>`
  }
};

// Which islands does this event show?
const eventIslands = (theme === '4island' || theme === 'multi')
  ? ['jungle','snow','badlands','forest']
  : (ISLAND[theme] ? [theme] : []);

// Themed background SVG — matches reference themeBg() exactly
function themeBg(t) {
  if (t === '4island' || t === 'multi') {
    return `<svg width="100%" height="100%" preserveAspectRatio="xMidYMid slice" viewBox="0 0 800 360" xmlns="http://www.w3.org/2000/svg">
      <defs><linearGradient id="sky" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#16323a"/><stop offset="1" stop-color="#0c0d10"/></linearGradient></defs>
      <rect width="800" height="360" fill="url(#sky)"/>
      <rect x="0" y="0" width="200" height="360" fill="#1e5e2e" opacity="0.55"/>
      <rect x="200" y="0" width="200" height="360" fill="#2b5d7a" opacity="0.5"/>
      <rect x="400" y="0" width="200" height="360" fill="#7a3b12" opacity="0.5"/>
      <rect x="600" y="0" width="200" height="360" fill="#3d6312" opacity="0.55"/>
      <g fill="#a9e34b" opacity="0.5"><polygon points="650,360 680,250 710,360"/><polygon points="710,360 740,270 770,360"/></g>
      <g fill="#e7f5ff" opacity="0.5"><polygon points="250,360 300,230 350,360"/></g>
      <g fill="#f08c00" opacity="0.4"><rect x="430" y="250" width="140" height="110"/></g>
    </svg>`;
  }
  const c = {jungle:['#103a1d','#1e5e2e'],snow:['#1a3550','#2b5d7a'],badlands:['#3a1c08','#7a3b12'],forest:['#16320f','#3d6312']}[t] || ['#16171c','#16171c'];
  return `<svg width="100%" height="100%" preserveAspectRatio="xMidYMid slice" viewBox="0 0 800 360" xmlns="http://www.w3.org/2000/svg">
    <defs><linearGradient id="evg" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="${c[1]}"/><stop offset="1" stop-color="${c[0]}"/></linearGradient></defs>
    <rect width="800" height="360" fill="url(#evg)"/>
  </svg>`;
}
%>

<main class="wrap">

  <div class="page-head">
    <a href="/events" class="back">← All events</a>
  </div>

  <div class="detail">
    <div class="themebg"><%- themeBg(theme) %></div>
    <div class="scrim"></div>
    <div class="content">
      <% if (event.event_date) { %>
        <span class="tag">Starts <%= new Date(event.event_date).toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'long',year:'numeric'}) %></span>
      <% } else { %>
        <span class="tag">Coming Soon</span>
      <% } %>
      <h2><%= event.title %></h2>
      <% if (event.description) { %>
        <div class="ev-desc"><%- event.description %></div>
      <% } %>
      <% if (eventIslands.length > 0) { %>
      <div class="islands">
        <% eventIslands.forEach(function(islKey) { %>
          <% const isl = ISLAND[islKey]; %>
          <div class="island-chip"><%- isl.ico %><%= isl.name %></div>
        <% }); %>
      </div>
      <% } %>
      <% if (event.is_open) { %>
        <a href="/apply" class="cta">Apply now →</a>
      <% } else { %>
        <a href="/applications" class="cta disabled">Applications not open yet →</a>
      <% } %>
    </div>
  </div>

</main>

<%- include('partials/foot') %>
