<%- include('partials/head', { pageTitle: 'Store' }) %>
<%- include('partials/header') %>

<main class="wrap">

  <div class="page-head">
    <a href="<%= lp %>/" class="back"><%= t('back_home') %></a>
    <div>
      <h1 class="page-title"><%= t('store_title') %></h1>
      <p class="page-sub"><%= t('store_sub') %></p>
    </div>
    <button onclick="tebexPopup('https://collective-union.tebex.io/checkout')" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:#e8eaf0;padding:9px 16px;border-radius:10px;font-size:14px;cursor:pointer;font-family:inherit;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      <%= t('store_basket') %>
    </button>
  </div>

  <% if (success) { %>
  <div class="store-success">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
    <%= t('store_success') %>
  </div>
  <% } %>

  <div class="store-grid">

    <!-- VIP -->
    <div class="rank vip">
      <div class="top">
        <svg viewBox="0 0 100 100">
          <polygon points="50,6 82,30 66,90 34,90 18,30" fill="#d6ecff"/>
          <polygon points="50,6 82,30 50,46 18,30" fill="#a5d8ff"/>
          <polygon points="18,30 50,46 34,90" fill="#74c0fc"/>
          <polygon points="82,30 50,46 66,90" fill="#3a7bd5"/>
        </svg>
      </div>
      <div class="b">
        <h3>VIP</h3>
        <div class="price">$4.99 <small><%= t('store_permanent') %></small></div>
        <div class="once"><%= t('store_one_time') %></div>
        <ul>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#74c0fc" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Custom armour trims in events &amp; community server
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#74c0fc" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Custom shield patterns in events &amp; community server
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#74c0fc" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            VIP tag &amp; TAB priority + VIP role in Discord
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#74c0fc" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Early access to event applications
          </li>
        </ul>
        <a class="buy" style="opacity:0.45;cursor:not-allowed;pointer-events:none;"><%= t('store_coming_soon') %></a>
      </div>
    </div>

    <!-- VIP+ -->
    <div class="rank plus">
      <div class="top">
        <svg viewBox="0 0 100 100">
          <polygon points="50,6 82,30 66,90 34,90 18,30" fill="#fff0c0"/>
          <polygon points="50,6 82,30 50,46 18,30" fill="#ffe08a"/>
          <polygon points="18,30 50,46 34,90" fill="#ffc63d"/>
          <polygon points="82,30 50,46 66,90" fill="#d99a16"/>
        </svg>
      </div>
      <div class="b">
        <h3>VIP+</h3>
        <div class="price">$9.99 <small><%= t('store_permanent') %></small></div>
        <div class="once">Includes everything in VIP</div>
        <ul>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Everything in VIP
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Custom kill/death animations &amp; chat messages on all servers
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Early access to event applications
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Custom name tag across all CUE servers
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Access to sneak peeks of future events
          </li>
        </ul>
        <a class="buy" style="opacity:0.45;cursor:not-allowed;pointer-events:none;"><%= t('store_coming_soon') %></a>
      </div>
    </div>

  </div>

  <p style="text-align:center;color:var(--muted);font-size:13px;margin-top:32px;max-width:600px;margin-left:auto;margin-right:auto;">
    All ranks are cosmetic only. No gameplay advantages. Compliant with the Minecraft EULA.
  </p>
  <p style="text-align:center;color:var(--muted);font-size:12px;margin-top:10px;">
    A checkout window will open. If you accidentally close it, just click the button again.
  </p>

</main>

<%- include('partials/foot') %>
<script>
function tebexPopup(url) {
  const w = 480, h = 700;
  const left = Math.round(screen.width / 2 - w / 2);
  const top = Math.round(screen.height / 2 - h / 2);
  window.open(url, 'tebex', `width=${w},height=${h},left=${left},top=${top},scrollbars=yes,resizable=yes`);
}
</script>
