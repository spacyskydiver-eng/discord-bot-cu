<%- include('partials/head', { pageTitle: 'Store' }) %>
<%- include('partials/header') %>

<main class="wrap">

  <div class="page-head">
    <a href="/" class="back">← Home</a>
    <div>
      <h1 class="page-title">Store</h1>
      <p class="page-sub">Two ranks. One-time purchase. Cosmetics that carry across all CUE events and the community server.</p>
    </div>
  </div>

  <% if (success) { %>
  <div class="store-success">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
    Purchase complete! Your rank will be applied within a few minutes.
  </div>
  <% } %>

  <div class="store-grid">

    <!-- VIP -->
    <div class="rank vip">
      <div class="top">
        <svg viewBox="0 0 100 100">
          <polygon points="50,6 82,30 66,90 34,90 18,30" fill="#d6ecff"/>
          <polygon points="50,6 82,30 50,46 18,30" fill="#a5d8ff"/>
          <polygon points="18,30 50,46 34,90" fill="#74c0fc"/>
          <polygon points="82,30 50,46 66,90" fill="#3a7bd5"/>
        </svg>
      </div>
      <div class="b">
        <h3>VIP</h3>
        <div class="price">£4.99 <small>/ permanent</small></div>
        <div class="once">One-time purchase · unlocked forever</div>
        <ul>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#74c0fc" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Custom armour trims in events &amp; community server
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#74c0fc" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Custom shield patterns in events &amp; community server
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#74c0fc" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            VIP tag &amp; TAB priority + VIP role in Discord
          </li>
        </ul>
        <button class="buy" onclick="openBuy(7526228, 'VIP', '£4.99')">Get VIP</button>
      </div>
    </div>

    <!-- VIP+ -->
    <div class="rank plus">
      <div class="top">
        <svg viewBox="0 0 100 100">
          <polygon points="50,6 82,30 66,90 34,90 18,30" fill="#fff0c0"/>
          <polygon points="50,6 82,30 50,46 18,30" fill="#ffe08a"/>
          <polygon points="18,30 50,46 34,90" fill="#ffc63d"/>
          <polygon points="82,30 50,46 66,90" fill="#d99a16"/>
        </svg>
      </div>
      <div class="b">
        <h3>VIP+</h3>
        <div class="price">£9.99 <small>/ permanent</small></div>
        <div class="once">Includes everything in VIP</div>
        <ul>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Everything in VIP
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Custom kill/death animations &amp; chat messages on all servers
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Early access to event applications
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Custom name tag across all CUE servers
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffc63d" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            Access to sneak peeks of future events
          </li>
        </ul>
        <button class="buy" onclick="openBuy(7526241, 'VIP+', '£9.99')">Get VIP+</button>
      </div>
    </div>

  </div>

  <p style="text-align:center;color:var(--muted);font-size:13px;margin-top:32px;max-width:600px;margin-left:auto;margin-right:auto;">
    All ranks are cosmetic only. No gameplay advantages. Compliant with the Minecraft EULA.
  </p>

</main>

<!-- Buy modal -->
<div id="buyModal" class="cs-modal" onclick="if(event.target===this)closeBuy()">
  <div class="cs-box" style="max-width:420px">
    <button class="cs-close" onclick="closeBuy()">✕</button>
    <h2 class="cs-title" id="buy-title">Get VIP</h2>
    <p class="cs-body" style="margin-bottom:20px">Enter your Minecraft username so your rank gets applied to the right account.</p>
    <input id="mc-username" type="text" placeholder="Minecraft username" autocomplete="off" spellcheck="false"
      style="width:100%;box-sizing:border-box;padding:10px 14px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(255,255,255,0.07);color:#fff;font-size:15px;outline:none;margin-bottom:8px"
      onkeydown="if(event.key==='Enter')proceedCheckout()">
    <div id="buy-error" style="color:#f87171;font-size:13px;min-height:18px;margin-bottom:10px"></div>
    <button id="checkout-btn" class="buy" style="width:100%" onclick="proceedCheckout()">Proceed to Checkout</button>
  </div>
</div>

<%- include('partials/foot') %>

<script src="https://js.tebex.io/v1.js"></script>
<script>
let pendingPackageId = null;

function openBuy(packageId, name, price) {
  pendingPackageId = packageId;
  document.getElementById('buy-title').textContent = 'Get ' + name + ' — ' + price;
  document.getElementById('buy-error').textContent = '';
  document.getElementById('mc-username').value = '';
  document.getElementById('checkout-btn').disabled = false;
  document.getElementById('checkout-btn').textContent = 'Proceed to Checkout';
  document.getElementById('buyModal').classList.add('open');
  setTimeout(() => document.getElementById('mc-username').focus(), 50);
}

function closeBuy() {
  document.getElementById('buyModal').classList.remove('open');
  pendingPackageId = null;
}

async function proceedCheckout() {
  const username = document.getElementById('mc-username').value.trim();
  const errEl = document.getElementById('buy-error');
  errEl.textContent = '';

  if (!username) {
    errEl.textContent = 'Please enter your Minecraft username.';
    return;
  }
  if (!/^[a-zA-Z0-9_]{1,16}$/.test(username)) {
    errEl.textContent = 'That doesn\'t look like a valid Minecraft username.';
    return;
  }

  const btn = document.getElementById('checkout-btn');
  btn.disabled = true;
  btn.textContent = 'Loading…';

  try {
    const res = await fetch('/store/checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ package_id: pendingPackageId, username })
    });
    const data = await res.json();

    if (data.error) {
      errEl.textContent = data.error;
      btn.disabled = false;
      btn.textContent = 'Proceed to Checkout';
      return;
    }

    closeBuy();

    if (data.basket_ident && typeof Tebex !== 'undefined') {
      Tebex.checkout.init({ ident: data.basket_ident, theme: 'dark' });
      Tebex.checkout.launch();
    } else if (data.checkout_url) {
      window.location.href = data.checkout_url;
    } else {
      errEl.textContent = 'Checkout unavailable, please try again.';
    }
  } catch (err) {
    errEl.textContent = 'Something went wrong. Please try again.';
    btn.disabled = false;
    btn.textContent = 'Proceed to Checkout';
  }
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeBuy();
});
</script>
