<%- include('partials/head', { pageTitle: 'Apply' }) %>
<%- include('partials/header') %>

<%
function renderBlock(b) {
  if (b.block_type === 'image') {
    return `<div class="sb-image"><img src="${b.content}" alt="${b.label||''}" />${b.label ? `<p style="font-size:12px;color:var(--muted);margin:4px 0 0">${b.label}</p>` : ''}</div>`;
  }
  if (b.block_type === 'video') {
    const ytMatch = b.content.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([A-Za-z0-9_-]{11})/);
    if (ytMatch) {
      return `<div class="sb-video"><div class="sb-iframe-wrap"><iframe src="https://www.youtube.com/embed/${ytMatch[1]}" allowfullscreen></iframe></div>${b.label ? `<p style="font-size:12px;color:var(--muted);margin:4px 0 0">${b.label}</p>` : ''}</div>`;
    }
    return `<div class="sb-video"><video src="${b.content}" controls style="max-width:100%;border-radius:10px"></video></div>`;
  }
  if (b.block_type === 'timestamp') {
    return `<div class="sb-timestamp"><span style="color:var(--muted)">${b.label||'Event time'}:</span> <span class="tz-stamp" data-utc="${b.content}">Loading...</span></div>`;
  }
  const cls = b.style_class || 'normal';
  if (cls === 'heading') return `<p class="sb-heading">${b.content}</p>`;
  if (cls === 'muted') return `<p class="sb-text" style="opacity:.7">${b.content}</p>`;
  return `<p class="sb-text">${b.content}</p>`;
}
%>

<main class="wrap">

  <div class="page-head">
    <a href="<%= lp %>/applications" class="back"><%= t('apply_back_applications') %></a>
    <div>
      <h1 class="page-title"><%= t('apply_page_title') %></h1>
      <% if (event) { %><p class="page-sub"><%= t('apply_for') %> <strong><%= (lang === 'fr' && event.title_fr) ? event.title_fr : event.title %></strong></p><% } %>
    </div>
  </div>

  <div class="apw-wrap">

    <% if (locals.isAdmin) { %>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;padding:10px 14px;background:rgba(251,191,36,.07);border:1px solid rgba(251,191,36,.2);border-radius:10px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <span style="font-family:'Baloo 2';font-weight:800;font-size:12px;color:#fbbf24;letter-spacing:.05em"><%= t('apply_admin_preview') %></span>
      <button id="adminSkipBtn" type="button" onclick="toggleAdminSkip()" style="margin-left:auto;font-family:'Baloo 2';font-weight:700;font-size:12px;padding:4px 12px;border-radius:7px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.08);color:#c9ccdb;cursor:pointer;"><%= t('apply_skip_off') %></button>
    </div>
    <% } %>

    <% if (!event) { %>
      <div class="apw-status">
        <div class="apw-status-icon">—</div>
        <h2><%= t('apply_no_event_title') %></h2>
        <p><%= t('apply_no_event_p') %></p>
        <a href="<%= lp %>/" class="apw-cta"><%= t('apply_back_home') %></a>
      </div>

    <% } else if (existing && existing.status === 'accepted' && !locals.isAdmin) { %>
      <div class="apw-status ok">
        <div class="apw-status-icon">✓</div>
        <h2><%= t('apply_accepted_title') %></h2>
        <p><%= t('apply_accepted_p') %> <strong><%= (lang === 'fr' && event.title_fr) ? event.title_fr : event.title %></strong><%= t('apply_accepted_p2') %></p>
        <a href="https://discord.gg/C63H8CFkm" target="_blank" rel="noopener" class="apw-cta apw-cta-discord"><%= t('apply_accepted_btn') %></a>
      </div>

    <% } else if (existing && existing.status === 'declined' && !locals.isAdmin) { %>
      <div class="apw-status err">
        <div class="apw-status-icon">✕</div>
        <h2><%= t('apply_declined_title') %></h2>
        <% if (existing.declined_at_stage) { %>
          <p><%= t('apply_declined_p1') %> <%= existing.declined_at_stage %><%= t('apply_declined_p2') %></p>
        <% } else { %>
          <p><%= t('apply_declined_p3') %></p>
        <% } %>
        <a href="<%= lp %>/events" class="apw-cta"><%= t('apply_view_events') %></a>
      </div>

    <% } else if (existing && existing.status === 'pending' && !locals.isAdmin) { %>
      <div class="apw-status warn">
        <div class="apw-status-icon">◎</div>
        <h2><%= t('apply_pending_title') %></h2>
        <p><%= t('apply_pending_p') %> <strong><%= (lang === 'fr' && event.title_fr) ? event.title_fr : event.title %></strong> <%= t('apply_pending_p2') %></p>
        <% const stageNames = t('apply_stage_names'); %>
        <% const reviewStage = existing.review_stage || 2; %>
        <div class="apw-progress">
          <% for (let s = 2; s <= 6; s++) { %>
            <% const passed = reviewStage > s; const isCurrent = reviewStage === s; %>
            <div class="apw-prog-row <%= passed ? 'passed' : isCurrent ? 'current' : '' %>">
              <div class="apw-prog-dot"><%= passed ? '✓' : s %></div>
              <div>
                <div class="apw-prog-name">Stage <%= s %> — <%= stageNames[s] || stageNames[s] %></div>
                <div class="apw-prog-stat"><%= passed ? t('apply_progress_passed') : isCurrent ? t('apply_progress_current') : t('apply_progress_waiting') %></div>
              </div>
            </div>
            <% if (s < 6) { %><div class="apw-prog-line <%= passed ? 'passed' : '' %>"></div><% } %>
          <% } %>
        </div>
      </div>

    <% } else if (submitted) { %>
      <div class="apw-status ok">
        <div class="apw-status-icon">✓</div>
        <h2><%= t('apply_received_title') %></h2>
        <p><%= t('apply_received_p') %> <strong><%= (lang === 'fr' && event.title_fr) ? event.title_fr : event.title %></strong> <%= t('apply_received_p2') %></p>
        <a href="<%= lp %>/" class="apw-cta"><%= t('apply_back_home') %></a>
      </div>

    <% } else if (!event.is_open && event.opens_at && new Date(event.opens_at) > new Date() && !locals.isAdmin) { %>
      <div class="apw-status">
        <div class="apw-status-icon">◷</div>
        <h2><%= t('apply_not_open_title') %></h2>
        <p><%= t('apply_not_open_p') %> <strong><%= (lang === 'fr' && event.title_fr) ? event.title_fr : event.title %></strong> <%= t('apply_not_open_p2') %></p>
        <p style="font-family:'Baloo 2';font-weight:800;font-size:16px;color:var(--text);margin-bottom:22px" class="tz-stamp" data-utc="<%= new Date(event.opens_at).toISOString() %>">Loading...</p>
        <a href="<%= lp %>/events" class="apw-cta"><%= t('apply_view_events') %></a>
      </div>

    <% } else if (!event.is_open && !locals.isAdmin) { %>
      <div class="apw-status">
        <div class="apw-status-icon">—</div>
        <h2><%= t('apply_closed_title') %></h2>
        <p><%= t('apply_closed_p') %> <strong><%= (lang === 'fr' && event.title_fr) ? event.title_fr : event.title %></strong> <%= t('apply_closed_p2') %></p>
        <a href="<%= lp %>/events" class="apw-cta"><%= t('apply_view_events') %></a>
      </div>

    <% } else if (!locals.user) { %>
      <div class="apw-status">
        <div class="apw-status-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" style="color:#5865F2"><path d="M20 4.4A19 19 0 0 0 15.3 3l-.3.5a14 14 0 0 1 4 2 16 16 0 0 0-13.4 0 14 14 0 0 1 4-2L9.3 3A19 19 0 0 0 4.6 4.4 20 20 0 0 0 1 18.6 19 19 0 0 0 6.8 21l.6-1a13 13 0 0 1-2-1l.5-.3a13 13 0 0 0 11.2 0l.5.3a13 13 0 0 1-2 1l.6 1A19 19 0 0 0 23 18.6 20 20 0 0 0 20 4.4ZM8.6 15.3c-.9 0-1.7-.9-1.7-2s.8-2 1.7-2 1.7.9 1.7 2-.7 2-1.7 2Zm6.8 0c-.9 0-1.7-.9-1.7-2s.8-2 1.7-2 1.7.9 1.7 2-.7 2-1.7 2Z"/></svg>
        </div>
        <h2><%= t('apply_login_title') %></h2>
        <p><%= t('apply_login_p') %></p>
        <a href="<%= lp %>/auth/discord" class="apw-cta apw-cta-discord"><%= t('apply_login_btn') %></a>
      </div>

    <% } else { %>

      <% if (locals.error === 'incomplete') { %>
      <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;margin-bottom:16px;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.25);border-radius:10px;font-size:13px;color:#f87171;font-family:'Baloo 2',sans-serif;font-weight:700">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= t('apply_error_incomplete') %>
      </div>
      <% } else if (locals.error === 'server') { %>
      <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;margin-bottom:16px;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.25);border-radius:10px;font-size:13px;color:#f87171;font-family:'Baloo 2',sans-serif;font-weight:700">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= t('apply_error_server') %>
      </div>
      <% } %>

      <!-- Draft resume banner (hidden by default, shown by JS) -->
      <div id="resumeBanner" style="display:none;align-items:center;gap:10px;padding:10px 16px;margin-bottom:14px;background:rgba(116,192,252,.08);border:1px solid rgba(116,192,252,.2);border-radius:10px;font-size:13px;color:#74c0fc;font-family:'Baloo 2',sans-serif;font-weight:700">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0"><path d="M12 2v10l4 2"/><circle cx="12" cy="12" r="10"/></svg>
        <%= t('apply_resume_banner') %> <span id="resumeStageNum">1</span>
        <button type="button" onclick="clearDraft();this.closest('#resumeBanner').style.display='none'" style="margin-left:auto;background:none;border:none;color:#74c0fc;cursor:pointer;font-size:12px;opacity:.7"><%= t('apply_clear_draft') %></button>
      </div>

      <!-- Step bar -->
      <div class="apw-steps" id="wizardHeader">
        <% t('apply_stage_names').slice(1).forEach(function(name, i) { %>
          <div class="wizard-step <%= i === 0 ? 'active' : '' %>" data-stage="<%= i+1 %>">
            <div class="apw-step-num"><%= i+1 %></div>
          </div>
          <% if (i < 6) { %><div class="wizard-connector"></div><% } %>
        <% }); %>
      </div>

      <!-- Wizard form -->
      <div class="apw-panel">
        <form id="applyForm" action="/apply/submit" method="POST">
          <input type="hidden" name="eligibility_answers" id="eligAnswersInput" value="{}" />

          <!-- ── STAGE 1: ELIGIBILITY ── -->
          <div class="wizard-stage active apw-stage" id="stage-1">
            <div class="apw-stage-num"><%= t('apply_stage_prefix') %> 1 <%= t('apply_stage_of') %> 7</div>
            <h2><%= (stageSettings[1] && stageSettings[1].title) || t('apply_stage_names')[1] %><% if (t('apply_s1_check_suffix')) { %> <%= t('apply_s1_check_suffix') %><% } %></h2>
            <% if (stageSettings[1] && stageSettings[1].subtitle) { %>
              <p class="apw-stage-sub"><%= stageSettings[1].subtitle %></p>
            <% } else { %>
              <p class="apw-stage-sub">Confirm you meet the basic requirements. Takes about 30 seconds.</p>
            <% } %>

            <%- (stageBlocks[1] || []).map(b => renderBlock(b)).join('') %>

            <div class="apw-elig-list" id="eligQList">
              <% for (const q of eligibilityQuestions) { %>
                <div class="elig-item" data-id="<%= q.id %>" data-req-yes="<%= q.required_yes %>" data-blocking="<%= q.blocking %>">
                  <p class="elig-q"><%= q.question_text %></p>
                  <div class="apw-yn">
                    <button type="button" class="yn-btn" data-val="yes"><%= t('apply_yn_yes') %></button>
                    <button type="button" class="yn-btn" data-val="no"><%= t('apply_yn_no') %></button>
                  </div>
                </div>
              <% } %>
            </div>

            <div class="apw-disq" id="disqMsg">
              <div class="apw-disq-title"><%= t('apply_disq_title') %></div>
              <p class="apw-disq-body"><%= t('apply_disq_body') %></p>
              <button type="button" class="apw-btn-ghost" onclick="resetEligibility()"><%= t('apply_go_back') %></button>
            </div>

            <div class="apw-nav" id="stage1Nav">
              <span></span>
              <button type="button" id="eligCheckBtn" class="apw-btn-next" onclick="checkEligibility()" disabled><%= t('apply_check_btn') %></button>
            </div>
          </div>

          <!-- ── STAGE 2: EVENT UNDERSTANDING + QUIZ ── -->
          <div class="wizard-stage apw-stage" id="stage-2">
            <div class="apw-stage-num"><%= t('apply_stage_prefix') %> 2 <%= t('apply_stage_of') %> 7</div>
            <h2><%= t('apply_s2_title') %></h2>
            <p class="apw-stage-sub"><%= t('apply_s2_sub') %></p>

            <% if (lang === 'fr') { %>
            <div class="apw-reading">
              <div class="apw-reading-head">Comprendre The Collective — Les bases</div>
              <div class="apw-reading-body">
                <p>The Collective est un événement de civilisation. Vous n'êtes pas seulement un joueur — vous êtes membre d'une civilisation, et vos décisions affectent tout le monde sur votre île.</p>
                <p>Vous serez assigné(e) à l'une des quatre îles — jungle, plaines, badlands ou glace. Chaque île a son propre terrain, ses ressources et ses défis. Vous commencez complètement isolé(e), sans aucun moyen d'atteindre les autres îles. Il n'y a pas d'équipes imposées, pas de plugin de factions, pas de résultats scénarisés. Chaque alliance, chaque trahison et chaque guerre est construite entièrement par les joueurs.</p>
                <p>L'événement se déroule sur 10 sessions planifiées, chacune d'environ 4 heures. Ce n'est pas un serveur disponible 24h/24. Les sessions sont planifiées et annoncées à l'avance. Ce que vous construisez, à qui vous faites confiance et vos décisions entre les sessions comptent autant que ce qui se passe pendant celles-ci.</p>
                <div id="sessionScheduleList" style="margin:12px 0 4px;display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:6px"></div>
                <p>Deux îles seront détruites avant la fin. Le monde est en train de mourir lentement. Ce qui se passe après dépend entièrement des joueurs.</p>
              </div>
            </div>
            <div class="apw-reading">
              <div class="apw-reading-head">Comprendre The Collective — Le système complet</div>
              <div class="apw-reading-body">
                <p class="apw-reading-section">L'Autel</p>
                <p>Au cœur de chaque île se trouve un autel ancestral. Pour garder votre île en vie, votre civilisation doit chasser la créature qui rôde sur votre territoire et apporter ce qu'elle laisse tomber en offrande à l'autel. À chaque session, les scores sont comptabilisés. L'île qui a le moins contribué commence à se fissurer et à se dégrader. Si votre île prend trop de retard, elle est détruite — et tous ses habitants doivent trouver un nouveau foyer sur une île survivante.</p>
                <p>La mécanique de l'autel est active à partir de la session 2 et se termine après la session 7, quand il ne reste plus que deux îles.</p>
                <p class="apw-reading-section">Les Portes et les Points de Passage</p>
                <p>Un mur sépare chaque île des autres. Le seul moyen de passer d'une île à une autre est par des points de passage dédiés intégrés dans le mur. Les portes s'ouvrent 30 minutes après le début de la session 3. Les zones contestées aux points de passage s'ouvrent 2 heures après les portes. À partir de la session 8, toutes les restrictions de passage sont levées et les joueurs peuvent voyager librement entre les deux îles restantes.</p>
                <p class="apw-reading-section">Zones de Régénération de Diamants</p>
                <p>Chaque île possède 6 zones de régénération de diamants. Ce sont des zones de 20x20 blocs où les joueurs ne peuvent ni placer ni casser de blocs. Le minerai de diamant se régénère à l'intérieur avec un temps de recharge. Ces zones sont votre principale source de diamants pour fabriquer de l'équipement. Les joueurs de n'importe quelle île peuvent entrer et miner vos zones — les défendre est de votre responsabilité.</p>
                <p>Les zones peuvent être améliorées en apportant du minerai étranger :</p>
                <ul class="apw-reading-list">
                  <li><strong>Niveau 1</strong> (par défaut) : 4 diamants, 30 minutes de recharge</li>
                  <li><strong>Niveau 2</strong> (coût : 32 minerais étrangers) : 7 diamants, 25 minutes de recharge</li>
                  <li><strong>Niveau 3</strong> (coût : 64 minerais étrangers) : 10 diamants, 20 minutes de recharge</li>
                </ul>
                <p class="apw-reading-section">Zones de Minerai d'Amélioration</p>
                <p>Chaque île possède 3 zones de minerai d'amélioration produisant le minerai unique de cette île. Le minerai de votre propre île ne vous sert à rien — il ne peut être utilisé que par d'autres îles pour améliorer leurs zones de diamants. Cela signifie que vous devez soit commercer avec d'autres îles, soit les attaquer pour obtenir le minerai étranger nécessaire à l'amélioration de vos propres zones.</p>
                <p class="apw-reading-section">Zones d'Or</p>
                <p>L'île désertique possède 2 zones de régénération d'or. Ce sont les seules sources d'or se régénérant naturellement sur la carte. L'or sert à fabriquer des pommes dorées. L'or de l'île désertique est une précieuse marchandise commerciale pour toutes les îles.</p>
                <p class="apw-reading-section">Zones Contestées</p>
                <p>Situées aux points de passage entre les îles. Ce sont des zones de 50x50 blocs où des mobs personnalisés gardent des coffres de butin contenant un meilleur équipement que tout ce qui peut être obtenu ailleurs. Les joueurs ne peuvent pas placer ou casser des blocs à l'intérieur. Une fois un coffre pillé, il disparaît. Les admins ouvrent et ferment les zones contestées avec un compte à rebours visuel des deux côtés.</p>
                <p class="apw-reading-section">Progression de l'Équipement</p>
                <p>Les plafonds d'enchantements se lèvent automatiquement au début des sessions 4 et 7.</p>
                <div class="apw-reading-table-wrap">
                  <table class="apw-reading-table">
                    <thead><tr><th>Sessions</th><th>Armure max</th><th>Épée max</th><th>Gapples max</th></tr></thead>
                    <tbody>
                      <tr><td>1–3</td><td>Protection 2</td><td>Tranchant 2</td><td>6</td></tr>
                      <tr><td>4–6</td><td>Protection 3</td><td>Tranchant 3</td><td>8</td></tr>
                      <tr><td>7–10</td><td>Protection 4</td><td>Tranchant 4</td><td>10</td></tr>
                    </tbody>
                  </table>
                </div>
                <p>Un seul set d'armure Protection 5 existe dans les coffres des zones contestées à partir de la session 5. Plus vous équipez de pièces simultanément, plus vous recevez de malus.</p>
                <p>La masse existe quelque part sur la carte. Elle ne peut pas être enchantée. Des indices seront donnés en session 6.</p>
                <p class="apw-reading-section">L'Économie</p>
                <p>Les joueurs gagnent des émeraudes en échangeant de la nourriture et des minerais au /shop. Les émeraudes peuvent être dépensées sur des blocs de construction spécifiques à l'île. Le shop ne vend pas d'équipement, d'armes ni de nourriture.</p>
                <p>Chaque joueur peut avoir un coffre verrouillé à tout moment. Verrouillez-le en fabriquant une clé et en l'utilisant sur un coffre.</p>
              </div>
            </div>
            <% } else { %>
            <div class="apw-reading">
              <div class="apw-reading-head">Understanding The Collective — The Basics</div>
              <div class="apw-reading-body">
                <p>The Collective is a civilisation event. You are not just a player — you are a member of a civilisation, and your decisions affect everyone on your island.</p>
                <p>You will be assigned to one of four islands — jungle, plains, badlands, or ice. Each island has its own terrain, resources, and challenges. You begin completely isolated with no way to reach other islands. There are no forced teams, no factions plugin, and no scripted outcomes. Every alliance, every betrayal, and every war is built entirely by the people playing.</p>
                <p>The event runs across 10 scheduled sessions each lasting around 4 hours. This is not a 24/7 server. Sessions are planned and announced in advance. What you build, who you trust, and what you decide between sessions matters just as much as what happens during them.</p>
                <div id="sessionScheduleList" style="margin:12px 0 4px;display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:6px"></div>
                <p>Two islands will be destroyed before the end. The world is slowly dying. What happens after that is entirely up to the players.</p>
              </div>
            </div>
            <div class="apw-reading">
              <div class="apw-reading-head">Understanding The Collective — The Full System</div>
              <div class="apw-reading-body">
                <p class="apw-reading-section">The Altar</p>
                <p>At the heart of each island lies an ancient altar. To keep your island alive your civilisation must hunt the creature that roams your land and bring what it drops as an offering to the altar. Every session the scores are tallied. The island that has contributed the least starts to crack and decay. If your island falls too far behind it gets destroyed — and everyone on it must find a new home on a surviving island.</p>
                <p>The altar mechanic is active from session 2 and ends after session 7 when only two islands remain.</p>
                <p class="apw-reading-section">The Gates and Crossing Points</p>
                <p>A wall separates every island from each other. The only way between islands is through dedicated crossing points built into the wall. Gates open 30 minutes into session 3. Contested zones at the crossing points open 2 hours after the gates. From session 8 onwards all crossing restrictions are lifted and players can travel freely between the two remaining islands.</p>
                <p class="apw-reading-section">Diamond Regen Zones</p>
                <p>Every island has 6 diamond regen zones spread across it. These are 20x20 block areas where players cannot place or break blocks. Diamond ore regenerates inside on a cooldown. These zones are your primary source of diamonds for crafting gear. Players from any island can enter and mine your zones — defending them is your responsibility.</p>
                <p>Zones can be upgraded by bringing foreign ore to the zone:</p>
                <ul class="apw-reading-list">
                  <li><strong>Tier 1</strong> (default): 4 diamonds, 30 minute cooldown</li>
                  <li><strong>Tier 2</strong> (costs 32 foreign ore): 7 diamonds, 25 minute cooldown</li>
                  <li><strong>Tier 3</strong> (costs 64 foreign ore): 10 diamonds, 20 minute cooldown</li>
                </ul>
                <p class="apw-reading-section">Upgrade Ore Zones</p>
                <p>Every island has 3 upgrade ore zones producing that island's unique ore. Your own island's ore is useless to you — it can only be used by other islands to upgrade their diamond zones. This means you need to either trade with other islands or raid them to get the foreign ore you need to upgrade your own zones.</p>
                <p class="apw-reading-section">Gold Zones</p>
                <p>The desert island has 2 gold regen zones. These are the only source of naturally regenerating gold on the map. Gold is used to craft golden apples. Desert island gold is a valuable trade commodity for all islands.</p>
                <p class="apw-reading-section">Contested Zones</p>
                <p>Located at the wall crossing points between islands. These are 50x50 block areas where custom mobs guard loot chests containing better gear than anything obtainable elsewhere. Players cannot place or break blocks inside. Once a chest is looted it disappears. Admins open and close contested zones with a visual countdown visible on both sides.</p>
                <p class="apw-reading-section">Gear Progression</p>
                <p>Enchantment caps lift automatically at the start of sessions 4 and 7.</p>
                <div class="apw-reading-table-wrap">
                  <table class="apw-reading-table">
                    <thead><tr><th>Sessions</th><th>Max Armour</th><th>Max Sword</th><th>Max Gapples</th></tr></thead>
                    <tbody>
                      <tr><td>1–3</td><td>Protection 2</td><td>Sharpness 2</td><td>6</td></tr>
                      <tr><td>4–6</td><td>Protection 3</td><td>Sharpness 3</td><td>8</td></tr>
                      <tr><td>7–10</td><td>Protection 4</td><td>Sharpness 4</td><td>10</td></tr>
                    </tbody>
                  </table>
                </div>
                <p>A single Protection 5 armour set exists in contested zone chests from session 5 onwards. The more pieces you equip simultaneously the more debuffs you receive.</p>
                <p>The mace exists somewhere on the map. It cannot be enchanted. Lore clues will be given in session 6.</p>
                <p class="apw-reading-section">The Economy</p>
                <p>Players earn emeralds by exchanging food and ores at the /shop. Emeralds can be spent on island specific building blocks. The shop does not sell gear, weapons, or food.</p>
                <p>Each player can have one locked chest at any time. Lock it by crafting a key and using it on a single chest.</p>
              </div>
            </div>
            <% } %>

