<%- include('partials/head', { pageTitle: 'Apply' }) %>
<%- include('partials/header') %>

<%
function renderBlock(b) {
  if (b.block_type === 'image') {
    return `<div class="sb-image"><img src="${b.content}" alt="${b.label||''}" />${b.label ? `<p style="font-size:12px;color:var(--muted);margin:4px 0 0">${b.label}</p>` : ''}</div>`;
  }
  if (b.block_type === 'video') {
    const ytMatch = b.content.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([A-Za-z0-9_-]{11})/);
    if (ytMatch) {
      return `<div class="sb-video"><div class="sb-iframe-wrap"><iframe src="https://www.youtube.com/embed/${ytMatch[1]}" allowfullscreen></iframe></div>${b.label ? `<p style="font-size:12px;color:var(--muted);margin:4px 0 0">${b.label}</p>` : ''}</div>`;
    }
    return `<div class="sb-video"><video src="${b.content}" controls style="max-width:100%;border-radius:10px"></video></div>`;
  }
  if (b.block_type === 'timestamp') {
    return `<div class="sb-timestamp"><span style="color:var(--muted)">${b.label||'Event time'}:</span> <span class="tz-stamp" data-utc="${b.content}">Loading...</span></div>`;
  }
  const cls = b.style_class || 'normal';
  if (cls === 'heading') return `<p class="sb-heading">${b.content}</p>`;
  if (cls === 'muted') return `<p class="sb-text" style="opacity:.7">${b.content}</p>`;
  return `<p class="sb-text">${b.content}</p>`;
}
%>

<main class="wrap">

  <div class="page-head">
    <a href="/applications" class="back">← Applications</a>
    <div>
      <h1 class="page-title">Apply</h1>
      <% if (event) { %><p class="page-sub">Applying for: <strong><%= event.title %></strong></p><% } %>
    </div>
  </div>

  <div class="apw-wrap">

    <% if (locals.isAdmin) { %>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;padding:10px 14px;background:rgba(251,191,36,.07);border:1px solid rgba(251,191,36,.2);border-radius:10px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <span style="font-family:'Baloo 2';font-weight:800;font-size:12px;color:#fbbf24;letter-spacing:.05em">ADMIN PREVIEW</span>
      <button id="adminSkipBtn" type="button" onclick="toggleAdminSkip()" style="margin-left:auto;font-family:'Baloo 2';font-weight:700;font-size:12px;padding:4px 12px;border-radius:7px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.08);color:#c9ccdb;cursor:pointer;">Skip OFF</button>
    </div>
    <% } %>

    <% if (!event) { %>
      <div class="apw-status">
        <div class="apw-status-icon">—</div>
        <h2>No Active Event</h2>
        <p>There are no events open for applications right now. Check back soon.</p>
        <a href="/" class="apw-cta">Back to home</a>
      </div>

    <% } else if (existing && existing.status === 'disqualified') { %>
      <div class="apw-status err">
        <div class="apw-status-icon">✕</div>
        <h2>Not Eligible</h2>
        <p>You did not meet the eligibility requirements for <strong><%= event.title %></strong>. You cannot reapply for this event with this Discord account.</p>
        <a href="/events" class="apw-cta">View events</a>
      </div>

    <% } else if (existing && existing.status === 'accepted') { %>
      <div class="apw-status ok">
        <div class="apw-status-icon">✓</div>
        <h2>Application Accepted</h2>
        <p>Congratulations — you've been accepted for <strong><%= event.title %></strong>. Watch your Discord for further instructions.</p>
        <a href="https://discord.gg/C63H8CFkm" target="_blank" rel="noopener" class="apw-cta apw-cta-discord">Open Discord</a>
      </div>

    <% } else if (existing && existing.status === 'declined') { %>
      <div class="apw-status err">
        <div class="apw-status-icon">✕</div>
        <h2>Application Declined</h2>
        <% if (existing.declined_at_stage) { %>
          <p>Your application was not successful at Stage <%= existing.declined_at_stage %>. You cannot reapply for this event with this Discord account.</p>
        <% } else { %>
          <p>Your application was not successful this time. We appreciate you applying and hope to see you at a future event.</p>
        <% } %>
        <a href="/events" class="apw-cta">View events</a>
      </div>

    <% } else if (existing && existing.status === 'pending') { %>
      <div class="apw-status warn">
        <div class="apw-status-icon">◎</div>
        <h2>Under Review</h2>
        <p>Your application for <strong><%= event.title %></strong> is being reviewed by staff. Track your progress below.</p>
        <% const stageNameMap = {2:'Basic Info',3:'Playstyle',4:'Scenarios',5:'Application',6:'Agreement'}; %>
        <% const reviewStage = existing.review_stage || 2; %>
        <div class="apw-progress">
          <% for (let s = 2; s <= 6; s++) { %>
            <% const passed = reviewStage > s; const isCurrent = reviewStage === s; %>
            <div class="apw-prog-row <%= passed ? 'passed' : isCurrent ? 'current' : '' %>">
              <div class="apw-prog-dot"><%= passed ? '✓' : s %></div>
              <div>
                <div class="apw-prog-name">Stage <%= s %> — <%= stageNameMap[s] %></div>
                <div class="apw-prog-stat"><%= passed ? 'Passed' : isCurrent ? 'Under Review' : 'Waiting' %></div>
              </div>
            </div>
            <% if (s < 6) { %><div class="apw-prog-line <%= passed ? 'passed' : '' %>"></div><% } %>
          <% } %>
        </div>
      </div>

    <% } else if (submitted) { %>
      <div class="apw-status ok">
        <div class="apw-status-icon">✓</div>
        <h2>Application Received</h2>
        <p>Your application for <strong><%= event.title %></strong> has been submitted. We'll review it and reach out via Discord.</p>
        <a href="/" class="apw-cta">Back to home</a>
      </div>

    <% } else if (!event.is_open && event.opens_at && new Date(event.opens_at) > new Date() && !locals.isAdmin) { %>
      <div class="apw-status">
        <div class="apw-status-icon">◷</div>
        <h2>Not Open Yet</h2>
        <p>Applications for <strong><%= event.title %></strong> aren't open yet. Come back at:</p>
        <p style="font-family:'Baloo 2';font-weight:800;font-size:16px;color:var(--text);margin-bottom:22px" class="tz-stamp" data-utc="<%= new Date(event.opens_at).toISOString() %>">Loading...</p>
        <a href="/events" class="apw-cta">View events</a>
      </div>

    <% } else if (!event.is_open && !locals.isAdmin) { %>
      <div class="apw-status">
        <div class="apw-status-icon">—</div>
        <h2>Applications Closed</h2>
        <p>Applications for <strong><%= event.title %></strong> are currently closed.</p>
        <a href="/events" class="apw-cta">View events</a>
      </div>

    <% } else if (!locals.user) { %>
      <div class="apw-status">
        <div class="apw-status-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" style="color:#5865F2"><path d="M20 4.4A19 19 0 0 0 15.3 3l-.3.5a14 14 0 0 1 4 2 16 16 0 0 0-13.4 0 14 14 0 0 1 4-2L9.3 3A19 19 0 0 0 4.6 4.4 20 20 0 0 0 1 18.6 19 19 0 0 0 6.8 21l.6-1a13 13 0 0 1-2-1l.5-.3a13 13 0 0 0 11.2 0l.5.3a13 13 0 0 1-2 1l.6 1A19 19 0 0 0 23 18.6 20 20 0 0 0 20 4.4ZM8.6 15.3c-.9 0-1.7-.9-1.7-2s.8-2 1.7-2 1.7.9 1.7 2-.7 2-1.7 2Zm6.8 0c-.9 0-1.7-.9-1.7-2s.8-2 1.7-2 1.7.9 1.7 2-.7 2-1.7 2Z"/></svg>
        </div>
        <h2>Sign in to apply</h2>
        <p>You need to sign in with Discord before you can submit your application.</p>
        <a href="/auth/discord" class="apw-cta apw-cta-discord">Sign in with Discord</a>
      </div>

    <% } else { %>

      <!-- Draft resume banner (hidden by default, shown by JS) -->
      <div id="resumeBanner" style="display:none;align-items:center;gap:10px;padding:10px 16px;margin-bottom:14px;background:rgba(116,192,252,.08);border:1px solid rgba(116,192,252,.2);border-radius:10px;font-size:13px;color:#74c0fc;font-family:'Baloo 2',sans-serif;font-weight:700">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0"><path d="M12 2v10l4 2"/><circle cx="12" cy="12" r="10"/></svg>
        Resuming your draft — picked up from stage <span id="resumeStageNum">1</span>
        <button type="button" onclick="clearDraft();this.closest('#resumeBanner').style.display='none'" style="margin-left:auto;background:none;border:none;color:#74c0fc;cursor:pointer;font-size:12px;opacity:.7">Clear draft ✕</button>
      </div>

      <!-- Step bar -->
      <div class="apw-steps" id="wizardHeader">
        <% ['Eligibility','Understanding','Basic Info','Playstyle','Scenarios','Application','Agreement'].forEach(function(name, i) { %>
          <div class="wizard-step <%= i === 0 ? 'active' : '' %>" data-stage="<%= i+1 %>">
            <div class="apw-step-num"><%= i+1 %></div>
          </div>
          <% if (i < 6) { %><div class="wizard-connector"></div><% } %>
        <% }); %>
      </div>

      <!-- Wizard form -->
      <div class="apw-panel">
        <form id="applyForm" action="/apply/submit" method="POST">
          <input type="hidden" name="eligibility_answers" id="eligAnswersInput" value="{}" />

          <!-- ── STAGE 1: ELIGIBILITY ── -->
          <div class="wizard-stage active apw-stage" id="stage-1">
            <div class="apw-stage-num">Stage 1 of 6</div>
            <h2><%= (stageSettings[1] && stageSettings[1].title) || 'Eligibility' %> Check</h2>
            <% if (stageSettings[1] && stageSettings[1].subtitle) { %>
              <p class="apw-stage-sub"><%= stageSettings[1].subtitle %></p>
            <% } else { %>
              <p class="apw-stage-sub">Confirm you meet the basic requirements. Takes about 30 seconds.</p>
            <% } %>

            <%- (stageBlocks[1] || []).map(b => renderBlock(b)).join('') %>

            <div class="apw-elig-list" id="eligQList">
              <% for (const q of eligibilityQuestions) { %>
                <div class="elig-item" data-id="<%= q.id %>" data-req-yes="<%= q.required_yes %>" data-blocking="<%= q.blocking %>">
                  <p class="elig-q"><%= q.question_text %></p>
                  <div class="apw-yn">
                    <button type="button" class="yn-btn" data-val="yes">Yes</button>
                    <button type="button" class="yn-btn" data-val="no">No</button>
                  </div>
                </div>
              <% } %>
            </div>

            <div class="apw-disq" id="disqMsg">
              <div class="apw-disq-title">You don't meet the requirements</div>
              <p class="apw-disq-body">Unfortunately you don't qualify for this event based on your answers. We hope to see you at a future one.</p>
              <button type="button" class="apw-btn-ghost" onclick="resetEligibility()">Go Back</button>
            </div>

            <div class="apw-nav" id="stage1Nav">
              <span></span>
              <button type="button" id="eligCheckBtn" class="apw-btn-next" onclick="checkEligibility()" disabled>Check Eligibility</button>
            </div>
          </div>

          <!-- ── STAGE 2: EVENT UNDERSTANDING + QUIZ ── -->
          <div class="wizard-stage apw-stage" id="stage-2">
            <div class="apw-stage-num">Stage 2 of 7</div>
            <h2>Understanding The Event</h2>
            <p class="apw-stage-sub">Read the overview and rules below, confirm you've read them, then answer 3 quick questions to continue.</p>

            <div class="apw-reading">
              <div class="apw-reading-head">Understanding The Collective — The Basics</div>
              <div class="apw-reading-body">
                <p>The Collective is a civilisation event. You are not just a player — you are a member of a civilisation, and your decisions affect everyone on your island.</p>
                <p>You will be assigned to one of four islands — jungle, plains, badlands, or ice. Each island has its own terrain, resources, and challenges. You begin completely isolated with no way to reach other islands. There are no forced teams, no factions plugin, and no scripted outcomes. Every alliance, every betrayal, and every war is built entirely by the people playing.</p>
                <p>The event runs across 10 scheduled sessions each lasting around 4 hours. This is not a 24/7 server. Sessions are planned and announced in advance. What you build, who you trust, and what you decide between sessions matters just as much as what happens during them.</p>
                <p>Two islands will be destroyed before the end. The world is slowly dying. What happens after that is entirely up to the players.</p>
              </div>
            </div>

            <div class="apw-reading">
              <div class="apw-reading-head">Understanding The Collective — The Full System</div>
              <div class="apw-reading-body">
                <p class="apw-reading-section">The Altar</p>
                <p>At the heart of each island lies an ancient altar. To keep your island alive your civilisation must hunt the creature that roams your land and bring what it drops as an offering to the altar. Every session the scores are tallied. The island that has contributed the least starts to crack and decay. If your island falls too far behind it gets destroyed — and everyone on it must find a new home on a surviving island.</p>
                <p>The altar mechanic is active from session 2 and ends after session 7 when only two islands remain.</p>

                <p class="apw-reading-section">The Gates and Crossing Points</p>
                <p>A wall separates every island from each other. The only way between islands is through dedicated crossing points built into the wall. Gates open 30 minutes into session 3. Contested zones at the crossing points open 2 hours after the gates. From session 8 onwards all crossing restrictions are lifted and players can travel freely between the two remaining islands.</p>

                <p class="apw-reading-section">Diamond Regen Zones</p>
                <p>Every island has 6 diamond regen zones spread across it. These are 20x20 block areas where players cannot place or break blocks. Diamond ore regenerates inside on a cooldown. These zones are your primary source of diamonds for crafting gear. Players from any island can enter and mine your zones — defending them is your responsibility.</p>
                <p>Zones can be upgraded by bringing foreign ore to the zone:</p>
                <ul class="apw-reading-list">
                  <li><strong>Tier 1</strong> (default): 4 diamonds, 30 minute cooldown</li>
                  <li><strong>Tier 2</strong> (costs 32 foreign ore): 7 diamonds, 25 minute cooldown</li>
                  <li><strong>Tier 3</strong> (costs 64 foreign ore): 10 diamonds, 20 minute cooldown</li>
                </ul>

                <p class="apw-reading-section">Upgrade Ore Zones</p>
                <p>Every island has 3 upgrade ore zones producing that island's unique ore. Your own island's ore is useless to you — it can only be used by other islands to upgrade their diamond zones. This means you need to either trade with other islands or raid them to get the foreign ore you need to upgrade your own zones.</p>

                <p class="apw-reading-section">Gold Zones</p>
                <p>The desert island has 2 gold regen zones. These are the only source of naturally regenerating gold on the map. Gold is used to craft golden apples. Desert island gold is a valuable trade commodity for all islands.</p>

                <p class="apw-reading-section">Contested Zones</p>
                <p>Located at the wall crossing points between islands. These are 50x50 block areas where custom mobs guard loot chests containing better gear than anything obtainable elsewhere. Players cannot place or break blocks inside. Once a chest is looted it disappears. Admins open and close contested zones with a visual countdown visible on both sides.</p>

                <p class="apw-reading-section">Gear Progression</p>
                <p>Enchantment caps lift automatically at the start of sessions 4 and 7.</p>
                <div class="apw-reading-table-wrap">
                  <table class="apw-reading-table">
                    <thead><tr><th>Sessions</th><th>Max Armour</th><th>Max Sword</th><th>Max Gapples</th></tr></thead>
                    <tbody>
                      <tr><td>1–3</td><td>Protection 2</td><td>Sharpness 2</td><td>6</td></tr>
                      <tr><td>4–6</td><td>Protection 3</td><td>Sharpness 3</td><td>8</td></tr>
                      <tr><td>7–10</td><td>Protection 4</td><td>Sharpness 4</td><td>10</td></tr>
                    </tbody>
                  </table>
                </div>
                <p>A single Protection 5 armour set exists in contested zone chests from session 5 onwards. The more pieces you equip simultaneously the more debuffs you receive.</p>
                <p>The mace exists somewhere on the map. It cannot be enchanted. Lore clues will be given in session 6.</p>

                <p class="apw-reading-section">The Economy</p>
                <p>Players earn emeralds by exchanging food and ores at the /shop. Emeralds can be spent on island specific building blocks. The shop does not sell gear, weapons, or food.</p>
                <p>Each player can have one locked chest at any time. Lock it by crafting a key and using it on a single chest.</p>
              </div>
            </div>

            <label class="agr-item" style="margin:20px 0">
              <input type="checkbox" class="agr-check" id="readingConfirmCheck" onchange="onReadingConfirm()"/>
              <span class="agr-text">I have read and understood the event overview above.</span>
            </label>

            <div id="quizSection" style="display:none">
              <div class="quiz-layout">
                <div class="quiz-rules-panel">
                  <div class="quiz-rules-head">Event Rules — reference</div>
                  <div class="quiz-rules-body">
                    <p class="apw-reading-section">General</p>
                    <ul class="apw-reading-list">
                      <li>You must make every reasonable effort to attend scheduled sessions. Players who repeatedly miss sessions without notice may be removed.</li>
                      <li>No hacking, cheating, or exploiting bugs. Any unfair advantage must be reported to staff immediately.</li>
                      <li>No mods that give a gameplay advantage. Performance mods such as Sodium and Optifine are allowed.</li>
                      <li>Staff decisions are final. Raise disputes through a ticket after the session.</li>
                      <li>Do not share information about the event publicly before it begins.</li>
                    </ul>
                    <p class="apw-reading-section">Combat</p>
                    <ul class="apw-reading-list">
                      <li>PvP is disabled during session 1. It enables at the start of session 2 and remains on for the rest of the event.</li>
                      <li>From session 2 onwards killing other players, including those on your own island, is allowed.</li>
                      <li>Stealing from other players and bases is allowed.</li>
                      <li>There are no protected areas outside of the designated no-build zones.</li>
                      <li>Do not combat log. Disconnecting to avoid death is a bannable offence.</li>
                      <li>This is not a roleplay server. You can be killed by anyone at any time for any reason from session 2 onwards.</li>
                    </ul>
                    <p class="apw-reading-section">Griefing</p>
                    <ul class="apw-reading-list">
                      <li>Destroying another player's builds purely to grief with no strategic purpose is not allowed.</li>
                      <li>Destroying your own island's landscape to grief your own civilisation is not allowed.</li>
                      <li>Intentionally destroying your own island's altar or ore zones is not allowed.</li>
                    </ul>
                    <p class="apw-reading-section">Gear and Enchantments</p>
                    <ul class="apw-reading-list">
                      <li>Enchantment caps are enforced by plugin and cannot be bypassed.</li>
                      <li>Golden apple limits are enforced by plugin.</li>
                      <li>Do not attempt to duplicate items or exploit any inventory mechanic.</li>
                    </ul>
                    <p class="apw-reading-section">Zones</p>
                    <ul class="apw-reading-list">
                      <li>No building or breaking blocks inside diamond regen zones, upgrade ore zones, or contested zones.</li>
                      <li>Do not attempt to exploit zone mechanics or cooldowns.</li>
                      <li>Do not block or obstruct zone entrances.</li>
                    </ul>
                    <p class="apw-reading-section">Communication</p>
                    <ul class="apw-reading-list">
                      <li>No sharing of real life personal information about other players.</li>
                      <li>No harassment, hate speech, or discriminatory language in any chat.</li>
                      <li>No advertising other servers or Discord servers during the event.</li>
                      <li>Spamming chat during live sessions is not allowed.</li>
                    </ul>
                    <p class="apw-reading-section">Tickets and Staff</p>
                    <ul class="apw-reading-list">
                      <li>If you have a complaint or rule break to report during a live session, open a ticket. Do not bring disputes into public chat.</li>
                      <li>False reports or abuse of the ticket system will result in punishment.</li>
                      <li>Impersonating staff is a bannable offence.</li>
                    </ul>
                    <p class="apw-reading-section">Content</p>
                    <ul class="apw-reading-list">
                      <li>By participating in this event you acknowledge that your gameplay may be recorded and used in future content by The Collective. If you do not consent, do not apply.</li>
                    </ul>
                  </div>
                </div>
                <div class="quiz-questions-panel">
                  <p class="quiz-intro">Answer all 3 correctly to continue. Wrong answers reset with a different question — refer to the rules on the left at any time.</p>
                  <div id="quizQ0" class="quiz-question"></div>
                  <div id="quizQ1" class="quiz-question"></div>
                  <div id="quizQ2" class="quiz-question"></div>
                  <div id="quizStatus" class="quiz-status">0 of 3 correct</div>
                </div>
              </div>
            </div>

            <div class="apw-nav">
              <button type="button" class="apw-btn-ghost" onclick="goStage(1)">Back</button>
              <button type="button" class="apw-btn-next" id="quizNextBtn" onclick="goStage(3)" disabled>Next</button>
            </div>
          </div>

          <!-- ── STAGE 3: BASIC INFO ── -->
          <div class="wizard-stage apw-stage" id="stage-3">
            <div class="apw-stage-num">Stage 3 of 7</div>
            <h2><%= (stageSettings[2] && stageSettings[2].title) || 'Basic Information' %></h2>
            <% if (stageSettings[2] && stageSettings[2].subtitle) { %>
              <p class="apw-stage-sub"><%= stageSettings[2].subtitle %></p>
            <% } else { %><p class="apw-stage-sub"></p><% } %>

            <%- (stageBlocks[2] || []).map(b => renderBlock(b)).join('') %>

            <div class="apw-field">
              <label class="apw-label">Minecraft In-Game Name <span class="req">*</span></label>
              <input type="text" name="ign" class="apw-input" placeholder="Your exact IGN" />
            </div>
            <div class="apw-field">
              <label class="apw-label">Discord Username <span class="req">*</span></label>
              <input type="text" name="discord_username" class="apw-input" placeholder="e.g. spacey or spacey#0001" />
            </div>
            <div class="apw-row">
              <div class="apw-field">
                <label class="apw-label">Age <span class="req">*</span></label>
                <input type="number" name="age" class="apw-input" min="13" max="99" placeholder="Your age" />
              </div>
              <div class="apw-field">
                <label class="apw-label">Country <span class="req">*</span></label>
                <input type="text" name="country" class="apw-input" placeholder="e.g. United Kingdom" />
              </div>
            </div>
            <div class="apw-field">
              <label class="apw-label">How did you hear about The Collective? <span class="req">*</span></label>
              <input type="text" name="how_heard" class="apw-input" placeholder="e.g. YouTube, a friend, Discord" />
            </div>
            <div class="apw-field">
              <label class="apw-label">Session Availability <span class="req">*</span></label>
              <p class="apw-field-hint">All 10 sessions are shown below with times in <strong>your local timezone</strong>. Tick every session you can attend. You must be able to make <strong>at least 5 sessions including Session 1</strong> to be considered.</p>
              <input type="hidden" name="session_availability" id="sessionAvailInput" />
              <div class="session-avail-grid" id="sessionAvailGrid"></div>
              <div class="session-avail-status" id="sessionAvailStatus"></div>
            </div>

            <div class="apw-field">
              <label class="apw-label">Have you played civilisation-style events before?</label>
              <input type="hidden" name="played_civ" id="playedCivVal" value="no" />
              <div class="apw-toggle">
                <button type="button" class="toggle-opt" onclick="setToggle('playedCivVal','yes',this,'civWrap')">Yes</button>
                <button type="button" class="toggle-opt active" onclick="setToggle('playedCivVal','no',this,'civWrap')">No</button>
              </div>
              <div id="civWrap" class="apw-cond" style="display:none">
                <div class="apw-field" style="margin-bottom:0">
                  <label class="apw-label">Which events?</label>
                  <input type="text" name="played_civ_details" class="apw-input" placeholder="e.g. Forged Alliance, MCC" />
                </div>
              </div>
            </div>
            <div class="apw-field">
              <label class="apw-label">Do you create content? (YouTube, Twitch, etc.)</label>
              <input type="hidden" name="creates_content" id="createsContentVal" value="no" />
              <div class="apw-toggle">
                <button type="button" class="toggle-opt" onclick="setToggle('createsContentVal','yes',this,'contentWrap')">Yes</button>
                <button type="button" class="toggle-opt active" onclick="setToggle('createsContentVal','no',this,'contentWrap')">No</button>
              </div>
              <div id="contentWrap" class="apw-cond" style="display:none">
                <div class="apw-field" style="margin-bottom:0">
                  <label class="apw-label">Channel / Stream link</label>
                  <input type="url" name="content_link" class="apw-input" placeholder="https://..." />
                </div>
              </div>
            </div>

            <div class="apw-field">
              <label class="apw-label">Island Preferences <span class="req">*</span></label>
              <p class="apw-field-hint">Click the islands in order from most to least preferred. Click again to remove a selection.</p>
              <div class="island-rank-grid">
                <div class="island-card" data-island="jungle" onclick="clickIsland('jungle')" style="--iclr:#1e6630;--itxt:#51cf66">
                  <div class="island-rank-badge"></div>
                  <div class="island-card-ico" style="background:linear-gradient(135deg,#1e5e2e,#0c0d10)">
                    <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><path d="M8 4C13 10 4 17 11 25S7 34 14 36" stroke="#37b24d" stroke-width="2.5" fill="none" stroke-linecap="round"/><ellipse cx="7" cy="11" rx="4" ry="2.5" fill="#2f9e44" transform="rotate(-30 7 11)"/><ellipse cx="12" cy="20" rx="4" ry="2.5" fill="#40c057" transform="rotate(20 12 20)"/><path d="M22 36L22 20" stroke="#7a5230" stroke-width="2.5"/><circle cx="22" cy="15" r="8" fill="#2b8a3e"/><circle cx="28" cy="18" r="5" fill="#37b24d"/></svg>
                  </div>
                  <div class="island-card-name" style="color:#51cf66">Jungle</div>
                </div>
                <div class="island-card" data-island="snow" onclick="clickIsland('snow')" style="--iclr:#2b5d7a;--itxt:#74c0fc">
                  <div class="island-rank-badge"></div>
                  <div class="island-card-ico" style="background:linear-gradient(135deg,#2b5d7a,#0c0d10)">
                    <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><polygon points="18,5 30,30 6,30" fill="#e7f5ff"/><polygon points="18,5 25,18 11,18" fill="#a5d8ff"/><polygon points="10,30 18,18 26,30" fill="#fff"/><g stroke="#d0ebff" stroke-width="1.5" stroke-linecap="round"><path d="M18 6v6M15 9h6M30 10v5M27.5 12.5h5"/></g></svg>
                  </div>
                  <div class="island-card-name" style="color:#74c0fc">Snow</div>
                </div>
                <div class="island-card" data-island="badlands" onclick="clickIsland('badlands')" style="--iclr:#7a3b12;--itxt:#ff922b">
                  <div class="island-rank-badge"></div>
                  <div class="island-card-ico" style="background:linear-gradient(135deg,#7a3b12,#0c0d10)">
                    <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="22" width="28" height="10" fill="#d9480f"/><rect x="4" y="17" width="28" height="5" fill="#e8590c"/><rect x="4" y="13" width="28" height="4" fill="#f08c00"/><rect x="10" y="7" width="8" height="15" fill="#e8590c"/><rect x="10" y="4" width="8" height="4" fill="#ffa94d"/><rect x="21" y="10" width="7" height="12" fill="#d9480f"/></svg>
                  </div>
                  <div class="island-card-name" style="color:#ff922b">Badlands</div>
                </div>
                <div class="island-card" data-island="forest" onclick="clickIsland('forest')" style="--iclr:#3d6312;--itxt:#94d82d">
                  <div class="island-rank-badge"></div>
                  <div class="island-card-ico" style="background:linear-gradient(135deg,#3d6312,#0c0d10)">
                    <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><rect x="16" y="26" width="4" height="8" fill="#7a5230"/><polygon points="18,5 27,18 9,18" fill="#5c940d"/><polygon points="18,11 29,26 7,26" fill="#82c91e"/><polygon points="18,17 30,32 6,32" fill="#a9e34b"/></svg>
                  </div>
                  <div class="island-card-name" style="color:#94d82d">Forest</div>
                </div>
              </div>
              <input type="hidden" name="island_choices" id="islandChoicesInput"/>
              <div class="island-rank-status" id="islandRankStatus">Select all 4 islands to continue</div>
            </div>

            <div class="apw-field">
              <label class="apw-label">Friends you want to play with</label>
              <p class="apw-field-hint">Optional. List the Minecraft IGNs of anyone you'd like to be placed with, one per line. <strong>Important:</strong> they must also include your IGN in their application — both sides need to list each other for us to try and group you together.</p>
              <textarea name="friend_requests" class="apw-textarea" rows="3" placeholder="Enter IGNs here, one per line..."></textarea>
            </div>

            <div class="apw-nav">
              <button type="button" class="apw-btn-ghost" onclick="goStage(2)">Back</button>
              <button type="button" class="apw-btn-next" onclick="nextFrom(3)">Next</button>
            </div>
          </div>

          <!-- ── STAGE 4: PLAYSTYLE ── -->
          <div class="wizard-stage apw-stage" id="stage-4">
            <div class="apw-stage-num">Stage 4 of 7</div>
            <h2><%= (stageSettings[3] && stageSettings[3].title) || 'Playstyle' %></h2>
            <% if (stageSettings[3] && stageSettings[3].subtitle) { %>
              <p class="apw-stage-sub"><%= stageSettings[3].subtitle %></p>
            <% } else { %><p class="apw-stage-sub"></p><% } %>

            <%- (stageBlocks[3] || []).map(b => renderBlock(b)).join('') %>

            <input type="hidden" name="playstyle" id="playstyleVal" />
            <div class="apw-playstyle-grid">
              <% for (const ps of playstyleOptions) { %>
                <div class="playstyle-card" data-val="<%= ps.value_key %>" onclick="pickPlaystyle(this)">
                  <div class="playstyle-card-title"><%= ps.title %></div>
                  <div class="playstyle-card-desc"><%= ps.description %></div>
                </div>
              <% } %>
            </div>
            <div class="apw-field">
              <label class="apw-label"><%= (stageSettings[3] && stageSettings[3].playstyle_desc_label) || 'Describe how you would actually play this event based on your chosen playstyle.' %> <span class="req">*</span></label>
              <textarea name="playstyle_description" class="apw-textarea" rows="4" placeholder="Be specific. What would you actually do on Day 1?"></textarea>
            </div>

            <div class="apw-nav">
              <button type="button" class="apw-btn-ghost" onclick="goStage(3)">Back</button>
              <button type="button" class="apw-btn-next" onclick="nextFrom(4)">Next</button>
            </div>
          </div>

          <!-- ── STAGE 5: SCENARIOS ── -->
          <div class="wizard-stage apw-stage" id="stage-5">
            <div class="apw-stage-num">Stage 5 of 7</div>
            <h2><%= (stageSettings[4] && stageSettings[4].title) || 'Scenario Questions' %></h2>
            <% if (stageSettings[4] && stageSettings[4].subtitle) { %>
              <p class="apw-stage-sub"><%= stageSettings[4].subtitle %></p>
            <% } else { %><p class="apw-stage-sub"></p><% } %>

            <%- (stageBlocks[4] || []).map(b => renderBlock(b)).join('') %>

            <div class="apw-scenario">
              <div class="apw-scenario-num"><%= (stageSettings[4] && stageSettings[4].scenario_1_title) || 'Scenario 1' %></div>
              <div class="apw-scenario-q"><%= (stageSettings[4] && stageSettings[4].scenario_1_text) || '' %></div>
              <textarea name="scenario_1" class="apw-textarea" rows="5" placeholder="Your response..."></textarea>
            </div>
            <div class="apw-scenario">
              <div class="apw-scenario-num"><%= (stageSettings[4] && stageSettings[4].scenario_2_title) || 'Scenario 2' %></div>
              <div class="apw-scenario-q"><%= (stageSettings[4] && stageSettings[4].scenario_2_text) || '' %></div>
              <textarea name="scenario_2" class="apw-textarea" rows="5" placeholder="Your response..."></textarea>
            </div>
            <div class="apw-scenario">
              <div class="apw-scenario-num"><%= (stageSettings[4] && stageSettings[4].scenario_3_title) || 'Scenario 3' %></div>
              <div class="apw-scenario-q"><%= (stageSettings[4] && stageSettings[4].scenario_3_text) || '' %></div>
              <textarea name="scenario_3" class="apw-textarea" rows="5" placeholder="Your response..."></textarea>
            </div>

            <div class="apw-nav">
              <button type="button" class="apw-btn-ghost" onclick="goStage(4)">Back</button>
              <button type="button" class="apw-btn-next" onclick="nextFrom(5)">Next</button>
            </div>
          </div>

          <!-- ── STAGE 6: APPLICATION TYPE ── -->
          <div class="wizard-stage apw-stage" id="stage-6">
            <div class="apw-stage-num">Stage 6 of 7</div>
            <h2><%= (stageSettings[5] && stageSettings[5].title) || 'Your Application' %></h2>
            <% if (stageSettings[5] && stageSettings[5].subtitle) { %>
              <p class="apw-stage-sub"><%= stageSettings[5].subtitle %></p>
            <% } else { %><p class="apw-stage-sub"></p><% } %>

            <%- (stageBlocks[5] || []).map(b => renderBlock(b)).join('') %>

            <input type="hidden" name="app_type" id="appTypeVal" />
            <div class="apw-type-grid">
              <div class="app-type-card" data-type="video" onclick="pickAppType('video',this)">
                <div class="app-type-card-title"><%= (stageSettings[5] && stageSettings[5].video_title) || 'Video' %></div>
                <div class="app-type-card-desc"><%= (stageSettings[5] && stageSettings[5].video_desc) || 'Record a short 1–3 minute introduction and paste the link.' %></div>
              </div>
              <div class="app-type-card" data-type="written" onclick="pickAppType('written',this)">
                <div class="app-type-card-title"><%= (stageSettings[5] && stageSettings[5].written_title) || 'Written' %></div>
                <div class="app-type-card-desc"><%= (stageSettings[5] && stageSettings[5].written_desc) || 'Write at least 150 words about yourself.' %></div>
              </div>
            </div>

            <div id="videoSection" style="display:none" class="apw-cond">
              <div class="apw-field">
                <label class="apw-label">Video Link <span class="req">*</span></label>
                <input type="url" name="video_link" id="videoLinkInput" class="apw-input" placeholder="https://youtu.be/... or Google Drive link" />
              </div>
            </div>
            <div id="writtenSection" style="display:none" class="apw-cond">
              <div class="apw-field">
                <label class="apw-label">Written Application <span class="req">*</span></label>
                <textarea name="written_app" id="writtenInput" class="apw-textarea" rows="10" oninput="updateWordCount(this)" placeholder="Tell us about yourself..."></textarea>
                <div class="apw-wc" id="wordCounter"><span id="wordCountNum">0</span> words <span class="wc-min">(minimum 150)</span></div>
              </div>
            </div>

            <div class="apw-nav">
              <button type="button" class="apw-btn-ghost" onclick="goStage(5)">Back</button>
              <button type="button" class="apw-btn-next" onclick="nextFrom(6)">Next</button>
            </div>
          </div>

          <!-- ── STAGE 7: AGREEMENT ── -->
          <div class="wizard-stage apw-stage" id="stage-7">
            <div class="apw-stage-num">Stage 7 of 7</div>
            <h2><%= (stageSettings[6] && stageSettings[6].title) || 'Final Agreement' %></h2>
            <% if (stageSettings[6] && stageSettings[6].subtitle) { %>
              <p class="apw-stage-sub"><%= stageSettings[6].subtitle %></p>
            <% } else { %>
              <p class="apw-stage-sub">Read and confirm each item to submit your application.</p>
            <% } %>

            <%- (stageBlocks[6] || []).map(b => renderBlock(b)).join('') %>

            <input type="hidden" name="agreements" id="agreementsVal" value="" />
            <div class="apw-agr-list">
              <% for (const item of agreementItems) { %>
                <label class="agr-item">
                  <input type="checkbox" class="agr-check" />
                  <span class="agr-text"><%= item.item_text %></span>
                </label>
              <% } %>
              <label class="agr-item" style="border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:14px 16px;margin-top:10px;background:rgba(255,255,255,.03)">
                <input type="checkbox" class="agr-check" />
                <span class="agr-text"><strong>I confirm that all information I have provided in this application is truthful, accurate, and my own.</strong> I understand that submitting false or misleading information may result in my removal from the event.</span>
              </label>
            </div>

            <div class="apw-nav">
              <button type="button" class="apw-btn-ghost" onclick="goStage(6)">Back</button>
              <button type="submit" class="apw-btn-submit" id="submitBtn" disabled>Submit Application</button>
            </div>
          </div>

        </form>
      </div>

    <% } %>

  </div>
</main>

<script>
// Timestamp display
document.querySelectorAll('.tz-stamp').forEach(function(el) {
  try {
    var d = new Date(el.dataset.utc);
    el.textContent = d.toLocaleString(undefined, {
      weekday:'long',year:'numeric',month:'long',day:'numeric',
      hour:'2-digit',minute:'2-digit',timeZoneName:'short'
    });
  } catch(_) {}
});

// Admin preview mode
var ADMIN_PREVIEW = <%- locals.isAdmin ? 'true' : 'false' %>;
var adminSkipOn = false;
function toggleAdminSkip() {
  adminSkipOn = !adminSkipOn;
  var btn = document.getElementById('adminSkipBtn');
  btn.textContent = adminSkipOn ? 'Skip ON' : 'Skip OFF';
  btn.style.background = adminSkipOn ? 'rgba(251,191,36,.25)' : 'rgba(255,255,255,.08)';
  btn.style.borderColor = adminSkipOn ? '#fbbf24' : 'rgba(255,255,255,.15)';
  btn.style.color = adminSkipOn ? '#fbbf24' : '#c9ccdb';
  if (adminSkipOn) {
    document.getElementById('quizNextBtn').disabled = false;
    quizAnswered = [true, true, true];
    updateQuizStatus();
  }
}

// Stage navigation
var currentStageNum = 1;
function goStage(n) {
  var goingForward = n > currentStageNum;
  document.querySelectorAll('.wizard-stage').forEach(function(s) {
    s.classList.remove('active');
  });
  document.getElementById('stage-' + n).classList.add('active');
  currentStageNum = n;
  saveDraft();

  document.querySelectorAll('.wizard-step').forEach(function(el, i) {
    el.classList.toggle('done', i + 1 < n);
    el.classList.toggle('active', i + 1 === n);
  });
  document.querySelectorAll('.wizard-connector').forEach(function(el, i) {
    el.classList.toggle('done', i + 1 < n);
  });

  var hdr = document.getElementById('wizardHeader');
  if (hdr) window.scrollTo({ top: hdr.offsetTop - 90, behavior: 'smooth' });
}

// Eligibility
var eligAnswers = {};
document.querySelectorAll('.yn-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    this.closest('.elig-item').querySelectorAll('.yn-btn').forEach(function(b) {
      b.classList.remove('selected');
    });
    this.classList.add('selected');
    eligAnswers[this.closest('.elig-item').dataset.id] = this.dataset.val;
    var total = document.querySelectorAll('.elig-item').length;
    document.getElementById('eligCheckBtn').disabled = Object.keys(eligAnswers).length < total;
  });
});

function checkEligibility() {
  var disq = false;
  document.querySelectorAll('.elig-item').forEach(function(item) {
    if (item.dataset.blocking !== 'true') return;
    var ans = eligAnswers[item.dataset.id];
    if (item.dataset.reqYes === 'true' && ans === 'no') disq = true;
    if (item.dataset.reqYes === 'false' && ans === 'yes') disq = true;
  });
  document.getElementById('eligAnswersInput').value = JSON.stringify(eligAnswers);
  if (disq) {
    fetch('/apply/record-disqualified', {
      method:'POST',headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ answers: eligAnswers })
    }).catch(function(){});
    document.getElementById('eligQList').style.display = 'none';
    document.getElementById('stage1Nav').style.display = 'none';
    document.getElementById('disqMsg').style.display = 'block';
  } else {
    goStage(2);
  }
}

function resetEligibility() {
  document.getElementById('eligQList').style.display = '';
  document.getElementById('stage1Nav').style.display = '';
  document.getElementById('disqMsg').style.display = 'none';
  document.querySelectorAll('.yn-btn').forEach(function(b) { b.classList.remove('selected'); });
  Object.keys(eligAnswers).forEach(function(k) { delete eligAnswers[k]; });
  document.getElementById('eligCheckBtn').disabled = true;
}

// Toggle opts (yes/no toggles)
function setToggle(inputId, val, btn, wrapId) {
  btn.parentElement.querySelectorAll('.toggle-opt').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById(inputId).value = val;
  var wrap = document.getElementById(wrapId);
  if (wrap) wrap.style.display = val === 'yes' ? 'block' : 'none';
}

// Playstyle selection
function pickPlaystyle(card) {
  document.querySelectorAll('.playstyle-card').forEach(function(c) { c.classList.remove('selected'); });
  card.classList.add('selected');
  document.getElementById('playstyleVal').value = card.dataset.val;
}

// App type selection
function pickAppType(type, card) {
  document.querySelectorAll('.app-type-card').forEach(function(c) { c.classList.remove('selected'); });
  card.classList.add('selected');
  document.getElementById('appTypeVal').value = type;
  document.getElementById('videoSection').style.display = type === 'video' ? 'block' : 'none';
  document.getElementById('writtenSection').style.display = type === 'written' ? 'block' : 'none';
}

function updateWordCount(ta) {
  var n = ta.value.trim() ? ta.value.trim().split(/\s+/).length : 0;
  document.getElementById('wordCountNum').textContent = n;
  document.getElementById('wordCounter').classList.toggle('ok', n >= 150);
}

// Agreement checkboxes
document.querySelectorAll('.agr-check').forEach(function(cb) {
  cb.addEventListener('change', function() {
    var all = Array.from(document.querySelectorAll('.agr-check')).every(function(c) { return c.checked; });
    document.getElementById('submitBtn').disabled = !all;
    document.getElementById('agreementsVal').value = all ? 'confirmed' : '';
  });
});

// Island preference ranking
var islandRanks = {};
var ORDINALS = ['1st','2nd','3rd','4th'];

function clickIsland(val) {
  if (islandRanks[val] !== undefined) {
    var removed = islandRanks[val];
    delete islandRanks[val];
    Object.keys(islandRanks).forEach(function(k) {
      if (islandRanks[k] > removed) islandRanks[k]--;
    });
  } else {
    var nextRank = Object.keys(islandRanks).length + 1;
    if (nextRank > 4) return;
    islandRanks[val] = nextRank;
  }
  updateIslandUI();
}

function updateIslandUI() {
  document.querySelectorAll('.island-card').forEach(function(card) {
    var val = card.dataset.island;
    var rank = islandRanks[val];
    var badge = card.querySelector('.island-rank-badge');
    card.classList.toggle('ranked', rank !== undefined);
    badge.textContent = rank !== undefined ? ORDINALS[rank - 1] : '';
    badge.style.opacity = rank !== undefined ? '1' : '0';
  });
  var count = Object.keys(islandRanks).length;
  var statusEl = document.getElementById('islandRankStatus');
  if (count === 4) {
    var ordered = ['', '', '', ''];
    Object.keys(islandRanks).forEach(function(k) { ordered[islandRanks[k] - 1] = k; });
    document.getElementById('islandChoicesInput').value = JSON.stringify(ordered);
    statusEl.textContent = 'All set';
    statusEl.classList.add('ok');
  } else {
    document.getElementById('islandChoicesInput').value = '';
    statusEl.textContent = (4 - count) + ' more to select';
    statusEl.classList.remove('ok');
  }
}

// Reading confirmation + quiz reveal
function onReadingConfirm() {
  var checked = document.getElementById('readingConfirmCheck').checked;
  var quizSection = document.getElementById('quizSection');
  if (checked) {
    quizSection.style.display = 'block';
    initQuiz();
  } else {
    quizSection.style.display = 'none';
    document.getElementById('quizNextBtn').disabled = true;
    quizAnswered = [false, false, false];
  }
}

// Quiz
var QUIZ_POOL = [
  { q:'Is PvP enabled during session 1?', opts:['Yes, from the start','No, it is disabled','Only near the walls','Only in contested zones'], a:1 },
  { q:'From which session is PvP permanently enabled?', opts:['Session 1','Session 2','Session 3','Session 4'], a:1 },
  { q:'What happens if you disconnect to avoid death?', opts:['You receive a warning','Nothing — it is allowed','It is a bannable offence','You lose your items'], a:2 },
  { q:'Is stealing from other players and their bases allowed?', opts:['No, never','Yes, it is fully allowed','Only after session 3','Only between islands'], a:1 },
  { q:'Is destroying another player\'s builds purely to grief allowed?', opts:['Yes, completely','No, it is not allowed','Only on enemy islands','Only in early sessions'], a:1 },
  { q:'Where should you report a rule break during a live session?', opts:['In public chat','By opening a ticket','By messaging a staff member directly','In Discord after the event'], a:1 },
  { q:'Which mods are explicitly allowed?', opts:['Any PvP mods','No mods at all','Performance mods like Sodium and Optifine','Any client-side mods'], a:2 },
  { q:'Is impersonating staff a bannable offence?', opts:['No, just a warning','Yes','Only if done repeatedly','Only in public chat'], a:1 },
  { q:'Can you share information about the event publicly before it begins?', opts:['Yes, freely','No','Only with your own community','Only after sign-up closes'], a:1 },
  { q:'Is killing a player on your own island allowed from session 2?', opts:['No, only players from other islands','Yes, anyone can be killed from session 2','Only with staff permission','Only in contested zones'], a:1 },
  { q:'Can you advertise other servers or Discord servers during the event?', opts:['Yes, freely','No, it is not allowed','Only in private messages','Only before sessions'], a:1 },
  { q:'Is sharing another player\'s real life personal information allowed?', opts:['Yes, if they agree','No, never','Only if relevant to a dispute','Only between friends'], a:1 },
  { q:'What happens if you abuse the ticket system with false reports?', opts:['Nothing','You receive a warning','You will be punished','You are automatically removed'], a:2 },
  { q:'Is intentionally destroying your own island\'s altar allowed?', opts:['Yes, it is your island','No, it is not allowed','Only in sessions 1-2','Only with your island\'s agreement'], a:1 },
];
var quizAnswered = [false, false, false];
var quizCurrent = [null, null, null];
var ORDINALS_Q = ['1st','2nd','3rd'];

function initQuiz() {
  quizAnswered = [false, false, false];
  var pool = QUIZ_POOL.slice();
  shuffle(pool);
  for (var i = 0; i < 3; i++) {
    quizCurrent[i] = pool[i];
    renderQuizQ(i);
  }
  updateQuizStatus();
}

function shuffle(arr) {
  for (var i = arr.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var t = arr[i]; arr[i] = arr[j]; arr[j] = t;
  }
}

function renderQuizQ(slot) {
  var q = quizCurrent[slot];
  var opts = q.opts.map(function(o, i) { return { text: o, correct: i === q.a }; });
  shuffle(opts);
  var html = '<div class="quiz-q-text">' + (slot + 1) + '. ' + q.q + '</div><div class="quiz-opts">';
  opts.forEach(function(opt) {
    html += '<button type="button" class="quiz-opt" data-correct="' + opt.correct + '" onclick="answerQuiz(' + slot + ',this)">' + opt.text + '</button>';
  });
  html += '</div>';
  var container = document.getElementById('quizQ' + slot);
  container.innerHTML = html;
  container.className = 'quiz-question';
}

function answerQuiz(slot, btn) {
  if (quizAnswered[slot]) return;
  if (btn.dataset.correct === 'true') {
    btn.classList.add('correct');
    quizAnswered[slot] = true;
    document.getElementById('quizQ' + slot).classList.add('passed');
    btn.closest('.quiz-opts').querySelectorAll('.quiz-opt').forEach(function(b) { b.disabled = true; });
  } else {
    btn.classList.add('wrong');
    btn.disabled = true;
    setTimeout(function() { replaceQuizQ(slot); }, 900);
  }
  updateQuizStatus();
}

function replaceQuizQ(slot) {
  var usedQs = quizCurrent.map(function(q) { return q ? q.q : ''; });
  var available = QUIZ_POOL.filter(function(q) { return usedQs.indexOf(q.q) === -1; });
  if (!available.length) available = QUIZ_POOL;
  var newQ = available[Math.floor(Math.random() * available.length)];
  quizCurrent[slot] = newQ;
  renderQuizQ(slot);
}

function updateQuizStatus() {
  var count = quizAnswered.filter(Boolean).length;
  var statusEl = document.getElementById('quizStatus');
  statusEl.textContent = count + ' of 3 correct';
  statusEl.className = 'quiz-status' + (count === 3 ? ' ok' : '');
  document.getElementById('quizNextBtn').disabled = count < 3;
}

// Stage validation
function nextFrom(stage) {
  if (adminSkipOn) { goStage(stage + 1); return; }
  if (stage === 3) {
    var required = ['ign','discord_username','age','country','how_heard'];
    for (var i = 0; i < required.length; i++) {
      var el = document.querySelector('[name="' + required[i] + '"]');
      if (!el.value.trim()) {
        el.classList.add('input-error');
        el.scrollIntoView({ behavior:'smooth', block:'center' });
        el.addEventListener('input', function() { this.classList.remove('input-error'); }, { once:true });
        return;
      }
    }
    if (!document.getElementById('islandChoicesInput').value) {
      document.querySelector('.island-rank-grid').scrollIntoView({ behavior:'smooth', block:'center' });
      document.getElementById('islandRankStatus').classList.add('err');
      return;
    }
    var _sessVal = [];
    try { _sessVal = JSON.parse(document.getElementById('sessionAvailInput').value || '[]'); } catch(e) {}
    if (_sessVal.length < 5 || !_sessVal.includes(1)) {
      var _saSt = document.getElementById('sessionAvailStatus');
      if (!_sessVal.includes(1)) {
        _saSt.textContent = 'Session 1 is required — please tick it if you can attend.';
      } else {
        _saSt.textContent = 'Please select at least 5 sessions you can attend.';
      }
      _saSt.className = 'session-avail-status err';
      document.getElementById('sessionAvailGrid').scrollIntoView({ behavior:'smooth', block:'center' });
      return;
    }
  }
  if (stage === 4) {
    if (!document.getElementById('playstyleVal').value) {
      alert('Please select a playstyle to continue.');
      return;
    }
    if (!document.querySelector('[name="playstyle_description"]').value.trim()) {
      document.querySelector('[name="playstyle_description"]').focus();
      return;
    }
  }
  if (stage === 5) {
    var scenarios = ['scenario_1','scenario_2','scenario_3'];
    for (var i = 0; i < scenarios.length; i++) {
      if (!document.querySelector('[name="' + scenarios[i] + '"]').value.trim()) {
        document.querySelector('[name="' + scenarios[i] + '"]').scrollIntoView({ behavior:'smooth', block:'center' });
        alert('Please answer all scenario questions.');
        return;
      }
    }
  }
  if (stage === 6) {
    var type = document.getElementById('appTypeVal').value;
    if (!type) { alert('Please choose video or written.'); return; }
    if (type === 'video' && !document.getElementById('videoLinkInput').value.trim()) {
      document.getElementById('videoLinkInput').focus();
      return;
    }
    if (type === 'written') {
      var words = document.getElementById('writtenInput').value.trim()
        ? document.getElementById('writtenInput').value.trim().split(/\s+/).length : 0;
      if (words < 150) {
        alert('Your written application needs at least 150 words. You have ' + words + '.');
        return;
      }
    }
  }
  goStage(stage + 1);
}

// ── Session availability ───────────────────────────────────────────────────
var SESSION_TIMES = [
  1754841600,1755014400,1755187200,1755360000,1755532800,
  1755705600,1755878400,1756051200,1756224000,1756396800
];

function initSessionAvail() {
  var grid = document.getElementById('sessionAvailGrid');
  if (!grid) return;
  SESSION_TIMES.forEach(function(ts, i) {
    var d = new Date(ts * 1000);
    var dateStr = d.toLocaleDateString(undefined, { weekday:'short', day:'numeric', month:'short', year:'numeric' });
    var timeStr = d.toLocaleTimeString(undefined, { hour:'2-digit', minute:'2-digit', timeZoneName:'short' });
    var row = document.createElement('label');
    row.className = 'session-avail-row';
    row.innerHTML =
      '<input type="checkbox" class="session-avail-chk" data-session="' + (i+1) + '" onchange="updateSessionAvail()">' +
      '<span class="session-avail-num">Session ' + (i+1) + '</span>' +
      '<span class="session-avail-date">' + dateStr + ' &mdash; ' + timeStr + '</span>';
    grid.appendChild(row);
  });
}

function updateSessionAvail() {
  var checked = [];
  document.querySelectorAll('.session-avail-chk').forEach(function(chk) {
    if (chk.checked) checked.push(parseInt(chk.dataset.session));
  });
  document.getElementById('sessionAvailInput').value = JSON.stringify(checked);
  saveDraft();
  var status = document.getElementById('sessionAvailStatus');
  var count = checked.length;
  if (count === 0) { status.textContent = ''; status.className = 'session-avail-status'; return; }
  var hasS1 = checked.includes(1);
  if (count < 5 || !hasS1) {
    var msg = !hasS1 ? 'Session 1 is required' : (5 - count) + ' more session' + (5 - count !== 1 ? 's' : '') + ' needed';
    status.textContent = count + ' selected — ' + msg;
    status.className = 'session-avail-status warn';
  } else {
    status.textContent = count + ' sessions selected ✓';
    status.className = 'session-avail-status ok';
  }
}

// ── Draft persistence ──────────────────────────────────────────────────────
var DRAFT_KEY = 'tfn_draft_' + '<%= locals.user ? locals.user.id : "guest" %>';
var DRAFT_EXISTS = <%- locals.existing ? 'true' : 'false' %>;

function _dv(sel) { var e = document.querySelector(sel); return e ? e.value : ''; }
function _di(id)  { var e = document.getElementById(id);  return e ? e.value : ''; }

function saveDraft() {
  if (DRAFT_EXISTS || !document.getElementById('applyForm')) return;
  try {
    localStorage.setItem(DRAFT_KEY, JSON.stringify({
      v: 2,
      stage: currentStageNum,
      quizPassed: quizAnswered.every(Boolean),
      elig:        _di('eligAnswersInput'),
      ign:         _dv('[name="ign"]'),
      disc:        _dv('[name="discord_username"]'),
      age:         _dv('[name="age"]'),
      country:     _dv('[name="country"]'),
      how_heard:   _dv('[name="how_heard"]'),
      played_civ:  _di('playedCivVal'),
      civ_details: _dv('[name="played_civ_details"]'),
      creates_content: _di('createsContentVal'),
      content_link: _dv('[name="content_link"]'),
      islandRanks: islandRanks,
      friends:     _dv('[name="friend_requests"]'),
      playstyle:   _di('playstyleVal'),
      ps_desc:     _dv('[name="playstyle_description"]'),
      s1:          _dv('[name="scenario_1"]'),
      s2:          _dv('[name="scenario_2"]'),
      s3:          _dv('[name="scenario_3"]'),
      app_type:     _di('appTypeVal'),
      video_link:   _di('videoLinkInput'),
      written_app:  _di('writtenInput'),
      session_avail: _di('sessionAvailInput'),
    }));
  } catch(e) {}
}

function clearDraft() {
  try { localStorage.removeItem(DRAFT_KEY); } catch(e) {}
}

function loadDraft() {
  if (DRAFT_EXISTS) { clearDraft(); return; }
  if (!document.getElementById('applyForm')) return;
  try {
    var raw = localStorage.getItem(DRAFT_KEY);
    if (!raw) return;
    var d = JSON.parse(raw);
    if (d.v !== 2) { clearDraft(); return; }

    function sv(sel, v) { var e = document.querySelector(sel); if (e && v) e.value = v; }
    function si(id,  v) { var e = document.getElementById(id);  if (e && v) e.value = v; }

    sv('[name="ign"]',                d.ign);
    sv('[name="discord_username"]',   d.disc);
    sv('[name="age"]',                d.age);
    sv('[name="country"]',            d.country);
    sv('[name="how_heard"]',          d.how_heard);
    sv('[name="played_civ_details"]', d.civ_details);
    sv('[name="content_link"]',       d.content_link);
    sv('[name="friend_requests"]',    d.friends);
    sv('[name="playstyle_description"]', d.ps_desc);
    sv('[name="scenario_1"]',         d.s1);
    sv('[name="scenario_2"]',         d.s2);
    sv('[name="scenario_3"]',         d.s3);
    si('videoLinkInput',              d.video_link);
    if (d.written_app) {
      si('writtenInput', d.written_app);
      var wi = document.getElementById('writtenInput');
      if (wi) updateWordCount(wi);
    }
    if (d.elig) si('eligAnswersInput', d.elig);

    // played_civ toggle button
    if (d.played_civ === 'yes') {
      var yBtn = document.querySelector('[onclick*="playedCivVal"][onclick*="\'yes\'"]');
      if (yBtn) yBtn.click();
    }

    // creates_content toggle button
    if (d.creates_content === 'yes') {
      var cBtn = document.querySelector('[onclick*="createsContentVal"][onclick*="\'yes\'"]');
      if (cBtn) cBtn.click();
    }

    // island ranks
    if (d.islandRanks && Object.keys(d.islandRanks).length) {
      islandRanks = d.islandRanks;
      updateIslandUI();
    }

    // playstyle card
    if (d.playstyle) {
      var psCard = document.querySelector('.playstyle-card[data-val="' + d.playstyle + '"]');
      if (psCard) pickPlaystyle(psCard);
    }

    // session availability checkboxes
    if (d.session_avail) {
      try {
        var savedSess = JSON.parse(d.session_avail);
        si('sessionAvailInput', d.session_avail);
        document.querySelectorAll('.session-avail-chk').forEach(function(chk) {
          chk.checked = savedSess.includes(parseInt(chk.dataset.session));
        });
        updateSessionAvail();
      } catch(e) {}
    }

    // app type card
    if (d.app_type) {
      var atCard = document.querySelector('.app-type-card[data-type="' + d.app_type + '"]');
      if (atCard) pickAppType(d.app_type, atCard);
    }

    // quiz state
    if (d.quizPassed) {
      quizAnswered = [true, true, true];
      var qBtn = document.getElementById('quizNextBtn');
      if (qBtn) qBtn.disabled = false;
    }

    // Jump to saved stage and show banner
    var target = parseInt(d.stage) || 1;
    if (target > 1) {
      goStage(target);
      var banner = document.getElementById('resumeBanner');
      if (banner) {
        banner.style.display = 'flex';
        document.getElementById('resumeStageNum').textContent = target;
      }
    }
  } catch(e) {}
}

// Initialise session grid and load draft on page ready
initSessionAvail();

// Auto-save on every text input (debounced 600ms)
var _saveTimer;
document.querySelectorAll('.apw-textarea, .apw-input').forEach(function(el) {
  el.addEventListener('input', function() {
    clearTimeout(_saveTimer);
    _saveTimer = setTimeout(saveDraft, 600);
  });
});

// Clear draft on successful submit
var _applyForm = document.getElementById('applyForm');
if (_applyForm) _applyForm.addEventListener('submit', clearDraft);

// Restore draft on page load
loadDraft();
</script>

