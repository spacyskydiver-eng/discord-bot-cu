            <h2><%= (stageSettings[5] && stageSettings[5].title) || t('apply_s6_your_app_fallback') %></h2>
            <% if (stageSettings[5] && stageSettings[5].subtitle) { %>
              <p class="apw-stage-sub"><%= stageSettings[5].subtitle %></p>
            <% } else { %><p class="apw-stage-sub"></p><% } %>

            <%- (stageBlocks[5] || []).map(b => renderBlock(b)).join('') %>

            <input type="hidden" name="app_type" id="appTypeVal" />
            <div class="apw-type-grid">
              <div class="app-type-card" data-type="video" onclick="pickAppType('video',this)">
                <div class="app-type-card-title"><%= (stageSettings[5] && stageSettings[5].video_title) || t('apply_s6_video_title') %></div>
                <div class="app-type-card-desc"><%= (stageSettings[5] && stageSettings[5].video_desc) || t('apply_s6_video_desc') %></div>
              </div>
              <div class="app-type-card" data-type="written" onclick="pickAppType('written',this)">
                <div class="app-type-card-title"><%= (stageSettings[5] && stageSettings[5].written_title) || t('apply_s6_written_title') %></div>
                <div class="app-type-card-desc"><%= (stageSettings[5] && stageSettings[5].written_desc) || t('apply_s6_written_desc') %></div>
              </div>
            </div>

            <div id="videoSection" style="display:none" class="apw-cond">
              <div class="apw-field">
                <label class="apw-label"><%= t('apply_s6_video_link') %> <span class="req">*</span></label>
                <input type="url" name="video_link" id="videoLinkInput" class="apw-input" placeholder="<%= t('apply_s6_video_ph') %>" />
              </div>
            </div>
            <div id="writtenSection" style="display:none" class="apw-cond">
              <div class="apw-field">
                <label class="apw-label"><%= t('apply_s6_written_label') %> <span class="req">*</span></label>
                <textarea name="written_app" id="writtenInput" class="apw-textarea" rows="10" oninput="updateWordCount(this)" placeholder="<%= t('apply_s6_written_ph') %>"></textarea>
                <div class="apw-wc" id="wordCounter"><span id="wordCountNum">0</span> <%= t('apply_wc_words') %> <span class="wc-min"><%= t('apply_s6_wc_min') %></span></div>
              </div>
            </div>

            <div class="apw-nav">
              <button type="button" class="apw-btn-ghost" onclick="goStage(5)"><%= t('btn_back') %></button>
              <button type="button" class="apw-btn-next" onclick="nextFrom(6)"><%= t('btn_next') %></button>
            </div>
          </div>

          <!-- ── STAGE 7: AGREEMENT ── -->
          <div class="wizard-stage apw-stage" id="stage-7">
            <div class="apw-stage-num"><%= t('apply_stage_prefix') %> 7 <%= t('apply_stage_of') %> 7</div>
            <h2><%= (stageSettings[6] && stageSettings[6].title) || t('apply_s7_final_agree_fallback') %></h2>
            <% if (stageSettings[6] && stageSettings[6].subtitle) { %>
              <p class="apw-stage-sub"><%= stageSettings[6].subtitle %></p>
            <% } else { %>
              <p class="apw-stage-sub"><%= t('apply_s7_sub') %></p>
            <% } %>

            <%- (stageBlocks[6] || []).map(b => renderBlock(b)).join('') %>

            <input type="hidden" name="agreements" id="agreementsVal" value="" />
            <div class="apw-agr-list">
              <% for (const item of agreementItems) { %>
                <label class="agr-item">
                  <input type="checkbox" class="agr-check" />
                  <span class="agr-text"><%= item.item_text %></span>
                </label>
              <% } %>
              <label class="agr-item" style="border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:14px 16px;margin-top:10px;background:rgba(255,255,255,.03)">
                <input type="checkbox" class="agr-check" />
                <span class="agr-text"><%= t('apply_s7_confirm') %></span>
              </label>
            </div>

            <div class="apw-nav">
              <button type="button" class="apw-btn-ghost" onclick="goStage(6)"><%= t('btn_back') %></button>
              <button type="submit" class="apw-btn-submit" id="submitBtn"><%= t('btn_submit') %></button>
            </div>
          </div>

        </form>
      </div>

    <% } %>

  </div>
</main>

<script>
// Timestamp display
document.querySelectorAll('.tz-stamp').forEach(function(el) {
  try {
    var d = new Date(el.dataset.utc);
    el.textContent = d.toLocaleString(undefined, {
      weekday:'long',year:'numeric',month:'long',day:'numeric',
      hour:'2-digit',minute:'2-digit',timeZoneName:'short'
    });
  } catch(_) {}
});

// Locale strings used in JS
var L = {
  skipOn:          '<%= t("apply_skip_on") %>',
  skipOff:         '<%= t("apply_skip_off") %>',
  islandAllSet:    '<%= t("apply_s3_island_all_set") %>',
  islandMoreSel:   '<%= t("apply_more_to_select") %>',
  ordinals:        <%- JSON.stringify(t('apply_ordinals')) %>,
  quizStatusOf:    '<%= t("apply_quiz_status_of") %>',
  sessionPrefix:   '<%= t("apply_session_prefix") %>',
  sessSelected:    '<%= t("apply_session_selected") %>',
  sessMoreNeeded:  '<%= t("apply_session_more_needed") %>',
  sessMoreNeededP: '<%= t("apply_session_more_needed_plural") %>',
  sessS1Required:  '<%= t("apply_session_s1_required") %>',
  sessSelectedWarn:'<%= t("apply_session_selected_warn") %>',
  alertPlaystyle:  '<%= t("apply_alert_playstyle") %>',
  alertScenarios:  '<%= t("apply_alert_scenarios") %>',
  alertAppType:    '<%= t("apply_alert_app_type") %>',
  alertWcPre:      '<%= t("apply_alert_written_wc_pre") %>',
  wcWords:         '<%= t("apply_wc_words") %>'
};

// Admin preview mode
var ADMIN_PREVIEW = <%- locals.isAdmin ? 'true' : 'false' %>;
var adminSkipOn = false;
function toggleAdminSkip() {
  adminSkipOn = !adminSkipOn;
  var btn = document.getElementById('adminSkipBtn');
  btn.textContent = adminSkipOn ? L.skipOn : L.skipOff;
  btn.style.background = adminSkipOn ? 'rgba(251,191,36,.25)' : 'rgba(255,255,255,.08)';
  btn.style.borderColor = adminSkipOn ? '#fbbf24' : 'rgba(255,255,255,.15)';
  btn.style.color = adminSkipOn ? '#fbbf24' : '#c9ccdb';
  if (adminSkipOn) {
    document.getElementById('quizNextBtn').disabled = false;
    quizAnswered = [true, true, true];
    updateQuizStatus();
  }
}

// Stage navigation
var currentStageNum = 1;
function goStage(n) {
  var goingForward = n > currentStageNum;
  document.querySelectorAll('.wizard-stage').forEach(function(s) {
    s.classList.remove('active');
  });
  document.getElementById('stage-' + n).classList.add('active');
  currentStageNum = n;
  saveDraft();

  document.querySelectorAll('.wizard-step').forEach(function(el, i) {
    el.classList.toggle('done', i + 1 < n);
    el.classList.toggle('active', i + 1 === n);
  });
  document.querySelectorAll('.wizard-connector').forEach(function(el, i) {
    el.classList.toggle('done', i + 1 < n);
  });

  var hdr = document.getElementById('wizardHeader');
  if (hdr) window.scrollTo({ top: hdr.offsetTop - 90, behavior: 'smooth' });
}

// Eligibility
var eligAnswers = {};
document.querySelectorAll('.yn-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    this.closest('.elig-item').querySelectorAll('.yn-btn').forEach(function(b) {
      b.classList.remove('selected');
    });
    this.classList.add('selected');
    eligAnswers[this.closest('.elig-item').dataset.id] = this.dataset.val;
    var total = document.querySelectorAll('.elig-item').length;
    document.getElementById('eligCheckBtn').disabled = Object.keys(eligAnswers).length < total;
  });
});

function checkEligibility() {
  var disq = false;
  document.querySelectorAll('.elig-item').forEach(function(item) {
    if (item.dataset.blocking !== 'true') return;
    var ans = eligAnswers[item.dataset.id];
    if (item.dataset.reqYes === 'true' && ans === 'no') disq = true;
    if (item.dataset.reqYes === 'false' && ans === 'yes') disq = true;
  });
  document.getElementById('eligAnswersInput').value = JSON.stringify(eligAnswers);
  if (disq) {
    document.getElementById('eligQList').style.display = 'none';
    document.getElementById('stage1Nav').style.display = 'none';
    document.getElementById('disqMsg').style.display = 'block';
  } else {
    goStage(2);
  }
}

function resetEligibility() {
  document.getElementById('eligQList').style.display = '';
  document.getElementById('stage1Nav').style.display = '';
  document.getElementById('disqMsg').style.display = 'none';
  document.querySelectorAll('.yn-btn').forEach(function(b) { b.classList.remove('selected'); });
  Object.keys(eligAnswers).forEach(function(k) { delete eligAnswers[k]; });
  document.getElementById('eligCheckBtn').disabled = true;
}

// Toggle opts (yes/no toggles)
function setToggle(inputId, val, btn, wrapId) {
  btn.parentElement.querySelectorAll('.toggle-opt').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById(inputId).value = val;
  var wrap = document.getElementById(wrapId);
  if (wrap) wrap.style.display = val === 'yes' ? 'block' : 'none';
}

// Playstyle selection
function pickPlaystyle(card) {
  document.querySelectorAll('.playstyle-card').forEach(function(c) { c.classList.remove('selected'); });
  card.classList.add('selected');
  document.getElementById('playstyleVal').value = card.dataset.val;
}

// App type selection
function pickAppType(type, card) {
  document.querySelectorAll('.app-type-card').forEach(function(c) { c.classList.remove('selected'); });
  card.classList.add('selected');
  document.getElementById('appTypeVal').value = type;
  document.getElementById('videoSection').style.display = type === 'video' ? 'block' : 'none';
  document.getElementById('writtenSection').style.display = type === 'written' ? 'block' : 'none';
}

function updateWordCount(ta) {
  var n = ta.value.trim() ? ta.value.trim().split(/\s+/).length : 0;
  document.getElementById('wordCountNum').textContent = n;
  document.getElementById('wordCounter').classList.toggle('ok', n >= 150);
}

// Agreement checkboxes — update hidden value; validation happens on submit
document.querySelectorAll('.apw-agr-list .agr-check').forEach(function(cb) {
  cb.addEventListener('change', function() {
    var all = Array.from(document.querySelectorAll('.apw-agr-list .agr-check')).every(function(c) { return c.checked; });
    document.getElementById('agreementsVal').value = all ? 'confirmed' : '';
  });
});

// Island preference ranking
var islandRanks = {};
var ORDINALS = L.ordinals;

function clickIsland(val) {
  if (islandRanks[val] !== undefined) {
    var removed = islandRanks[val];
    delete islandRanks[val];
    Object.keys(islandRanks).forEach(function(k) {
      if (islandRanks[k] > removed) islandRanks[k]--;
    });
  } else {
    var nextRank = Object.keys(islandRanks).length + 1;
    if (nextRank > 4) return;
    islandRanks[val] = nextRank;
  }
  updateIslandUI();
}

function updateIslandUI() {
  document.querySelectorAll('.island-card').forEach(function(card) {
    var val = card.dataset.island;
    var rank = islandRanks[val];
    var badge = card.querySelector('.island-rank-badge');
    card.classList.toggle('ranked', rank !== undefined);
    badge.textContent = rank !== undefined ? ORDINALS[rank - 1] : '';
    badge.style.opacity = rank !== undefined ? '1' : '0';
  });
  var count = Object.keys(islandRanks).length;
  var statusEl = document.getElementById('islandRankStatus');
  if (count === 4) {
    var ordered = ['', '', '', ''];
    Object.keys(islandRanks).forEach(function(k) { ordered[islandRanks[k] - 1] = k; });
    document.getElementById('islandChoicesInput').value = JSON.stringify(ordered);
    statusEl.textContent = L.islandAllSet;
    statusEl.classList.add('ok');
  } else {
    document.getElementById('islandChoicesInput').value = '';
    statusEl.textContent = (4 - count) + ' ' + L.islandMoreSel;
    statusEl.classList.remove('ok');
  }
}

// Reading confirmation + quiz reveal
function onReadingConfirm() {
  var checked = document.getElementById('readingConfirmCheck').checked;
  var quizSection = document.getElementById('quizSection');
  if (checked) {
    quizSection.style.display = 'block';
    initQuiz();
  } else {
    quizSection.style.display = 'none';
    document.getElementById('quizNextBtn').disabled = true;
    quizAnswered = [false, false, false];
  }
}

// Quiz
var QUIZ_POOL = <%- JSON.stringify(t('quiz')) %>;
var quizAnswered = [false, false, false];
var quizCurrent = [null, null, null];

function initQuiz() {
  quizAnswered = [false, false, false];
  var pool = QUIZ_POOL.slice();
  shuffle(pool);
  for (var i = 0; i < 3; i++) {
    quizCurrent[i] = pool[i];
    renderQuizQ(i);
  }
  updateQuizStatus();
}

function shuffle(arr) {
  for (var i = arr.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var t = arr[i]; arr[i] = arr[j]; arr[j] = t;
  }
}

function renderQuizQ(slot) {
  var q = quizCurrent[slot];
  var opts = q.opts.map(function(o, i) { return { text: o, correct: i === q.a }; });
  shuffle(opts);
  var html = '<div class="quiz-q-text">' + (slot + 1) + '. ' + q.q + '</div><div class="quiz-opts">';
  opts.forEach(function(opt) {
    html += '<button type="button" class="quiz-opt" data-correct="' + opt.correct + '" onclick="answerQuiz(' + slot + ',this)">' + opt.text + '</button>';
  });
  html += '</div>';
  var container = document.getElementById('quizQ' + slot);
  container.innerHTML = html;
  container.className = 'quiz-question';
}

function answerQuiz(slot, btn) {
  if (quizAnswered[slot]) return;
  if (btn.dataset.correct === 'true') {
    btn.classList.add('correct');
    quizAnswered[slot] = true;
    document.getElementById('quizQ' + slot).classList.add('passed');
    btn.closest('.quiz-opts').querySelectorAll('.quiz-opt').forEach(function(b) { b.disabled = true; });
  } else {
    btn.classList.add('wrong');
    btn.disabled = true;
    setTimeout(function() { replaceQuizQ(slot); }, 900);
  }
  updateQuizStatus();
}

function replaceQuizQ(slot) {
  var usedQs = quizCurrent.map(function(q) { return q ? q.q : ''; });
  var available = QUIZ_POOL.filter(function(q) { return usedQs.indexOf(q.q) === -1; });
  if (!available.length) available = QUIZ_POOL;
  var newQ = available[Math.floor(Math.random() * available.length)];
  quizCurrent[slot] = newQ;
  renderQuizQ(slot);
}

function updateQuizStatus() {
  var count = quizAnswered.filter(Boolean).length;
  var statusEl = document.getElementById('quizStatus');
  statusEl.textContent = count + ' ' + L.quizStatusOf;
  statusEl.className = 'quiz-status' + (count === 3 ? ' ok' : '');
  document.getElementById('quizNextBtn').disabled = count < 3;
}

// Stage validation
function nextFrom(stage) {
  if (adminSkipOn) { goStage(stage + 1); return; }
  if (stage === 3) {
    var required = ['ign','discord_username','age','country','how_heard'];
    for (var i = 0; i < required.length; i++) {
      var el = document.querySelector('[name="' + required[i] + '"]');
      if (!el.value.trim()) {
        el.classList.add('input-error');
        el.scrollIntoView({ behavior:'smooth', block:'center' });
        el.addEventListener('input', function() { this.classList.remove('input-error'); }, { once:true });
        return;
      }
    }
    if (!document.getElementById('islandChoicesInput').value) {
      document.querySelector('.island-rank-grid').scrollIntoView({ behavior:'smooth', block:'center' });
      document.getElementById('islandRankStatus').classList.add('err');
      return;
    }
    var _sessVal = [];
    try { _sessVal = JSON.parse(document.getElementById('sessionAvailInput').value || '[]'); } catch(e) {}
    if (_sessVal.length < 5 || !_sessVal.includes(1)) {
      var _saSt = document.getElementById('sessionAvailStatus');
      if (!_sessVal.includes(1)) {
        _saSt.textContent = L.sessS1Required;
      } else {
        var _needed = 5 - _sessVal.length;
        _saSt.textContent = _needed + ' ' + (_needed !== 1 ? L.sessMoreNeededP : L.sessMoreNeeded);
      }
      _saSt.className = 'session-avail-status err';
      document.getElementById('sessionAvailGrid').scrollIntoView({ behavior:'smooth', block:'center' });
      return;
    }
  }
  if (stage === 4) {
    if (!document.getElementById('playstyleVal').value) {
      alert(L.alertPlaystyle);
      return;
    }
    if (!document.querySelector('[name="playstyle_description"]').value.trim()) {
      document.querySelector('[name="playstyle_description"]').focus();
      return;
    }
  }
  if (stage === 5) {
    var scenarios = ['scenario_1','scenario_2','scenario_3'];
    for (var i = 0; i < scenarios.length; i++) {
      if (!document.querySelector('[name="' + scenarios[i] + '"]').value.trim()) {
        document.querySelector('[name="' + scenarios[i] + '"]').scrollIntoView({ behavior:'smooth', block:'center' });
        alert(L.alertScenarios);
        return;
      }
    }
  }
  if (stage === 6) {
    var type = document.getElementById('appTypeVal').value;
    if (!type) { alert(L.alertAppType); return; }
    if (type === 'video' && !document.getElementById('videoLinkInput').value.trim()) {
      document.getElementById('videoLinkInput').focus();
      return;
    }
    if (type === 'written') {
      var words = document.getElementById('writtenInput').value.trim()
        ? document.getElementById('writtenInput').value.trim().split(/\s+/).length : 0;
      if (words < 150) {
        alert(L.alertWcPre + ' ' + words + ' ' + L.wcWords + '.');
        return;
      }
    }
  }
  goStage(stage + 1);
}

// ── Session availability ───────────────────────────────────────────────────
var SESSION_TIMES = [
  1755360000,1755446400,1755619200,1755792000,1755964800,
  1756137600,1756310400,1756483200,1756656000,1756828800
];

function initSessionAvail() {
  SESSION_TIMES.forEach(function(ts, i) {
    var d = new Date(ts * 1000);
    var dateStr = d.toLocaleDateString(undefined, { weekday:'short', day:'numeric', month:'short', year:'numeric' });
    var timeStr = d.toLocaleTimeString(undefined, { hour:'2-digit', minute:'2-digit', timeZoneName:'short' });

    // Stage 2 overview list
    var schedList = document.getElementById('sessionScheduleList');
    if (schedList) {
      var chip = document.createElement('div');
      chip.style.cssText = 'display:flex;align-items:center;gap:8px;padding:6px 10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;font-size:12px';
      chip.innerHTML = '<span style="font-family:\'Baloo 2\';font-weight:800;color:var(--accent);min-width:72px">' + L.sessionPrefix + ' ' + (i+1) + '</span>' +
        '<span style="color:var(--muted)">' + dateStr + ' &mdash; ' + timeStr + '</span>';
      schedList.appendChild(chip);
    }

    // Stage 3 availability grid
    var grid = document.getElementById('sessionAvailGrid');
    if (grid) {
      var row = document.createElement('label');
      row.className = 'session-avail-row';
      row.innerHTML =
        '<input type="checkbox" class="session-avail-chk" data-session="' + (i+1) + '" onchange="updateSessionAvail()">' +
        '<span class="session-avail-num">' + L.sessionPrefix + ' ' + (i+1) + '</span>' +
        '<span class="session-avail-date">' + dateStr + ' &mdash; ' + timeStr + '</span>';
      grid.appendChild(row);
    }
  });
}

function updateSessionAvail() {
  var checked = [];
  document.querySelectorAll('.session-avail-chk').forEach(function(chk) {
    if (chk.checked) checked.push(parseInt(chk.dataset.session));
  });
  document.getElementById('sessionAvailInput').value = JSON.stringify(checked);
  saveDraft();
  var status = document.getElementById('sessionAvailStatus');
  var count = checked.length;
  if (count === 0) { status.textContent = ''; status.className = 'session-avail-status'; return; }
  var hasS1 = checked.includes(1);
  if (count < 5 || !hasS1) {
    var needed = 5 - count;
    var msg = !hasS1 ? L.sessS1Required : needed + ' ' + (needed !== 1 ? L.sessMoreNeededP : L.sessMoreNeeded);
    status.textContent = count + ' ' + L.sessSelectedWarn + ' ' + msg;
    status.className = 'session-avail-status warn';
  } else {
    status.textContent = count + ' ' + L.sessSelected;
    status.className = 'session-avail-status ok';
  }
}

// ── Draft persistence ──────────────────────────────────────────────────────
var DRAFT_KEY = 'tfn_draft_' + '<%= locals.user ? locals.user.id : "guest" %>';
var DRAFT_EXISTS = <%- locals.existing ? 'true' : 'false' %>;

function _dv(sel) { var e = document.querySelector(sel); return e ? e.value : ''; }
function _di(id)  { var e = document.getElementById(id);  return e ? e.value : ''; }

function saveDraft() {
  if (DRAFT_EXISTS || !document.getElementById('applyForm')) return;
  try {
    localStorage.setItem(DRAFT_KEY, JSON.stringify({
      v: 2,
      stage: currentStageNum,
      quizPassed: quizAnswered.every(Boolean),
      elig:        _di('eligAnswersInput'),
      ign:         _dv('[name="ign"]'),
      disc:        _dv('[name="discord_username"]'),
      age:         _dv('[name="age"]'),
      country:     _dv('[name="country"]'),
      how_heard:   _dv('[name="how_heard"]'),
      played_civ:  _di('playedCivVal'),
      civ_details: _dv('[name="played_civ_details"]'),
      creates_content: _di('createsContentVal'),
      content_link: _dv('[name="content_link"]'),
      islandRanks: islandRanks,
      friends:     _dv('[name="friend_requests"]'),
      playstyle:   _di('playstyleVal'),
      ps_desc:     _dv('[name="playstyle_description"]'),
      s1:          _dv('[name="scenario_1"]'),
      s2:          _dv('[name="scenario_2"]'),
      s3:          _dv('[name="scenario_3"]'),
      app_type:     _di('appTypeVal'),
      video_link:   _di('videoLinkInput'),
      written_app:  _di('writtenInput'),
      session_avail: _di('sessionAvailInput'),
    }));
  } catch(e) {}
}

function clearDraft() {
  try { localStorage.removeItem(DRAFT_KEY); } catch(e) {}
}

function loadDraft() {
  if (DRAFT_EXISTS) { clearDraft(); return; }
  if (!document.getElementById('applyForm')) return;
  try {
    var raw = localStorage.getItem(DRAFT_KEY);
    if (!raw) return;
    var d = JSON.parse(raw);
    if (d.v !== 2) { clearDraft(); return; }

    function sv(sel, v) { var e = document.querySelector(sel); if (e && v) e.value = v; }
    function si(id,  v) { var e = document.getElementById(id);  if (e && v) e.value = v; }

    sv('[name="ign"]',                d.ign);
    sv('[name="discord_username"]',   d.disc);
    sv('[name="age"]',                d.age);
    sv('[name="country"]',            d.country);
    sv('[name="how_heard"]',          d.how_heard);
    sv('[name="played_civ_details"]', d.civ_details);
    sv('[name="content_link"]',       d.content_link);
    sv('[name="friend_requests"]',    d.friends);
    sv('[name="playstyle_description"]', d.ps_desc);
    sv('[name="scenario_1"]',         d.s1);
    sv('[name="scenario_2"]',         d.s2);
    sv('[name="scenario_3"]',         d.s3);
    si('videoLinkInput',              d.video_link);
    if (d.written_app) {
      si('writtenInput', d.written_app);
      var wi = document.getElementById('writtenInput');
      if (wi) updateWordCount(wi);
    }
    if (d.elig) si('eligAnswersInput', d.elig);

    // played_civ toggle button
    if (d.played_civ === 'yes') {
      var yBtn = document.querySelector('[onclick*="playedCivVal"][onclick*="\'yes\'"]');
      if (yBtn) yBtn.click();
    }

    // creates_content toggle button
    if (d.creates_content === 'yes') {
      var cBtn = document.querySelector('[onclick*="createsContentVal"][onclick*="\'yes\'"]');
      if (cBtn) cBtn.click();
    }

    // island ranks
    if (d.islandRanks && Object.keys(d.islandRanks).length) {
      islandRanks = d.islandRanks;
      updateIslandUI();
    }

    // playstyle card
    if (d.playstyle) {
      var psCard = document.querySelector('.playstyle-card[data-val="' + d.playstyle + '"]');
      if (psCard) pickPlaystyle(psCard);
    }

    // session availability checkboxes
    if (d.session_avail) {
      try {
        var savedSess = JSON.parse(d.session_avail);
        si('sessionAvailInput', d.session_avail);
        document.querySelectorAll('.session-avail-chk').forEach(function(chk) {
          chk.checked = savedSess.includes(parseInt(chk.dataset.session));
        });
        updateSessionAvail();
      } catch(e) {}
    }

    // app type card
    if (d.app_type) {
      var atCard = document.querySelector('.app-type-card[data-type="' + d.app_type + '"]');
      if (atCard) pickAppType(d.app_type, atCard);
    }

    // quiz state
    if (d.quizPassed) {
      quizAnswered = [true, true, true];
      var qBtn = document.getElementById('quizNextBtn');
      if (qBtn) qBtn.disabled = false;
    }

    // Jump to saved stage and show banner
    var target = parseInt(d.stage) || 1;
    if (target > 1) {
      goStage(target);
      var banner = document.getElementById('resumeBanner');
      if (banner) {
        banner.style.display = 'flex';
        document.getElementById('resumeStageNum').textContent = target;
      }
    }
  } catch(e) {}
}

// Initialise session grid and load draft on page ready
initSessionAvail();

// Auto-save on every text input (debounced 600ms)
var _saveTimer;
document.querySelectorAll('.apw-textarea, .apw-input').forEach(function(el) {
  el.addEventListener('input', function() {
    clearTimeout(_saveTimer);
    _saveTimer = setTimeout(saveDraft, 600);
  });
});

// Form submit: validate agreements then clear draft
var _applyForm = document.getElementById('applyForm');
if (_applyForm) {
  _applyForm.addEventListener('submit', function(e) {
    var unchecked = Array.from(document.querySelectorAll('.apw-agr-list .agr-check')).filter(function(c) { return !c.checked; });
    if (unchecked.length > 0) {
      e.preventDefault();
      unchecked[0].closest('.agr-item').style.outline = '2px solid #f87171';
      unchecked[0].closest('.agr-item').scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(function() {
        if (unchecked[0].closest('.agr-item')) unchecked[0].closest('.agr-item').style.outline = '';
      }, 2500);
      return;
    }
    clearDraft();
  });
}

// Restore draft on page load
loadDraft();
</script>

