<%- include('partials/head', { pageTitle: 'Upcoming Events' }) %>
<%- include('partials/header') %>

<%
const ISLAND = {
  jungle: { color:'#2f9e44', shade:'#1e5e2e',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path d="M10 4 C 18 14, 4 22, 14 32 S 8 42, 18 46" stroke="#37b24d" stroke-width="3" fill="none" stroke-linecap="round"/><ellipse cx="9" cy="14" rx="5" ry="3" fill="#2f9e44" transform="rotate(-30 9 14)"/><ellipse cx="15" cy="26" rx="5" ry="3" fill="#40c057" transform="rotate(20 15 26)"/><ellipse cx="11" cy="38" rx="5" ry="3" fill="#2f9e44" transform="rotate(-15 11 38)"/><path d="M30 46 L30 26" stroke="#7a5230" stroke-width="3"/><circle cx="30" cy="20" r="10" fill="#2b8a3e"/><circle cx="38" cy="24" r="7" fill="#37b24d"/></svg>`
  },
  snow: { color:'#74c0fc', shade:'#2b5d7a',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><polygon points="24,6 40,40 8,40" fill="#e7f5ff"/><polygon points="24,6 33,24 15,24" fill="#a5d8ff"/><polygon points="14,40 24,24 34,40" fill="#fff"/><g stroke="#d0ebff" stroke-width="2" stroke-linecap="round"><path d="M24 8 v8 M20 12 h8 M40 14 v6 M37 17 h6"/></g></svg>`
  },
  badlands: { color:'#e8590c', shade:'#7a3b12',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="30" width="36" height="12" fill="#d9480f"/><rect x="6" y="24" width="36" height="6" fill="#e8590c"/><rect x="6" y="18" width="36" height="6" fill="#f08c00"/><rect x="14" y="10" width="9" height="20" fill="#e8590c"/><rect x="14" y="6" width="9" height="4" fill="#ffa94d"/><rect x="28" y="14" width="8" height="16" fill="#d9480f"/></svg>`
  },
  forest: { color:'#82c91e', shade:'#3d6312',
    ico:`<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><rect x="22" y="34" width="4" height="10" fill="#7a5230"/><polygon points="24,6 36,24 12,24" fill="#5c940d"/><polygon points="24,14 38,34 10,34" fill="#82c91e"/><polygon points="24,22 40,40 8,40" fill="#a9e34b"/></svg>`
  }
};
%>

<main class="wrap">

  <div class="page-head">
    <a href="/" class="back">← Home</a>
    <div>
      <h1 class="page-title">Upcoming Events</h1>
      <p class="page-sub">Click an event to see the full details.</p>
    </div>
  </div>

  <% if (events.length === 0) { %>
    <p style="color:var(--muted);font-size:15px;text-align:center;padding:60px 0;">No events scheduled yet — check back soon.</p>
  <% } else { %>
  <div class="event-list">
    <% events.forEach(function(ev) { %>
      <% const theme = ev.theme || 'default'; %>
      <% const isl = ISLAND[theme]; %>
      <a href="/events/<%= ev.id %>" class="efeat">
        <div class="efeat-art">
          <% if (ev.card_image) { %>
            <div class="efeat-art-blur" style="background-image:url('<%= ev.card_image %>')"></div>
            <img src="<%= ev.card_image %>" alt="<%= ev.title %>">
          <% } else { %>
            <!-- Placeholder art until image is provided -->
            <div class="efeat-art-placeholder">
              <% if (theme === '4island' || theme === 'multi') { %>
                <div style="position:absolute;inset:0;display:flex">
                  <div style="flex:1;background:linear-gradient(180deg,#1e5e2e,#103a1d)"></div>
                  <div style="flex:1;background:linear-gradient(180deg,#2b5d7a,#1a3550)"></div>
                  <div style="flex:1;background:linear-gradient(180deg,#7a3b12,#3a1c08)"></div>
                  <div style="flex:1;background:linear-gradient(180deg,#3d6312,#16320f)"></div>
                </div>
                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:space-around;padding:0 60px">
                  <div style="width:120px;height:120px;filter:drop-shadow(0 8px 20px rgba(0,0,0,.6))"><%- ISLAND.jungle.ico %></div>
                  <div style="width:120px;height:120px;filter:drop-shadow(0 8px 20px rgba(0,0,0,.6))"><%- ISLAND.snow.ico %></div>
                  <div style="width:120px;height:120px;filter:drop-shadow(0 8px 20px rgba(0,0,0,.6))"><%- ISLAND.badlands.ico %></div>
                  <div style="width:120px;height:120px;filter:drop-shadow(0 8px 20px rgba(0,0,0,.6))"><%- ISLAND.forest.ico %></div>
                </div>
              <% } else if (isl) { %>
                <div style="position:absolute;inset:0;background:linear-gradient(135deg,<%= isl.shade %>,#0c0d10)"></div>
                <div style="width:180px;height:180px;filter:drop-shadow(0 12px 30px rgba(0,0,0,.7))"><%- isl.ico %></div>
              <% } else { %>
                <div style="position:absolute;inset:0;background:linear-gradient(135deg,#1d1f26,#0c0d10)"></div>
              <% } %>
            </div>
          <% } %>
        </div>
        <div class="efeat-foot">
          <div>
            <div class="efeat-name"><%= ev.title %></div>
            <div class="efeat-meta">
              <% if (ev.event_date) { %>
                Starts <%= new Date(ev.event_date).toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'long',year:'numeric'}) %>
              <% } else if (ev.is_open) { %>
                Applications open now
              <% } else { %>
                Coming soon
              <% } %>
            </div>
          </div>
          <span class="efeat-cta">View details →</span>
        </div>
      </a>
    <% }); %>
  </div>
  <% } %>

</main>

<%- include('partials/foot') %>
